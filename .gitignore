# ---------------------------------------------------------------------------
# Rust / Cargo
# ---------------------------------------------------------------------------
target/
debug/
**/*.rs.bk
.rustc_info.json
.cargo-ok

# MSVC Windows (debug symbols from rustc)
*.pdb
*.exp
*.ilk

# Generated by cargo mutants
**/mutants.out*/

# Optional Rust tooling caches
.sccache/
.cache/

# ---------------------------------------------------------------------------
# Secrets and local env
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
!LICENSE

# ---------------------------------------------------------------------------
# Logs, profiling, coverage
# ---------------------------------------------------------------------------
*.log
perf.data
perf.data.old
*.profraw
*.profdata
coverage/
lcov.info
*.lcov
tarpaulin-report.html
flamegraph.svg

# ---------------------------------------------------------------------------
# Temp files from atomic writes / tests
# ---------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*.reconstructing
*.orchid-decrypting

# ---------------------------------------------------------------------------
# Stray notes / scratch files accidentally dropped into the repo
# ---------------------------------------------------------------------------
Untitled
Untitled.*
*.scratch

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Editors / IDEs / AI assistants
# ---------------------------------------------------------------------------
.idea/
.vs/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.fleet/
.nova/
*.iml

# Cursor / Claude / Copilot / Codeium session artefacts
.cursor/
.cursorrules.local
.claude/
.codeium/
.aider*
.continue/
agent-tools/
agent-transcripts/

# ---------------------------------------------------------------------------
# Node / web tooling (defensive — no JS project yet, but prevents surprises)
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
dist/

# JetBrains template reference:
# https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
