import { Theme } from "theme_global.slint";
import { NavigationGlobal } from "navigation_global.slint";
import { NotificationGlobal } from "notification_global.slint";
import { AppState } from "app_state_global.slint";

export component NotificationCenter inherits Rectangle {
    callback dismiss();

    width: 320px;
    background: Theme.surface-raised;

    // Edge facing the canvas: opposite the docked side.
    Rectangle {
        x: AppState.edge-panels-mirrored ? parent.width - 1px : 0;
        width: 1px;
        height: parent.height;
        background: Theme.border-default;
    }

    VerticalLayout {
        width: parent.width;
        height: 100%;
        padding: Theme.spacing-unit * 2;
        spacing: Theme.spacing-unit;

        HorizontalLayout {
            spacing: Theme.spacing-unit;

            Text {
                text: NavigationGlobal.notification-center-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            if NotificationGlobal.notifications.length > 0: Rectangle {
                height: 32px;
                border-radius: Theme.radius-md;
                background: clear-ta.has-hover ? Theme.surface-base : transparent;

                clear-ta := TouchArea {
                    clicked => { NotificationGlobal.clear-all(); }
                }
                if clear-ta.has-hover : Rectangle {
                    x: parent.x;
                    y: parent.height + 2px;
                    width: clear-hint.preferred-width + 12px;
                    height: clear-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    clear-hint := Text {
                        x: 6px; y: 3px;
                        text: NotificationGlobal.clear-all-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                HorizontalLayout {
                    padding-left: Theme.spacing-unit;
                    padding-right: Theme.spacing-unit;
                    alignment: center;

                    Text {
                        text: NotificationGlobal.clear-all-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                width: 32px;
                height: 32px;
                background: Theme.surface-base;
                border-radius: Theme.radius-md;

                panel-close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }
                if panel-close-ta.has-hover : Rectangle {
                    x: parent.x - panel-close-hint.preferred-width - 8px;
                    y: parent.height + 2px;
                    width: panel-close-hint.preferred-width + 12px;
                    height: panel-close-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    panel-close-hint := Text {
                        x: 6px; y: 3px;
                        text: NavigationGlobal.panel-dismiss-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        if NotificationGlobal.notifications.length == 0: Text {
            text: NotificationGlobal.empty-placeholder;
            color: Theme.text-secondary;
            font-size: Theme.font-size-sm;
            wrap: word-wrap;
            vertical-stretch: 1;
            vertical-alignment: top;
        }

        if NotificationGlobal.notifications.length > 0: Flickable {
            vertical-stretch: 1;
            width: 100%;
            viewport-width: self.width;
            viewport-height: list.preferred-height;

            list := VerticalLayout {
                width: parent.viewport-width;
                spacing: Theme.spacing-unit;

                for item in NotificationGlobal.notifications: Rectangle {
                    background: Theme.surface-base;
                    border-radius: Theme.radius-md;
                    clip: true;

                    HorizontalLayout {
                        spacing: 0;

                        Rectangle {
                            width: 3px;
                            background: item.severity >= 3
                                ? #e85d5d
                                : (item.severity == 2
                                    ? #d4a017
                                    : Theme.accent-brand);
                        }

                        VerticalLayout {
                            padding: Theme.spacing-unit * 1.5;
                            spacing: 4px;
                            horizontal-stretch: 1;

                            HorizontalLayout {
                                spacing: Theme.spacing-unit;

                                Text {
                                    text: item.title;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-size-sm;
                                    font-weight: Theme.weight-semibold;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: item.time-label;
                                    color: Theme.text-tertiary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    border-radius: Theme.radius-md;
                                    background: dismiss-ta.has-hover ? Theme.surface-raised : transparent;

                                    dismiss-ta := TouchArea {
                                        clicked => { NotificationGlobal.dismiss-item(item.id); }
                                    }
                                    if dismiss-ta.has-hover : Rectangle {
                                        x: parent.x - item-dismiss-hint.preferred-width - 8px;
                                        y: parent.height + 2px;
                                        width: item-dismiss-hint.preferred-width + 12px;
                                        height: item-dismiss-hint.preferred-height + 6px;
                                        background: Theme.surface-raised;
                                        border-radius: Theme.radius-md;
                                        border-width: 1px;
                                        border-color: Theme.border-default;
                                        z: 100;
                                        item-dismiss-hint := Text {
                                            x: 6px; y: 3px;
                                            text: NotificationGlobal.dismiss-label;
                                            color: Theme.text-secondary;
                                            font-size: Theme.font-size-sm;
                                        }
                                    }

                                    Text {
                                        text: "×";
                                        color: Theme.text-tertiary;
                                        font-size: Theme.font-size-md;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            if item.body != "": Text {
                                text: item.body;
                                color: Theme.text-secondary;
                                font-size: Theme.font-size-sm;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }
    }
}
