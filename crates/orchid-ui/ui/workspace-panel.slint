import { Theme } from "theme_global.slint";
import { NavigationGlobal } from "navigation_global.slint";
import { AppState } from "app_state_global.slint";

export component WorkspacePanel inherits Rectangle {
    callback workspace-clicked(string);
    callback dismiss();

    width: 280px;
    background: Theme.surface-raised;

    // Edge facing the canvas: opposite the docked side.
    Rectangle {
        x: AppState.edge-panels-mirrored ? 0 : parent.width - 1px;
        width: 1px;
        height: parent.height;
        background: Theme.border-default;
    }

    VerticalLayout {
        width: parent.width;
        height: 100%;
        padding: Theme.spacing-unit * 2;
        spacing: Theme.spacing-unit;

        HorizontalLayout {
            Text {
                text: NavigationGlobal.workspace-panel-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 32px;
                height: 32px;
                background: Theme.surface-base;
                border-radius: Theme.radius-md;

                panel-close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }
                if panel-close-ta.has-hover : Rectangle {
                    x: parent.x - panel-close-hint.preferred-width - 8px;
                    y: parent.height + 2px;
                    width: panel-close-hint.preferred-width + 12px;
                    height: panel-close-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    panel-close-hint := Text {
                        x: 6px; y: 3px;
                        text: NavigationGlobal.panel-dismiss-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Flickable {
            vertical-stretch: 1;
            width: 100%;

            VerticalLayout {
                spacing: 4px;

                for ws in AppState.workspace.workspaces: Rectangle {
                    height: 36px;
                    background: ws.is-active ? Theme.accent-brand : Theme.surface-base;
                    border-radius: Theme.radius-md;

                    ws-ta := TouchArea {
                        clicked => {
                            root.workspace-clicked(ws.id);
                            root.dismiss();
                        }
                    }
                    if ws-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: ws-hint.preferred-width + 12px;
                        height: ws-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        ws-hint := Text {
                            x: 6px; y: 3px;
                            text: ws.name;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    Text {
                        text: ws.name;
                        color: ws.is-active ? Theme.text-primary : Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        font-weight: ws.is-active ? Theme.weight-semibold : Theme.weight-regular;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        wrap: no-wrap;
                        overflow: elide;
                    }
                }
            }
        }
    }
}
