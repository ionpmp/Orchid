import { WorkspaceModel } from "workspace/defs.slint";

export global AppState {
    in property <string> current-theme-id;
    in property <string> current-language;
    in property <string> current-density;
    // True when `current-language` is Arabic (BCP-47 tag starts with "ar").
    in property <bool> is-rtl;
    // Workspace/notification docking + edge-swipe targets: flipped for RTL,
    // left-handed primary hand, or input.mirror-edge-swipes.
    in property <bool> edge-panels-mirrored;
    in property <int> mode;
    in property <WorkspaceModel> workspace;
}
