import { Theme } from "../theme_global.slint";
import { WidgetCloseConfirmDialog } from "defs.slint";

export component WidgetCloseConfirmDialog inherits Rectangle {
    in property <WidgetCloseConfirmDialog> dialog;
    callback save();
    callback discard();
    callback cancel();

    background: #00000080;

    backdrop-ta := TouchArea {
        clicked => { root.cancel(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 360px;
        height: lay.preferred-height + 16px;
        background: Theme.surface-raised;
        border-radius: Theme.radius-md;
        drop-shadow-blur: Theme.reduce-motion ? 0px : 16px;
        drop-shadow-color: #00000080;

        lay := VerticalLayout {
            padding: 16px;
            spacing: 12px;

            Text {
                text: dialog.title;
                color: Theme.text-primary;
                font-size: Theme.font-size-lg;
                font-weight: Theme.weight-semibold;
            }

            Text {
                text: dialog.message;
                color: Theme.text-secondary;
                font-size: Theme.font-size-md;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: end;

                Rectangle {
                    width: max(72px, cancel-label.preferred-width + 16px);
                    height: 32px;
                    background: cancel-ta.has-hover ? Theme.surface-base : transparent;
                    border-radius: Theme.radius-md;
                    cancel-ta := TouchArea { clicked => { root.cancel(); } }
                    if cancel-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: cancel-hint.preferred-width + 12px;
                        height: cancel-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        cancel-hint := Text {
                            x: 6px; y: 3px;
                            text: dialog.cancel-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    cancel-label := Text {
                        text: dialog.cancel-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: max(72px, discard-label.preferred-width + 16px);
                    height: 32px;
                    background: discard-ta.has-hover ? #ef444444 : #ef444422;
                    border-radius: Theme.radius-md;
                    border-width: discard-ta.has-hover ? 1px : 0px;
                    border-color: discard-ta.has-hover ? #ef4444 : transparent;
                    discard-ta := TouchArea { clicked => { root.discard(); } }
                    if discard-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: discard-hint.preferred-width + 12px;
                        height: discard-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        discard-hint := Text {
                            x: 6px; y: 3px;
                            text: dialog.discard-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    discard-label := Text {
                        text: dialog.discard-label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: max(72px, save-label.preferred-width + 16px);
                    height: 32px;
                    background: save-ta.has-hover ? Theme.accent-brand : #4d82ff88;
                    border-radius: Theme.radius-md;
                    save-ta := TouchArea { clicked => { root.save(); } }
                    if save-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: save-hint.preferred-width + 12px;
                        height: save-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        save-hint := Text {
                            x: 6px; y: 3px;
                            text: dialog.save-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    save-label := Text {
                        text: dialog.save-label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
