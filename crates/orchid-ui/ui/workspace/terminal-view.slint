import { Theme } from "../theme_global.slint";
import { TerminalCellModel } from "defs.slint";

// Use built-in `TextInput` (not `FocusScope`) to receive key events. On winit+Windows
// the plain `FocusScope` path is unreliable: `KeyEvent::text` can be empty or pre-wrapped
// in spurious C0/PUA codepoints, so the PTY never got consistent bytes. `TextInput` uses
// the same text pipeline as the platform text system (layouts, @/#, IME-friendly).
// Slint 1.16 `KeyEvent` has `text` + `modifiers` (no separate `event.key`); Rust maps PUA /
// C0 key identities via `orchid_terminal::InputEncoder`.
export component TerminalView inherits Rectangle {
    forward-focus: text-input;
    in property <int> cols;
    in property <int> rows;
    in property <[[TerminalCellModel]]> cells;
    in property <image> pixels;
    in property <int> cursor-col;
    in property <int> cursor-row;
    in property <bool> cursor-visible;
    in property <length> cell-width;
    in property <length> cell-height;

    in property <bool> input-enabled: true;

    callback key-pressed(string, bool, bool, bool);
    callback shortcut(string);

    background: Theme.surface-base;

    Image {
        width: 100%;
        height: 100%;
        source: root.pixels;
        image-fit: fill;
    }

    text-input := TextInput {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        text: "";
        single-line: true;
        font-size: 0.1px;
        // Match canvas so a stray space is invisible; raster is drawn in the `Image` below.
        color: Theme.surface-base;
        text-cursor-width: 0px;
        enabled: root.input-enabled;
        read-only: false;
        // Handle keys in two ways: (1) when `key-pressed` has `event.text` (or a Key.* match),
        // `accept` and send to the PTY; (2) when the platform gives an empty `event.text` for
        // Shift+digit (@/#/$ on US), return `reject` so TextInput inserts, then `edited` sends
        // the new buffer and clears. Never `accept` without having forwarded â€” that swallowed
        // @/#/$ on Windows+TextInput.
        key-pressed(event) => {
            if (root.input-enabled) {
                if (event.modifiers.control && event.modifiers.shift) {
                    if (event.text == "h" || event.text == "H") {
                        root.shortcut("split-h");
                        return accept;
                    }
                    if (event.text == "j" || event.text == "J") {
                        root.shortcut("split-v");
                        return accept;
                    }
                    if (event.text == "t" || event.text == "T") {
                        root.shortcut("tab-new");
                        return accept;
                    }
                    if (event.text == "w" || event.text == "W") {
                        root.shortcut("close");
                        return accept;
                    }
                    if (event.text == Key.RightArrow) {
                        root.shortcut("focus-next");
                        return accept;
                    }
                    if (event.text == Key.LeftArrow) {
                        root.shortcut("focus-prev");
                        return accept;
                    }
                }
                if (event.modifiers.control && !event.modifiers.shift) {
                    if (event.text == Key.PageDown) {
                        root.shortcut("tab-next");
                        return accept;
                    }
                    if (event.text == Key.PageUp) {
                        root.shortcut("tab-prev");
                        return accept;
                    }
                }
            }
            if (event.text != "") {
                root.key-pressed(
                    event.text,
                    event.modifiers.control,
                    event.modifiers.shift,
                    event.modifiers.alt
                );
                self.text = "";
                return accept;
            }
            // Let the widget apply the key; we pick the inserted text in `edited`.
            return reject;
        }
        edited() => {
            if (self.text == "") { return; }
            root.key-pressed(self.text, false, false, false);
            self.text = "";
        }
    }
}
