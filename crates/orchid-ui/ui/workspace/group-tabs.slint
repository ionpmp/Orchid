import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { GroupTabModel } from "defs.slint";

/// Compact tab strip for widgets stacked in a shared layout slot.
export component GroupTabs inherits Rectangle {
    in property <[GroupTabModel]> tabs;

    callback tab-clicked(string);
    callback tab-closed(string);
    callback tab-move-left(string);
    callback tab-move-right(string);
    callback dissolve-clicked();

    height: 28px;
    background: Theme.surface-raised;

    HorizontalLayout {
        padding: 2px;
        spacing: 2px;

        for tab[i] in tabs : Rectangle {
            width: 140px;
            height: 24px;
            background: tab.is-active ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;

                tab-ta := TouchArea {
                    horizontal-stretch: 1;
                    clicked => { root.tab-clicked(tab.instance-id); }

                    Text {
                        text: tab.title;
                        color: tab.is-active ? Theme.text-primary : Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        font-weight: tab.is-active ? Theme.weight-medium : Theme.weight-regular;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                if i > 0 : Rectangle {
                    width: 16px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: left-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: 8px;
                    left-ta := TouchArea {
                        clicked => { root.tab-move-left(tab.instance-id); }
                    }
                    Text {
                        text: "‹";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if i + 1 < tabs.length : Rectangle {
                    width: 16px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: right-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: 8px;
                    right-ta := TouchArea {
                        clicked => { root.tab-move-right(tab.instance-id); }
                    }
                    Text {
                        text: "›";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 18px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: close-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: 9px;

                    close-ta := TouchArea {
                        clicked => { root.tab-closed(tab.instance-id); }
                    }

                    Text {
                        text: "×";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            width: 28px;
            height: 24px;
            background: dissolve-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            dissolve-ta := TouchArea {
                clicked => { root.dissolve-clicked(); }
            }

            if dissolve-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: hint.preferred-width + 12px;
                height: hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;

                hint := Text {
                    x: 6px;
                    y: 3px;
                    text: Strings.group-tooltip-dissolve;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            Text {
                text: "⧉";
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
