import { Theme } from "../theme_global.slint";
import { WidgetFrame } from "widget-frame.slint";
import { WorkspaceSwitcher } from "workspace-switcher.slint";
import { WidgetDock } from "widget-dock.slint";
import { WorkspaceModel, WorkspaceSummary, WidgetFrameModel, DockWidgetType } from "defs.slint";

export component WorkspaceView inherits Rectangle {
    in property <WorkspaceModel> workspace;

    callback workspace-clicked(string);
    callback workspace-create-clicked();
    callback dock-add-clicked(string);
    callback widget-close-clicked(string);
    callback widget-drag-started(string, length, length);
    callback widget-drag-moved(string, length, length);
    callback widget-drag-ended(string);
    callback widget-resize-started(string, string, length, length);
    callback widget-resize-moved(string, length, length);
    callback widget-resize-ended(string);
    callback terminal-key-pressed(string, string);
    callback terminal-viewport-changed(string, length, length);
    callback rss-item-clicked(string);
    callback search-query-changed(string, string);
    callback search-candidate-activated(string, string);
    callback search-selection-changed(string, int);
    callback media-play-pause();
    callback media-next();
    callback media-previous();
    callback password-search-changed(string);
    callback password-entry-clicked(string);
    callback password-copy-password(string);
    callback password-copy-username(string);
    callback password-copy-totp(string);
    callback password-open-url(string);

    background: Theme.surface-base;

    WorkspaceSwitcher {
        x: 0;
        y: 0;
        width: parent.width;
        height: 40px;
        workspaces: root.workspace.workspaces;
        active-workspace-id: root.workspace.active-workspace-id;
        workspace-clicked(id) => { root.workspace-clicked(id); }
        workspace-create-clicked => { root.workspace-create-clicked(); }
    }

    canvas := Rectangle {
        x: 0;
        y: 40px;
        width: parent.width;
        height: parent.height - 40px - 64px;
        background: Theme.surface-base;
        clip: true;

        // With `for` children, Flickable does not infer viewport size (Slint #407); set it explicitly
        // so wheel / drag scrolling works when the logical grid is taller than the visible area.
        // `interactive: false`: otherwise Slint starts canvas flick after 8px move in 500ms and
        // cancels the widget header TouchArea — vertical widget drags fail. Wheel scroll still works.
        canvas-flick := Flickable {
            interactive: false;
            width: parent.width;
            height: parent.height;
            viewport-width: max(root.workspace.canvas-content-width, self.width);
            viewport-height: max(root.workspace.canvas-content-height, self.height);

            // Must match viewport-*: `parent` here is not reliably the full scroll extent (Slint Flickable).
            canvas-inner := Rectangle {
                width: max(root.workspace.canvas-content-width, canvas-flick.width);
                height: max(root.workspace.canvas-content-height, canvas-flick.height);
                background: Theme.surface-base;

                for w[i] in root.workspace.widgets: WidgetFrame {
                    x: w.x;
                    y: w.y;
                    width: w.width;
                    height: w.height;
                    model: w;
                    close-clicked => { root.widget-close-clicked(w.instance-id); }
                    drag-started(dx, dy) => { root.widget-drag-started(w.instance-id, dx, dy); }
                    drag-moved(dx, dy) => { root.widget-drag-moved(w.instance-id, dx, dy); }
                    drag-ended => { root.widget-drag-ended(w.instance-id); }
                    resize-started(c, px, py) => { root.widget-resize-started(w.instance-id, c, px, py); }
                    resize-moved(px, py) => { root.widget-resize-moved(w.instance-id, px, py); }
                    resize-ended => { root.widget-resize-ended(w.instance-id); }
                    terminal-key-pressed(text) => { root.terminal-key-pressed(w.instance-id, text); }
                    terminal-viewport-changed(w_, h_) => { root.terminal-viewport-changed(w.instance-id, w_, h_); }
                    rss-item-clicked(link) => { root.rss-item-clicked(link); }
                    search-query-changed(inst, q) => { root.search-query-changed(inst, q); }
                    search-candidate-activated(inst, id) => { root.search-candidate-activated(inst, id); }
                    search-selection-changed(inst, idx) => { root.search-selection-changed(inst, idx); }
                    media-play-pause => { root.media-play-pause(); }
                    media-next => { root.media-next(); }
                    media-previous => { root.media-previous(); }
                    password-search-changed(q) => { root.password-search-changed(q); }
                    password-entry-clicked(id) => { root.password-entry-clicked(id); }
                    password-copy-password(id) => { root.password-copy-password(id); }
                    password-copy-username(id) => { root.password-copy-username(id); }
                    password-copy-totp(id) => { root.password-copy-totp(id); }
                    password-open-url(url) => { root.password-open-url(url); }
                }
            }
        }
    }

    WidgetDock {
        x: 0;
        y: parent.height - 64px;
        width: parent.width;
        height: 64px;
        dock-types: root.workspace.dock-types;
        dock-add-label: root.workspace.dock-add-label;
        add-clicked(type-id) => { root.dock-add-clicked(type-id); }
    }
}
