import { Theme } from "../theme_global.slint";
import { NavigationGlobal } from "../navigation_global.slint";
import { WidgetCatalog } from "../widget_catalog_global.slint";
import { WidgetFrame } from "widget-frame.slint";
import { WorkspaceSwitcher } from "workspace-switcher.slint";
import { WidgetDock } from "widget-dock.slint";
import { WidgetCatalogPanel } from "widget-catalog.slint";
import { WorkspaceModel, WorkspaceSummary, WidgetFrameModel, DockWidgetType } from "defs.slint";

export component WorkspaceView inherits Rectangle {
    in property <WorkspaceModel> workspace;

    callback workspace-clicked(string);
    callback workspace-create-clicked();
    callback dock-add-clicked(string);
    callback widget-close-clicked(string);
    callback widget-close-confirm-save(string);
    callback widget-close-confirm-discard(string);
    callback widget-close-confirm-cancel(string);
    callback widget-drag-started(string, length, length);
    callback widget-drag-moved(string, length, length);
    callback widget-drag-ended(string);
    callback widget-resize-started(string, string, length, length);
    callback widget-resize-moved(string, length, length);
    callback widget-resize-ended(string);
    callback group-tab-clicked(string, string);
    callback group-dissolve-clicked(string);
    callback terminal-key-pressed(string, string, bool, bool, bool);
    callback terminal-viewport-changed(string, length, length);
    callback terminal-tab-clicked(string, int);
    callback terminal-tab-closed(string, int);
    callback terminal-tab-new(string);
    callback terminal-split-horizontal(string);
    callback terminal-split-vertical(string);
    callback terminal-pane-clicked(string, string);
    callback terminal-pane-closed(string, string);
    callback terminal-split-drag-moved(string, string, string, float, float);
    callback terminal-shortcut(string, string);
    callback rss-item-clicked(string);
    callback recent-files-item-clicked(string);
    callback search-query-changed(string, string);
    callback search-candidate-activated(string, string);
    callback search-selection-changed(string, int);
    callback media-play-pause();
    callback media-next();
    callback media-previous();
    callback password-search-changed(string);
    callback password-entry-clicked(string);
    callback password-copy-password(string);
    callback password-copy-username(string);
    callback password-copy-totp(string);
    callback password-open-url(string);
    callback password-unlock-submit(string);
    callback password-unlock-biometric();
    callback password-lock-vault();
    callback password-add-entry-request();
    callback password-add-entry-commit(string, string, string, string);
    callback password-add-entry-cancel();
    callback password-add-entry-generate-password();

    callback viewer-image-zoom-in(string);
    callback viewer-image-zoom-out(string);
    callback viewer-image-fit(string);
    callback viewer-image-actual-size(string);
    callback viewer-image-rotate-cw(string);
    callback viewer-image-rotate-ccw(string);
    callback viewer-image-pan(string, length, length);
    callback viewer-viewport-changed(string, length, length);
    callback viewer-pdf-prev-page(string);
    callback viewer-pdf-next-page(string);
    callback viewer-pdf-fit-width(string, length);
    callback viewer-pdf-fit-page(string, length, length);
    callback viewer-pdf-zoom-in(string);
    callback viewer-pdf-zoom-out(string);
    callback viewer-pdf-go-to-page(string, int);
    callback viewer-archive-navigate-into(string, string);
    callback viewer-archive-navigate-up(string);
    callback viewer-archive-select(string, string);
    callback viewer-archive-extract-selected(string);
    callback viewer-archive-extract-all(string);
    callback viewer-text-toggle-edit(string);
    callback viewer-text-save(string);
    callback viewer-text-edited(string, string);

    callback fm-sidebar-clicked(string, string);
    callback fm-toggle-dual-pane(string);
    callback fm-toggle-show-hidden(string);
    callback fm-toggle-click-behavior(string);
    callback fm-pane-clicked(string, int);
    callback fm-tab-clicked(string, int, string);
    callback fm-tab-closed(string, int, string);
    callback fm-tab-new(string, int);
    callback fm-new-folder(string, int);
    callback fm-nav-back(string, int);
    callback fm-nav-forward(string, int);
    callback fm-nav-up(string, int);
    callback fm-breadcrumb-clicked(string, int, string);
    callback fm-view-mode-cycle(string, int);
    callback fm-sort-cycle(string, int);
    callback fm-sort-column-clicked(string, int, int);
    callback fm-quick-filter-changed(string, int, string);
    callback fm-entry-clicked(string, int, string, bool);
    callback fm-entry-shift-clicked(string, int, string);
    callback fm-entry-double-clicked(string, int, string, bool);
    callback fm-entry-context(string, int, string, length, length);
    callback fm-context-action(string, string, [string]);
    callback fm-context-dismiss(string);
    callback fm-confirm-yes(string);
    callback fm-confirm-no(string);
    callback fm-rename-commit(string, string, string);
    callback fm-rename-cancel(string);
    callback fm-tag-commit(string, string);
    callback fm-tag-cancel(string);
    callback fm-passphrase-commit(string, string);
    callback fm-passphrase-cancel(string);
    callback fm-passphrase-biometric(string);
    callback fm-managed-policy-close(string);
    callback fm-select-all(string, int);
    callback fm-delete-selected(string, int);
    callback fm-copy-selected(string, int);
    callback fm-paste-clipboard(string, int);
    callback fm-rename-selected(string, int);
    callback fm-deselect-all(string, int);
    callback fm-open-selected(string, int);
    callback fm-entry-drag-start(string, int, string);
    callback fm-entry-drag-hover(string, int, string);
    callback fm-entry-drag-drop(string, int, string);
    callback fm-entry-drag-cancel(string, int);
    callback fm-pane-drag-hover(string, int);
    callback fm-drop-on-current-dir(string, int);
    callback fm-entry-drag-scroll(string, int, length, length, length, length);
    callback fm-error-action(string, int);

    callback canvas-long-pressed(length, length, length, length);
    callback canvas-scrolled(length, length);
    callback catalog-pick(string);
    callback catalog-dismiss();
    callback catalog-search-changed(string);

    background: Theme.surface-base;

    WorkspaceSwitcher {
        x: 0;
        y: 0;
        width: parent.width;
        height: 40px;
        workspaces: root.workspace.workspaces;
        active-workspace-id: root.workspace.active-workspace-id;
        workspace-clicked(id) => { root.workspace-clicked(id); }
        workspace-create-clicked => { root.workspace-create-clicked(); }
    }

    if NavigationGlobal.hint-mode-enabled: Rectangle {
        x: 12px;
        y: 44px;
        width: hint-workspace.preferred-width + 16px;
        height: hint-workspace.preferred-height + 10px;
        background: #00000088;
        border-radius: Theme.radius-md;

        hint-workspace := Text {
            x: 8px;
            y: 5px;
            text: NavigationGlobal.hint-workspace-label;
            color: #ffffff;
            font-size: Theme.font-size-sm;
            wrap: word-wrap;
        }
    }

    property <length> dock-height: NavigationGlobal.dock-visible ? 64px : 0px;
    animate dock-height {
        duration: Theme.reduce-motion ? 0ms : 180ms;
        easing: ease-out;
    }

    canvas := Rectangle {
        x: 0;
        y: 40px;
        width: parent.width;
        height: parent.height - 40px - root.dock-height;
        background: Theme.surface-base;
        clip: true;

        // With `for` children, Flickable does not infer viewport size (Slint #407); set it explicitly
        // so wheel / drag scrolling works when the logical grid is taller than the visible area.
        // `interactive: false`: otherwise Slint starts canvas flick after 8px move in 500ms and
        // cancels the widget header TouchArea — vertical widget drags fail. Wheel scroll still works.
        canvas-flick := Flickable {
            interactive: false;
            width: parent.width;
            height: parent.height;
            viewport-width: max(root.workspace.canvas-content-width, self.width);
            viewport-height: max(root.workspace.canvas-content-height, self.height);

            changed viewport-x => {
                root.canvas-scrolled(canvas-flick.viewport-x, canvas-flick.viewport-y);
            }
            changed viewport-y => {
                root.canvas-scrolled(canvas-flick.viewport-x, canvas-flick.viewport-y);
            }

            // Must match viewport-*: `parent` here is not reliably the full scroll extent (Slint Flickable).
            canvas-inner := Rectangle {
                width: max(root.workspace.canvas-content-width, canvas-flick.width);
                height: max(root.workspace.canvas-content-height, canvas-flick.height);
                background: Theme.surface-base;

                property <bool> long-press-armed: false;
                property <length> long-press-content-x: 0;
                property <length> long-press-content-y: 0;
                property <length> long-press-viewport-x: 0;
                property <length> long-press-viewport-y: 0;
                property <length> long-press-down-x: 0;
                property <length> long-press-down-y: 0;

                long-press-timer := Timer {
                    interval: 500ms;
                    running: canvas-inner.long-press-armed;
                    triggered => {
                        canvas-inner.long-press-armed = false;
                        root.canvas-long-pressed(
                            canvas-inner.long-press-content-x,
                            canvas-inner.long-press-content-y,
                            canvas-inner.long-press-viewport-x,
                            canvas-inner.long-press-viewport-y,
                        );
                    }
                }

                // Behind widgets: empty canvas hits here; widgets stay on top.
                canvas-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    pointer-event(event) => {
                        if (event.kind == PointerEventKind.down) {
                            canvas-inner.long-press-down-x = self.mouse-x;
                            canvas-inner.long-press-down-y = self.mouse-y;
                            canvas-inner.long-press-content-x = self.mouse-x + canvas-flick.viewport-x;
                            canvas-inner.long-press-content-y = self.mouse-y + canvas-flick.viewport-y;
                            canvas-inner.long-press-viewport-x = canvas-flick.viewport-x;
                            canvas-inner.long-press-viewport-y = canvas-flick.viewport-y;
                            canvas-inner.long-press-armed = true;
                        } else if (event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel) {
                            canvas-inner.long-press-armed = false;
                        }
                    }
                    moved => {
                        if (canvas-inner.long-press-armed
                            && (abs(self.mouse-x - canvas-inner.long-press-down-x) > 8px
                                || abs(self.mouse-y - canvas-inner.long-press-down-y) > 8px)) {
                            canvas-inner.long-press-armed = false;
                        }
                    }
                }

                for w[i] in root.workspace.widgets: WidgetFrame {
                    x: w.x;
                    y: w.y;
                    width: w.width;
                    height: w.height;
                    model: w;
                    close-clicked => { root.widget-close-clicked(w.instance-id); }
                    close-confirm-save(id) => { root.widget-close-confirm-save(id); }
                    close-confirm-discard(id) => { root.widget-close-confirm-discard(id); }
                    close-confirm-cancel(id) => { root.widget-close-confirm-cancel(id); }
                    drag-started(dx, dy) => { root.widget-drag-started(w.instance-id, dx, dy); }
                    drag-moved(dx, dy) => { root.widget-drag-moved(w.instance-id, dx, dy); }
                    drag-ended => { root.widget-drag-ended(w.instance-id); }
                    resize-started(c, px, py) => { root.widget-resize-started(w.instance-id, c, px, py); }
                    resize-moved(px, py) => { root.widget-resize-moved(w.instance-id, px, py); }
                    resize-ended => { root.widget-resize-ended(w.instance-id); }
                    group-tab-clicked(member-id) => { root.group-tab-clicked(w.group-id, member-id); }
                    group-dissolve-clicked => { root.group-dissolve-clicked(w.group-id); }
                    terminal-key-pressed(text, ctrl, shift, alt) => {
                        root.terminal-key-pressed(w.instance-id, text, ctrl, shift, alt);
                    }
                    terminal-viewport-changed(w_, h_) => { root.terminal-viewport-changed(w.instance-id, w_, h_); }
                    terminal-tab-clicked(idx) => { root.terminal-tab-clicked(w.instance-id, idx); }
                    terminal-tab-closed(idx) => { root.terminal-tab-closed(w.instance-id, idx); }
                    terminal-tab-new => { root.terminal-tab-new(w.instance-id); }
                    terminal-split-horizontal => { root.terminal-split-horizontal(w.instance-id); }
                    terminal-split-vertical => { root.terminal-split-vertical(w.instance-id); }
                    terminal-pane-clicked(sid) => { root.terminal-pane-clicked(w.instance-id, sid); }
                    terminal-pane-closed(sid) => { root.terminal-pane-closed(w.instance-id, sid); }
                    terminal-split-drag-moved(a, b, fx, fy) => {
                        root.terminal-split-drag-moved(w.instance-id, a, b, fx, fy);
                    }
                    terminal-shortcut(action) => { root.terminal-shortcut(w.instance-id, action); }
                    rss-item-clicked(link) => { root.rss-item-clicked(link); }
                    recent-files-item-clicked(path) => { root.recent-files-item-clicked(path); }
                    search-query-changed(inst, q) => { root.search-query-changed(inst, q); }
                    search-candidate-activated(inst, id) => { root.search-candidate-activated(inst, id); }
                    search-selection-changed(inst, idx) => { root.search-selection-changed(inst, idx); }
                    media-play-pause => { root.media-play-pause(); }
                    media-next => { root.media-next(); }
                    media-previous => { root.media-previous(); }
                    password-search-changed(q) => { root.password-search-changed(q); }
                    password-entry-clicked(id) => { root.password-entry-clicked(id); }
                    password-copy-password(id) => { root.password-copy-password(id); }
                    password-copy-username(id) => { root.password-copy-username(id); }
                    password-copy-totp(id) => { root.password-copy-totp(id); }
                    password-open-url(url) => { root.password-open-url(url); }
                    password-unlock-submit(pw) => { root.password-unlock-submit(pw); }
                    password-unlock-biometric => { root.password-unlock-biometric(); }
                    password-lock-vault => { root.password-lock-vault(); }
                    password-add-entry-request => { root.password-add-entry-request(); }
                    password-add-entry-commit(title, username, password, url) => {
                        root.password-add-entry-commit(title, username, password, url);
                    }
                    password-add-entry-cancel => { root.password-add-entry-cancel(); }
                    password-add-entry-generate-password => {
                        root.password-add-entry-generate-password();
                    }
                    viewer-image-zoom-in(id) => { root.viewer-image-zoom-in(id); }
                    viewer-image-zoom-out(id) => { root.viewer-image-zoom-out(id); }
                    viewer-image-fit(id) => { root.viewer-image-fit(id); }
                    viewer-image-actual-size(id) => { root.viewer-image-actual-size(id); }
                    viewer-image-rotate-cw(id) => { root.viewer-image-rotate-cw(id); }
                    viewer-image-rotate-ccw(id) => { root.viewer-image-rotate-ccw(id); }
                    viewer-image-pan(id, dx, dy) => { root.viewer-image-pan(id, dx, dy); }
                    viewer-viewport-changed(id, w, h) => { root.viewer-viewport-changed(id, w, h); }
                    viewer-pdf-prev-page(id) => { root.viewer-pdf-prev-page(id); }
                    viewer-pdf-next-page(id) => { root.viewer-pdf-next-page(id); }
                    viewer-pdf-fit-width(id, w) => { root.viewer-pdf-fit-width(id, w); }
                    viewer-pdf-fit-page(id, w, h) => { root.viewer-pdf-fit-page(id, w, h); }
                    viewer-pdf-zoom-in(id) => { root.viewer-pdf-zoom-in(id); }
                    viewer-pdf-zoom-out(id) => { root.viewer-pdf-zoom-out(id); }
                    viewer-pdf-go-to-page(id, p) => { root.viewer-pdf-go-to-page(id, p); }
                    viewer-archive-navigate-into(id, path) => { root.viewer-archive-navigate-into(id, path); }
                    viewer-archive-navigate-up(id) => { root.viewer-archive-navigate-up(id); }
                    viewer-archive-select(id, path) => { root.viewer-archive-select(id, path); }
                    viewer-archive-extract-selected(id) => { root.viewer-archive-extract-selected(id); }
                    viewer-archive-extract-all(id) => { root.viewer-archive-extract-all(id); }
                    viewer-text-toggle-edit(id) => { root.viewer-text-toggle-edit(id); }
                    viewer-text-save(id) => { root.viewer-text-save(id); }
                    viewer-text-edited(id, t) => { root.viewer-text-edited(id, t); }

                    fm-sidebar-clicked(fm_id, id) => { root.fm-sidebar-clicked(fm_id, id); }
                    fm-toggle-dual-pane(fm_id) => { root.fm-toggle-dual-pane(fm_id); }
                    fm-toggle-show-hidden(fm_id) => { root.fm-toggle-show-hidden(fm_id); }
                    fm-toggle-click-behavior(fm_id) => { root.fm-toggle-click-behavior(fm_id); }
                    fm-pane-clicked(fm_id, p) => { root.fm-pane-clicked(fm_id, p); }
                    fm-tab-clicked(fm_id, p, id) => { root.fm-tab-clicked(fm_id, p, id); }
                    fm-tab-closed(fm_id, p, id) => { root.fm-tab-closed(fm_id, p, id); }
                    fm-tab-new(fm_id, p) => { root.fm-tab-new(fm_id, p); }
                    fm-new-folder(fm_id, p) => { root.fm-new-folder(fm_id, p); }
                    fm-nav-back(fm_id, p) => { root.fm-nav-back(fm_id, p); }
                    fm-nav-forward(fm_id, p) => { root.fm-nav-forward(fm_id, p); }
                    fm-nav-up(fm_id, p) => { root.fm-nav-up(fm_id, p); }
                    fm-breadcrumb-clicked(fm_id, p, path) => { root.fm-breadcrumb-clicked(fm_id, p, path); }
                    fm-view-mode-cycle(fm_id, p) => { root.fm-view-mode-cycle(fm_id, p); }
                    fm-sort-cycle(fm_id, p) => { root.fm-sort-cycle(fm_id, p); }
                    fm-sort-column-clicked(fm_id, p, col) => { root.fm-sort-column-clicked(fm_id, p, col); }
                    fm-quick-filter-changed(fm_id, p, q) => { root.fm-quick-filter-changed(fm_id, p, q); }
                    fm-entry-clicked(fm_id, p, path, ctrl) => { root.fm-entry-clicked(fm_id, p, path, ctrl); }
                    fm-entry-shift-clicked(fm_id, p, path) => { root.fm-entry-shift-clicked(fm_id, p, path); }
                    fm-entry-double-clicked(fm_id, p, path, is_dir) => { root.fm-entry-double-clicked(fm_id, p, path, is_dir); }
                    fm-entry-context(fm_id, p, path, x, y) => { root.fm-entry-context(fm_id, p, path, x, y); }
                    fm-context-action(fm_id, id, paths) => { root.fm-context-action(fm_id, id, paths); }
                    fm-context-dismiss(fm_id) => { root.fm-context-dismiss(fm_id); }
                    fm-confirm-yes(fm_id) => { root.fm-confirm-yes(fm_id); }
                    fm-confirm-no(fm_id) => { root.fm-confirm-no(fm_id); }
                    fm-rename-commit(fm_id, old, new) => { root.fm-rename-commit(fm_id, old, new); }
                    fm-rename-cancel(fm_id) => { root.fm-rename-cancel(fm_id); }
                    fm-tag-commit(fm_id, tag) => { root.fm-tag-commit(fm_id, tag); }
                    fm-tag-cancel(fm_id) => { root.fm-tag-cancel(fm_id); }
                    fm-passphrase-commit(fm_id, pw) => { root.fm-passphrase-commit(fm_id, pw); }
                    fm-passphrase-cancel(fm_id) => { root.fm-passphrase-cancel(fm_id); }
                    fm-passphrase-biometric(fm_id) => { root.fm-passphrase-biometric(fm_id); }
                    fm-managed-policy-close(fm_id) => { root.fm-managed-policy-close(fm_id); }
                    fm-select-all(fm_id, p) => { root.fm-select-all(fm_id, p); }
                    fm-delete-selected(fm_id, p) => { root.fm-delete-selected(fm_id, p); }
                    fm-copy-selected(fm_id, p) => { root.fm-copy-selected(fm_id, p); }
                    fm-paste-clipboard(fm_id, p) => { root.fm-paste-clipboard(fm_id, p); }
                    fm-rename-selected(fm_id, p) => { root.fm-rename-selected(fm_id, p); }
                    fm-deselect-all(fm_id, p) => { root.fm-deselect-all(fm_id, p); }
                    fm-open-selected(fm_id, p) => { root.fm-open-selected(fm_id, p); }
                    fm-entry-drag-start(fm_id, p, path) => { root.fm-entry-drag-start(fm_id, p, path); }
                    fm-entry-drag-hover(fm_id, p, path) => { root.fm-entry-drag-hover(fm_id, p, path); }
                    fm-entry-drag-drop(fm_id, p, path) => { root.fm-entry-drag-drop(fm_id, p, path); }
                    fm-entry-drag-cancel(fm_id, p) => { root.fm-entry-drag-cancel(fm_id, p); }
                    fm-pane-drag-hover(fm_id, p) => { root.fm-pane-drag-hover(fm_id, p); }
                    fm-drop-on-current-dir(fm_id, p) => { root.fm-drop-on-current-dir(fm_id, p); }
                    fm-entry-drag-scroll(fm_id, p, mx, my, vy, w) => { root.fm-entry-drag-scroll(fm_id, p, mx, my, vy, w); }
                    fm-error-action(fm_id, p) => { root.fm-error-action(fm_id, p); }
                }

                // Snap-cell ghosts sit above frames so they are not clipped by frame `clip: true`.
                for w[i] in root.workspace.widgets: Rectangle {
                    visible: w.snap-visible;
                    x: w.snap-x;
                    y: w.snap-y;
                    width: w.snap-width;
                    height: w.snap-height;
                    background: transparent;
                    border-width: 2px;
                    border-color: w.placement-valid ? Theme.accent-brand : #e35d6a;
                    border-radius: Theme.radius-md;
                    opacity: 0.9;
                }
            }
        }

        if WidgetCatalog.visible: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000028;

            catalog-backdrop := TouchArea {
                clicked => {
                    root.catalog-dismiss();
                }
            }

            WidgetCatalogPanel {
                x: min(max(WidgetCatalog.screen-x, 8px), parent.width - self.width - 8px);
                y: min(max(WidgetCatalog.screen-y, 8px), parent.height - self.height - 8px);
                pick(type-id) => {
                    root.catalog-pick(type-id);
                }
                dismiss => {
                    root.catalog-dismiss();
                }
                search-changed(q) => {
                    root.catalog-search-changed(q);
                }
            }
        }
    }

    WidgetDock {
        x: 0;
        y: parent.height - root.dock-height;
        width: parent.width;
        height: root.dock-height;
        clip: true;
        opacity: NavigationGlobal.dock-visible ? 1.0 : 0.0;
        animate opacity {
            duration: Theme.reduce-motion ? 0ms : 160ms;
            easing: ease-out;
        }
        dock-types: root.workspace.dock-types;
        dock-add-label: root.workspace.dock-add-label;
        add-clicked(type-id) => { root.dock-add-clicked(type-id); }
    }

    if NavigationGlobal.hint-mode-enabled && NavigationGlobal.dock-visible: Rectangle {
        x: 12px;
        y: parent.height - root.dock-height - hint-dock.preferred-height - 18px;
        width: hint-dock.preferred-width + 16px;
        height: hint-dock.preferred-height + 10px;
        background: #00000088;
        border-radius: Theme.radius-md;
        opacity: root.dock-height > 0 ? 1.0 : 0.0;

        hint-dock := Text {
            x: 8px;
            y: 5px;
            text: NavigationGlobal.hint-dock-label;
            color: #ffffff;
            font-size: Theme.font-size-sm;
            wrap: word-wrap;
        }
    }

    if NavigationGlobal.hint-mode-enabled: Rectangle {
        x: parent.width - hint-gestures.preferred-width - 28px;
        y: parent.height - hint-gestures.preferred-height - 24px;
        width: hint-gestures.preferred-width + 16px;
        height: hint-gestures.preferred-height + 10px;
        background: #00000088;
        border-radius: Theme.radius-md;

        hint-gestures := Text {
            x: 8px;
            y: 5px;
            text: NavigationGlobal.hint-gestures-label;
            color: #ffffff;
            font-size: Theme.font-size-sm;
            wrap: word-wrap;
        }
    }
}
