import { Theme } from "../theme_global.slint";
import { WidgetCatalog } from "../widget_catalog_global.slint";
import { WidgetFrame } from "widget-frame.slint";
import { WorkspaceSwitcher } from "workspace-switcher.slint";
import { WidgetDock } from "widget-dock.slint";
import { WidgetCatalogPanel } from "widget-catalog.slint";
import { WorkspaceModel, WorkspaceSummary, WidgetFrameModel, DockWidgetType } from "defs.slint";

export component WorkspaceView inherits Rectangle {
    in property <WorkspaceModel> workspace;

    callback workspace-clicked(string);
    callback workspace-create-clicked();
    callback dock-add-clicked(string);
    callback widget-close-clicked(string);
    callback widget-drag-started(string, length, length);
    callback widget-drag-moved(string, length, length);
    callback widget-drag-ended(string);
    callback widget-resize-started(string, string, length, length);
    callback widget-resize-moved(string, length, length);
    callback widget-resize-ended(string);
    callback terminal-key-pressed(string, string);
    callback terminal-viewport-changed(string, length, length);
    callback terminal-tab-clicked(string, int);
    callback terminal-tab-closed(string, int);
    callback terminal-tab-new(string);
    callback terminal-split-horizontal(string);
    callback terminal-split-vertical(string);
    callback terminal-pane-clicked(string, string);
    callback terminal-pane-closed(string, string);
    callback terminal-split-drag-moved(string, string, string, float, float);
    callback terminal-shortcut(string, string);
    callback rss-item-clicked(string);
    callback search-query-changed(string, string);
    callback search-candidate-activated(string, string);
    callback search-selection-changed(string, int);
    callback media-play-pause();
    callback media-next();
    callback media-previous();
    callback password-search-changed(string);
    callback password-entry-clicked(string);
    callback password-copy-password(string);
    callback password-copy-username(string);
    callback password-copy-totp(string);
    callback password-open-url(string);

    callback viewer-image-zoom-in(string);
    callback viewer-image-zoom-out(string);
    callback viewer-image-fit(string);
    callback viewer-image-actual-size(string);
    callback viewer-image-rotate-cw(string);
    callback viewer-image-rotate-ccw(string);
    callback viewer-image-pan(string, length, length);
    callback viewer-viewport-changed(string, length, length);
    callback viewer-pdf-prev-page(string);
    callback viewer-pdf-next-page(string);
    callback viewer-pdf-fit-width(string, length);
    callback viewer-pdf-fit-page(string, length, length);
    callback viewer-pdf-zoom-in(string);
    callback viewer-pdf-zoom-out(string);
    callback viewer-pdf-go-to-page(string, int);
    callback viewer-archive-navigate-into(string, string);
    callback viewer-archive-navigate-up(string);
    callback viewer-archive-select(string, string);

    callback fm-sidebar-clicked(string);
    callback fm-toggle-dual-pane();
    callback fm-toggle-show-hidden();
    callback fm-toggle-click-behavior();
    callback fm-pane-clicked(int);
    callback fm-tab-clicked(int, string);
    callback fm-tab-closed(int, string);
    callback fm-tab-new(int);
    callback fm-new-folder(int);
    callback fm-nav-back(int);
    callback fm-nav-forward(int);
    callback fm-nav-up(int);
    callback fm-breadcrumb-clicked(int, string);
    callback fm-view-mode-cycle(int);
    callback fm-sort-cycle(int);
    callback fm-sort-column-clicked(int, int);
    callback fm-quick-filter-changed(int, string);
    callback fm-entry-clicked(int, string, bool);
    callback fm-entry-shift-clicked(int, string);
    callback fm-entry-double-clicked(int, string, bool);
    callback fm-entry-context(int, string, length, length);
    callback fm-context-action(string, [string]);
    callback fm-context-dismiss();
    callback fm-confirm-yes();
    callback fm-confirm-no();
    callback fm-rename-commit(string, string);
    callback fm-rename-cancel();
    callback fm-tag-commit(string);
    callback fm-tag-cancel();
    callback fm-passphrase-commit(string);
    callback fm-passphrase-cancel();
    callback fm-select-all(int);
    callback fm-delete-selected(int);
    callback fm-copy-selected(int);
    callback fm-paste-clipboard(int);
    callback fm-rename-selected(int);
    callback fm-deselect-all(int);
    callback fm-open-selected(int);
    callback fm-entry-drag-start(int, string);
    callback fm-entry-drag-hover(int, string);
    callback fm-entry-drag-drop(int, string);
    callback fm-entry-drag-cancel(int);
    callback fm-pane-drag-hover(int);
    callback fm-drop-on-current-dir(int);
    callback fm-entry-drag-scroll(int, length, length, length, length);

    callback canvas-long-pressed(length, length, length, length);
    callback canvas-scrolled(length, length);
    callback catalog-pick(string);
    callback catalog-dismiss();
    callback catalog-search-changed(string);

    background: Theme.surface-base;

    WorkspaceSwitcher {
        x: 0;
        y: 0;
        width: parent.width;
        height: 40px;
        workspaces: root.workspace.workspaces;
        active-workspace-id: root.workspace.active-workspace-id;
        workspace-clicked(id) => { root.workspace-clicked(id); }
        workspace-create-clicked => { root.workspace-create-clicked(); }
    }

    canvas := Rectangle {
        x: 0;
        y: 40px;
        width: parent.width;
        height: parent.height - 40px - 64px;
        background: Theme.surface-base;
        clip: true;

        // With `for` children, Flickable does not infer viewport size (Slint #407); set it explicitly
        // so wheel / drag scrolling works when the logical grid is taller than the visible area.
        // `interactive: false`: otherwise Slint starts canvas flick after 8px move in 500ms and
        // cancels the widget header TouchArea — vertical widget drags fail. Wheel scroll still works.
        canvas-flick := Flickable {
            interactive: false;
            width: parent.width;
            height: parent.height;
            viewport-width: max(root.workspace.canvas-content-width, self.width);
            viewport-height: max(root.workspace.canvas-content-height, self.height);

            changed viewport-x => {
                root.canvas-scrolled(canvas-flick.viewport-x, canvas-flick.viewport-y);
            }
            changed viewport-y => {
                root.canvas-scrolled(canvas-flick.viewport-x, canvas-flick.viewport-y);
            }

            // Must match viewport-*: `parent` here is not reliably the full scroll extent (Slint Flickable).
            canvas-inner := Rectangle {
                width: max(root.workspace.canvas-content-width, canvas-flick.width);
                height: max(root.workspace.canvas-content-height, canvas-flick.height);
                background: Theme.surface-base;

                property <bool> long-press-armed: false;
                property <length> long-press-content-x: 0;
                property <length> long-press-content-y: 0;
                property <length> long-press-viewport-x: 0;
                property <length> long-press-viewport-y: 0;
                property <length> long-press-down-x: 0;
                property <length> long-press-down-y: 0;

                long-press-timer := Timer {
                    interval: 500ms;
                    running: canvas-inner.long-press-armed;
                    triggered => {
                        canvas-inner.long-press-armed = false;
                        root.canvas-long-pressed(
                            canvas-inner.long-press-content-x,
                            canvas-inner.long-press-content-y,
                            canvas-inner.long-press-viewport-x,
                            canvas-inner.long-press-viewport-y,
                        );
                    }
                }

                // Behind widgets: empty canvas hits here; widgets stay on top.
                canvas-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    pointer-event(event) => {
                        if (event.kind == PointerEventKind.down) {
                            canvas-inner.long-press-down-x = self.mouse-x;
                            canvas-inner.long-press-down-y = self.mouse-y;
                            canvas-inner.long-press-content-x = self.mouse-x + canvas-flick.viewport-x;
                            canvas-inner.long-press-content-y = self.mouse-y + canvas-flick.viewport-y;
                            canvas-inner.long-press-viewport-x = canvas-flick.viewport-x;
                            canvas-inner.long-press-viewport-y = canvas-flick.viewport-y;
                            canvas-inner.long-press-armed = true;
                        } else if (event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel) {
                            canvas-inner.long-press-armed = false;
                        }
                    }
                    moved => {
                        if (canvas-inner.long-press-armed
                            && (abs(self.mouse-x - canvas-inner.long-press-down-x) > 8px
                                || abs(self.mouse-y - canvas-inner.long-press-down-y) > 8px)) {
                            canvas-inner.long-press-armed = false;
                        }
                    }
                }

                for w[i] in root.workspace.widgets: WidgetFrame {
                    x: w.x;
                    y: w.y;
                    width: w.width;
                    height: w.height;
                    model: w;
                    close-clicked => { root.widget-close-clicked(w.instance-id); }
                    drag-started(dx, dy) => { root.widget-drag-started(w.instance-id, dx, dy); }
                    drag-moved(dx, dy) => { root.widget-drag-moved(w.instance-id, dx, dy); }
                    drag-ended => { root.widget-drag-ended(w.instance-id); }
                    resize-started(c, px, py) => { root.widget-resize-started(w.instance-id, c, px, py); }
                    resize-moved(px, py) => { root.widget-resize-moved(w.instance-id, px, py); }
                    resize-ended => { root.widget-resize-ended(w.instance-id); }
                    terminal-key-pressed(text) => { root.terminal-key-pressed(w.instance-id, text); }
                    terminal-viewport-changed(w_, h_) => { root.terminal-viewport-changed(w.instance-id, w_, h_); }
                    terminal-tab-clicked(idx) => { root.terminal-tab-clicked(w.instance-id, idx); }
                    terminal-tab-closed(idx) => { root.terminal-tab-closed(w.instance-id, idx); }
                    terminal-tab-new => { root.terminal-tab-new(w.instance-id); }
                    terminal-split-horizontal => { root.terminal-split-horizontal(w.instance-id); }
                    terminal-split-vertical => { root.terminal-split-vertical(w.instance-id); }
                    terminal-pane-clicked(sid) => { root.terminal-pane-clicked(w.instance-id, sid); }
                    terminal-pane-closed(sid) => { root.terminal-pane-closed(w.instance-id, sid); }
                    terminal-split-drag-moved(a, b, fx, fy) => {
                        root.terminal-split-drag-moved(w.instance-id, a, b, fx, fy);
                    }
                    terminal-shortcut(action) => { root.terminal-shortcut(w.instance-id, action); }
                    rss-item-clicked(link) => { root.rss-item-clicked(link); }
                    search-query-changed(inst, q) => { root.search-query-changed(inst, q); }
                    search-candidate-activated(inst, id) => { root.search-candidate-activated(inst, id); }
                    search-selection-changed(inst, idx) => { root.search-selection-changed(inst, idx); }
                    media-play-pause => { root.media-play-pause(); }
                    media-next => { root.media-next(); }
                    media-previous => { root.media-previous(); }
                    password-search-changed(q) => { root.password-search-changed(q); }
                    password-entry-clicked(id) => { root.password-entry-clicked(id); }
                    password-copy-password(id) => { root.password-copy-password(id); }
                    password-copy-username(id) => { root.password-copy-username(id); }
                    password-copy-totp(id) => { root.password-copy-totp(id); }
                    password-open-url(url) => { root.password-open-url(url); }
                    viewer-image-zoom-in(id) => { root.viewer-image-zoom-in(id); }
                    viewer-image-zoom-out(id) => { root.viewer-image-zoom-out(id); }
                    viewer-image-fit(id) => { root.viewer-image-fit(id); }
                    viewer-image-actual-size(id) => { root.viewer-image-actual-size(id); }
                    viewer-image-rotate-cw(id) => { root.viewer-image-rotate-cw(id); }
                    viewer-image-rotate-ccw(id) => { root.viewer-image-rotate-ccw(id); }
                    viewer-image-pan(id, dx, dy) => { root.viewer-image-pan(id, dx, dy); }
                    viewer-viewport-changed(id, w, h) => { root.viewer-viewport-changed(id, w, h); }
                    viewer-pdf-prev-page(id) => { root.viewer-pdf-prev-page(id); }
                    viewer-pdf-next-page(id) => { root.viewer-pdf-next-page(id); }
                    viewer-pdf-fit-width(id, w) => { root.viewer-pdf-fit-width(id, w); }
                    viewer-pdf-fit-page(id, w, h) => { root.viewer-pdf-fit-page(id, w, h); }
                    viewer-pdf-zoom-in(id) => { root.viewer-pdf-zoom-in(id); }
                    viewer-pdf-zoom-out(id) => { root.viewer-pdf-zoom-out(id); }
                    viewer-pdf-go-to-page(id, p) => { root.viewer-pdf-go-to-page(id, p); }
                    viewer-archive-navigate-into(id, path) => { root.viewer-archive-navigate-into(id, path); }
                    viewer-archive-navigate-up(id) => { root.viewer-archive-navigate-up(id); }
                    viewer-archive-select(id, path) => { root.viewer-archive-select(id, path); }

                    fm-sidebar-clicked(id) => { root.fm-sidebar-clicked(id); }
                    fm-toggle-dual-pane => { root.fm-toggle-dual-pane(); }
                    fm-toggle-show-hidden => { root.fm-toggle-show-hidden(); }
                    fm-toggle-click-behavior => { root.fm-toggle-click-behavior(); }
                    fm-pane-clicked(p) => { root.fm-pane-clicked(p); }
                    fm-tab-clicked(p, id) => { root.fm-tab-clicked(p, id); }
                    fm-tab-closed(p, id) => { root.fm-tab-closed(p, id); }
                    fm-tab-new(p) => { root.fm-tab-new(p); }
                    fm-new-folder(p) => { root.fm-new-folder(p); }
                    fm-nav-back(p) => { root.fm-nav-back(p); }
                    fm-nav-forward(p) => { root.fm-nav-forward(p); }
                    fm-nav-up(p) => { root.fm-nav-up(p); }
                    fm-breadcrumb-clicked(p, path) => { root.fm-breadcrumb-clicked(p, path); }
                    fm-view-mode-cycle(p) => { root.fm-view-mode-cycle(p); }
                    fm-sort-cycle(p) => { root.fm-sort-cycle(p); }
                    fm-sort-column-clicked(p, col) => { root.fm-sort-column-clicked(p, col); }
                    fm-quick-filter-changed(p, q) => { root.fm-quick-filter-changed(p, q); }
                    fm-entry-clicked(p, path, ctrl) => { root.fm-entry-clicked(p, path, ctrl); }
                    fm-entry-shift-clicked(p, path) => { root.fm-entry-shift-clicked(p, path); }
                    fm-entry-double-clicked(p, path, is_dir) => { root.fm-entry-double-clicked(p, path, is_dir); }
                    fm-entry-context(p, path, x, y) => { root.fm-entry-context(p, path, x, y); }
                    fm-context-action(id, paths) => { root.fm-context-action(id, paths); }
                    fm-context-dismiss => { root.fm-context-dismiss(); }
                    fm-confirm-yes => { root.fm-confirm-yes(); }
                    fm-confirm-no => { root.fm-confirm-no(); }
                    fm-rename-commit(old, new) => { root.fm-rename-commit(old, new); }
                    fm-rename-cancel => { root.fm-rename-cancel(); }
                    fm-tag-commit(tag) => { root.fm-tag-commit(tag); }
                    fm-tag-cancel => { root.fm-tag-cancel(); }
                    fm-passphrase-commit(pw) => { root.fm-passphrase-commit(pw); }
                    fm-passphrase-cancel => { root.fm-passphrase-cancel(); }
                    fm-select-all(p) => { root.fm-select-all(p); }
                    fm-delete-selected(p) => { root.fm-delete-selected(p); }
                    fm-copy-selected(p) => { root.fm-copy-selected(p); }
                    fm-paste-clipboard(p) => { root.fm-paste-clipboard(p); }
                    fm-rename-selected(p) => { root.fm-rename-selected(p); }
                    fm-deselect-all(p) => { root.fm-deselect-all(p); }
                    fm-open-selected(p) => { root.fm-open-selected(p); }
                    fm-entry-drag-start(p, path) => { root.fm-entry-drag-start(p, path); }
                    fm-entry-drag-hover(p, path) => { root.fm-entry-drag-hover(p, path); }
                    fm-entry-drag-drop(p, path) => { root.fm-entry-drag-drop(p, path); }
                    fm-entry-drag-cancel(p) => { root.fm-entry-drag-cancel(p); }
                    fm-pane-drag-hover(p) => { root.fm-pane-drag-hover(p); }
                    fm-drop-on-current-dir(p) => { root.fm-drop-on-current-dir(p); }
                    fm-entry-drag-scroll(p, mx, my, vy, w) => { root.fm-entry-drag-scroll(p, mx, my, vy, w); }
                }
            }
        }

        if WidgetCatalog.visible: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000028;

            catalog-backdrop := TouchArea {
                clicked => {
                    root.catalog-dismiss();
                }
            }

            WidgetCatalogPanel {
                x: min(max(WidgetCatalog.screen-x, 8px), parent.width - self.width - 8px);
                y: min(max(WidgetCatalog.screen-y, 8px), parent.height - self.height - 8px);
                pick(type-id) => {
                    root.catalog-pick(type-id);
                }
                dismiss => {
                    root.catalog-dismiss();
                }
                search-changed(q) => {
                    root.catalog-search-changed(q);
                }
            }
        }
    }

    WidgetDock {
        x: 0;
        y: parent.height - 64px;
        width: parent.width;
        height: 64px;
        dock-types: root.workspace.dock-types;
        dock-add-label: root.workspace.dock-add-label;
        add-clicked(type-id) => { root.dock-add-clicked(type-id); }
    }
}
