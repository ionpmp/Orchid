import { Theme } from "../theme_global.slint";
import { DockWidgetType } from "defs.slint";

export component WidgetDock inherits Rectangle {
    in property <[DockWidgetType]> dock-types;
    in property <string> dock-add-label;

    callback add-clicked(string);

    background: Theme.surface-raised;

    Rectangle {
        y: 0;
        width: parent.width;
        height: 1px;
        background: Theme.border-default;
    }

    HorizontalLayout {
        y: 1px;
        width: parent.width;
        height: parent.height - 1px;
        padding: 8px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.dock-add-label;
            color: Theme.text-secondary;
            font-size: Theme.font-size-sm;
            vertical-alignment: center;
        }

        for dw[i] in dock-types: Rectangle {
            width: 120px;
            height: 48px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: Theme.border-default;

            ta := TouchArea {
                clicked => { root.add-clicked(dw.type-id); }
            }
            if ta.has-hover : Rectangle {
                x: parent.x;
                y: -dock-hint.preferred-height - 8px;
                width: dock-hint.preferred-width + 12px;
                height: dock-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                dock-hint := Text {
                    x: 6px; y: 3px;
                    text: dw.description != ""
                        ? dw.label + " — " + dw.description
                        : dw.label;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            states [
                hover when ta.has-hover: {
                    background: Theme.surface-raised;
                    border-color: Theme.accent-brand;
                }
            ]
            animate background, border-color {
                duration: Theme.reduce-motion ? 0ms : 120ms;
                easing: ease-out;
            }

            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                alignment: center;

                Text {
                    text: dw.icon == "terminal" ? ">" :
                          dw.icon == "weather" ? "*" :
                          dw.icon == "moon" ? "o" :
                          dw.icon == "system" ? "#" :
                          dw.icon == "rss" ? "@" :
                          dw.icon == "recent-files" ? "~" :
                          dw.icon == "search" ? "?" :
                          dw.icon == "media" ? ">" :
                          dw.icon == "password" ? "*" :
                          dw.icon == "viewer" ? "[]" :
                          dw.icon == "fm" ? "/" :
                          "+";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-md;
                    horizontal-alignment: center;
                }

                Text {
                    text: dw.label;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    font-weight: Theme.weight-medium;
                    horizontal-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}
