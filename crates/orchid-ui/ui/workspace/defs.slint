// Shared structs for workspace UI (avoids import cycles with widget-frame).

export struct WorkspaceSummary {
    id: string,
    name: string,
    ordinal: int,
    is-active: bool,
}

export struct TerminalCellModel {
    ch: string,
    fg: color,
    bg: color,
    bold: bool,
}

export struct WeatherForecastEntry {
    day-label: string,
    high-text: string,
    low-text: string,
    icon: string,
    precip-text: string,
}

export struct MoonValueEntry {
    label: string,
    value: string,
}

export struct SystemIndicatorEntry {
    label: string,
    value-text: string,
    percent: float,
    icon: string,
    status: int,
}

export struct WeatherModel {
    location: string,
    current-temp: string,
    condition-label: string,
    condition-icon: string,
    feels-like: string,
    humidity: string,
    wind: string,
    forecast: [WeatherForecastEntry],
    last-updated: string,
    status: int,
}

export struct MoonModel {
    phase-label: string,
    phase-icon: string,
    illumination: string,
    values: [MoonValueEntry],
}

export struct SystemModel {
    indicators: [SystemIndicatorEntry],
}

export struct RssItemEntry {
    id: string,
    title: string,
    source: string,
    published: string,
    summary: string,
    link: string,
}

export struct RssModel {
    items: [RssItemEntry],
    last-updated: string,
    error-summary: string,
    has-items: bool,
    empty-state-text: string,
}

export struct SearchCandidateEntry {
    id: string,
    source-name: string,
    source-icon: string,
    title: string,
    subtitle: string,
    shortcut: string,
}

export struct SearchModel {
    query: string,
    candidates: [SearchCandidateEntry],
    is-searching: bool,
    error: string,
    selected-index: int,
    placeholder-text: string,
    empty-state-text: string,
    no-results-text: string,
    searching-text: string,
    /// True only for the first rebuild after the user adds a search widget from the dock.
    request-autofocus: bool,
}

export struct MediaModel {
    has-session: bool,
    title: string,
    artist: string,
    album: string,
    source-app: string,
    position: string,
    duration: string,
    progress: float,
    is-playing: bool,
    has-thumbnail: bool,
    thumbnail: image,
}

export struct PasswordEntryItem {
    id: string,
    title: string,
    username: string,
    url-host: string,
    has-totp: bool,
    tags: [string],
    color-label: string,
    modified: string,
}

export struct PasswordTagChip {
    label: string,
}

export struct PasswordDetail {
    has-selection: bool,
    id: string,
    title: string,
    username: string,
    url: string,
    notes: string,
    totp-code: string,
    totp-remaining: int,
    tags: [PasswordTagChip],
}

export struct PasswordModel {
    is-unlocked: bool,
    lock-reason: string,
    entries: [PasswordEntryItem],
    selected: PasswordDetail,
    search-query: string,
    toast-message: string,
    toast-visible: bool,
    request-autofocus: bool,
}

export struct WidgetFrameModel {
    instance-id: string,
    type-id: string,
    title: string,
    x: length,
    y: length,
    width: length,
    height: length,
    z-order: int,

    terminal-cols: int,
    terminal-rows: int,
    terminal-cells: [[TerminalCellModel]],
    terminal-cursor-col: int,
    terminal-cursor-row: int,
    terminal-cursor-visible: bool,
    terminal-cell-width: length,
    terminal-cell-height: length,
    /// fontdue-rastered terminal (same font as font metrics; avoids Skia per-cell text mismatch).
    terminal-pixels: image,

    weather: WeatherModel,
    moon: MoonModel,
    system: SystemModel,
    rss: RssModel,
    search: SearchModel,
    media: MediaModel,
    password: PasswordModel,
}

export struct DockWidgetType {
    type-id: string,
    label: string,
    icon: string,
}

export struct WorkspaceModel {
    workspaces: [WorkspaceSummary],
    active-workspace-id: string,
    widgets: [WidgetFrameModel],
    dock-types: [DockWidgetType],
    dock-add-label: string,
    grid-columns: int,
    grid-rows: int,
    /// Scrollable canvas width (logical px); usually the viewport width.
    canvas-content-width: length,
    /// Scrollable canvas height; grows when [`grid-rows`] exceeds the visible row stride.
    canvas-content-height: length,
}
