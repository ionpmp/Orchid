// Shared structs for workspace UI (avoids import cycles with widget-frame).

export struct WorkspaceSummary {
    id: string,
    name: string,
    ordinal: int,
    is-active: bool,
}

export struct TerminalCellModel {
    ch: string,
    fg: color,
    bg: color,
    bold: bool,
}

export struct WeatherForecastEntry {
    day-label: string,
    high-text: string,
    low-text: string,
    icon: string,
    precip-text: string,
}

export struct MoonValueEntry {
    label: string,
    value: string,
}

export struct SystemIndicatorEntry {
    label: string,
    value-text: string,
    percent: float,
    icon: string,
    status: int,
}

export struct WeatherModel {
    location: string,
    current-temp: string,
    condition-label: string,
    condition-icon: string,
    feels-like: string,
    humidity: string,
    wind: string,
    forecast: [WeatherForecastEntry],
    last-updated: string,
    status: int,
}

export struct MoonModel {
    phase-label: string,
    phase-icon: string,
    illumination: string,
    values: [MoonValueEntry],
}

export struct SystemModel {
    indicators: [SystemIndicatorEntry],
}

export struct RssItemEntry {
    id: string,
    title: string,
    source: string,
    published: string,
    summary: string,
    link: string,
}

export struct RssModel {
    items: [RssItemEntry],
    last-updated: string,
    error-summary: string,
    has-items: bool,
    empty-state-text: string,
}

export struct SearchCandidateEntry {
    id: string,
    source-name: string,
    source-icon: string,
    title: string,
    subtitle: string,
    shortcut: string,
}

export struct SearchModel {
    query: string,
    candidates: [SearchCandidateEntry],
    is-searching: bool,
    error: string,
    selected-index: int,
    placeholder-text: string,
    empty-state-text: string,
    no-results-text: string,
    searching-text: string,
    /// True only for the first rebuild after the user adds a search widget from the dock.
    request-autofocus: bool,
}

export struct MediaModel {
    has-session: bool,
    title: string,
    artist: string,
    album: string,
    source-app: string,
    position: string,
    duration: string,
    progress: float,
    is-playing: bool,
    has-thumbnail: bool,
    thumbnail: image,
}

export struct PasswordEntryItem {
    id: string,
    title: string,
    username: string,
    url-host: string,
    has-totp: bool,
    tags: [string],
    color-label: string,
    modified: string,
}

export struct PasswordTagChip {
    label: string,
}

export struct PasswordDetail {
    has-selection: bool,
    id: string,
    title: string,
    username: string,
    url: string,
    notes: string,
    totp-code: string,
    totp-remaining: int,
    tags: [PasswordTagChip],
}

export struct PasswordModel {
    is-unlocked: bool,
    lock-reason: string,
    entries: [PasswordEntryItem],
    selected: PasswordDetail,
    search-query: string,
    toast-message: string,
    toast-visible: bool,
    request-autofocus: bool,
}

export struct ViewerSyntaxSegment {
    text: string,
    scope: int,
}

export struct ViewerSyntaxLine {
    line-number: int,
    segments: [ViewerSyntaxSegment],
}

export struct ViewerImageModel {
    width-px: int,
    height-px: int,
    rgba-image: image,
    zoom: float,
    pan-x: length,
    pan-y: length,
    rotation-deg: int,
    flipped-h: bool,
    flipped-v: bool,
    info-text: string,
    path-display: string,
}

export struct ViewerPdfModel {
    page-count: int,
    current-page: int,
    page-width-px: int,
    page-height-px: int,
    page-image: image,
    zoom: float,
    info-text: string,
    path-display: string,
    available: bool,
    unavailable-reason: string,
}

export struct ViewerTextModel {
    language: string,
    encoding: string,
    line-ending: string,
    dirty: bool,
    read-only: bool,
    total-lines: int,
    first-visible-line: int,
    cursor-line: int,
    cursor-col: int,
    visible-lines: [ViewerSyntaxLine],
    info-text: string,
    path-display: string,
}

export struct ViewerArchiveEntry {
    path-in-archive: string,
    name: string,
    is-dir: bool,
    size-text: string,
    modified-text: string,
    icon: string,
    is-up: bool,
}

export struct ViewerArchiveModel {
    format: string,
    total-entries: int,
    current-inner-path: string,
    breadcrumbs: [string],
    entries: [ViewerArchiveEntry],
    selected-path: string,
    preview-kind: int,
    preview-text: string,
    preview-binary-size: string,
    info-text: string,
    path-display: string,
}

export struct ViewerEmptyModel {
    placeholder-text: string,
}

export struct ViewerStatusModel {
    path-display: string,
    message: string,
    icon: string,
}

export struct ViewerModel {
    kind: int,
    status: ViewerStatusModel,
    empty: ViewerEmptyModel,
    image: ViewerImageModel,
    pdf: ViewerPdfModel,
    text: ViewerTextModel,
    archive: ViewerArchiveModel,
}

export struct FmTagChip {
    label: string,
    color: color,
}

export struct FmEntry {
    path: string,
    name: string,
    is-dir: bool,
    size-text: string,
    modified-text: string,
    type-text: string,
    icon: string,
    has-thumbnail: bool,
    thumbnail-key: string,
    thumbnail: image,
    is-selected: bool,
    is-hidden: bool,
    is-encrypted: bool,
    is-managed: bool,
    is-starred: bool,
    color-label: string,
    tags: [FmTagChip],
}

export struct FmBreadcrumb {
    path: string,
    label: string,
}

export struct FmTab {
    id: string,
    path-display: string,
    breadcrumbs: [FmBreadcrumb],
    can-back: bool,
    can-forward: bool,
    view-mode: int,
    entries: [FmEntry],
    selection-count: int,
    status-text: string,
    quick-filter: string,
    is-loading: bool,
    error: string,
    sort-by: int,
    sort-descending: bool,
    sort-name-label: string,
    sort-size-label: string,
    sort-modified-label: string,
    sort-type-label: string,
}

export struct FmPane {
    tabs: [FmTab],
    active-tab: int,
}

export struct FmSidebarItem {
    id: string,
    label: string,
    icon: string,
    indent: int,
    is-section-header: bool,
    is-active: bool,
}

export struct FmContextAction {
    id: string,
    label: string,
    shortcut: string,
    icon: string,
    enabled: bool,
    is-separator: bool,
}

export struct FmContextMenu {
    visible: bool,
    x: length,
    y: length,
    actions: [FmContextAction],
    target-paths: [string],
}

export struct FmConfirmDialog {
    visible: bool,
    title: string,
    message: string,
    confirm-label: string,
    cancel-label: string,
    pending-action: string,
    pending-paths: [string],
}

export struct FmRenameState {
    active: bool,
    path: string,
    proposed-name: string,
    title: string,
    ok-label: string,
    cancel-label: string,
}

export struct FmTagState {
    active: bool,
    proposed-tag: string,
    title: string,
    ok-label: string,
    cancel-label: string,
}

export struct FmPassphraseState {
    active: bool,
    proposed-passphrase: string,
    title: string,
    ok-label: string,
    cancel-label: string,
}

export struct FileManagerModel {
    panes: [FmPane],
    active-pane: int,
    dual-pane: bool,
    dual-pane-label: string,
    clipboard-indicator: string,
    show-hidden: bool,
    show-hidden-label: string,
    sidebar-items: [FmSidebarItem],
    context-menu: FmContextMenu,
    confirm-dialog: FmConfirmDialog,
    rename: FmRenameState,
    tag: FmTagState,
    passphrase: FmPassphraseState,
}

export struct WidgetFrameModel {
    instance-id: string,
    type-id: string,
    title: string,
    x: length,
    y: length,
    width: length,
    height: length,
    z-order: int,

    terminal-cols: int,
    terminal-rows: int,
    terminal-cells: [[TerminalCellModel]],
    terminal-cursor-col: int,
    terminal-cursor-row: int,
    terminal-cursor-visible: bool,
    terminal-cell-width: length,
    terminal-cell-height: length,
    /// fontdue-rastered terminal (same font as font metrics; avoids Skia per-cell text mismatch).
    terminal-pixels: image,

    weather: WeatherModel,
    moon: MoonModel,
    system: SystemModel,
    rss: RssModel,
    search: SearchModel,
    media: MediaModel,
    password: PasswordModel,
    viewer: ViewerModel,
    file-manager: FileManagerModel,
}

export struct DockWidgetType {
    type-id: string,
    label: string,
    icon: string,
}

export struct WorkspaceModel {
    workspaces: [WorkspaceSummary],
    active-workspace-id: string,
    widgets: [WidgetFrameModel],
    dock-types: [DockWidgetType],
    dock-add-label: string,
    grid-columns: int,
    grid-rows: int,
    /// Scrollable canvas width (logical px); usually the viewport width.
    canvas-content-width: length,
    /// Scrollable canvas height; grows when [`grid-rows`] exceeds the visible row stride.
    canvas-content-height: length,
}
