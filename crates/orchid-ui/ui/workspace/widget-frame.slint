import { Theme } from "../theme_global.slint";
import { WidgetFrameModel, TerminalCellModel } from "defs.slint";
import { TerminalView } from "terminal-view.slint";
import { WeatherView } from "../widgets/weather.slint";
import { MoonView } from "../widgets/moon.slint";
import { SystemView } from "../widgets/system.slint";
import { RssView } from "../widgets/rss.slint";
import { SearchView } from "../widgets/search.slint";
import { MediaView } from "../widgets/media.slint";
import { PasswordView } from "../widgets/password.slint";
import { ViewerView } from "../widgets/viewer/viewer.slint";
import { FileManagerView } from "../widgets/file-manager/file-manager.slint";

export component WidgetFrame inherits Rectangle {
    in property <WidgetFrameModel> model;

    callback close-clicked();
    callback drag-started(length, length);
    callback drag-moved(length, length);
    callback drag-ended();
    callback resize-started(string, length, length);
    callback resize-moved(length, length);
    callback resize-ended();
    callback terminal-key-pressed(string);
    callback terminal-viewport-changed(length, length);
    callback rss-item-clicked(string);
    callback search-query-changed(string, string);
    callback search-candidate-activated(string, string);
    callback search-selection-changed(string, int);

    // Media
    callback media-play-pause();
    callback media-next();
    callback media-previous();

    // Password
    callback password-search-changed(string);
    callback password-entry-clicked(string);
    callback password-copy-password(string);
    callback password-copy-username(string);
    callback password-copy-totp(string);
    callback password-open-url(string);

    callback viewer-image-zoom-in(string);
    callback viewer-image-zoom-out(string);
    callback viewer-image-fit(string);
    callback viewer-image-actual-size(string);
    callback viewer-image-rotate-cw(string);
    callback viewer-image-rotate-ccw(string);
    callback viewer-image-pan(string, length, length);
    callback viewer-viewport-changed(string, length, length);

    callback viewer-pdf-prev-page(string);
    callback viewer-pdf-next-page(string);
    callback viewer-pdf-fit-width(string, length);
    callback viewer-pdf-fit-page(string, length, length);
    callback viewer-pdf-zoom-in(string);
    callback viewer-pdf-zoom-out(string);
    callback viewer-pdf-go-to-page(string, int);

    callback viewer-archive-navigate-into(string, string);
    callback viewer-archive-navigate-up(string);
    callback viewer-archive-select(string, string);

    callback fm-sidebar-clicked(string);
    callback fm-toggle-dual-pane();
    callback fm-toggle-show-hidden();
    callback fm-toggle-click-behavior();
    callback fm-pane-clicked(int);
    callback fm-tab-clicked(int, string);
    callback fm-tab-closed(int, string);
    callback fm-tab-new(int);
    callback fm-new-folder(int);
    callback fm-nav-back(int);
    callback fm-nav-forward(int);
    callback fm-nav-up(int);
    callback fm-breadcrumb-clicked(int, string);
    callback fm-view-mode-cycle(int);
    callback fm-sort-cycle(int);
    callback fm-sort-column-clicked(int, int);
    callback fm-quick-filter-changed(int, string);
    callback fm-entry-clicked(int, string, bool);
    callback fm-entry-shift-clicked(int, string);
    callback fm-entry-double-clicked(int, string, bool);
    callback fm-entry-context(int, string, length, length);
    callback fm-context-action(string, [string]);
    callback fm-context-dismiss();
    callback fm-confirm-yes();
    callback fm-confirm-no();
    callback fm-rename-commit(string, string);
    callback fm-rename-cancel();
    callback fm-tag-commit(string);
    callback fm-tag-cancel();
    callback fm-passphrase-commit(string);
    callback fm-passphrase-cancel();
    callback fm-select-all(int);
    callback fm-delete-selected(int);
    callback fm-copy-selected(int);
    callback fm-paste-clipboard(int);
    callback fm-rename-selected(int);
    callback fm-deselect-all(int);
    callback fm-open-selected(int);
    callback fm-entry-drag-start(int, string);
    callback fm-entry-drag-hover(int, string);
    callback fm-entry-drag-drop(int, string);
    callback fm-entry-drag-cancel(int);
    callback fm-pane-drag-hover(int);
    callback fm-drop-on-current-dir(int);

    background: Theme.surface-raised;
    border-width: 1px;
    border-color: Theme.border-default;
    border-radius: Theme.radius-md;
    drop-shadow-blur: 8px;
    drop-shadow-color: #00000040;
    clip: true;

    header := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 32px;
        background: Theme.surface-base;

        Rectangle {
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: Theme.border-default;
        }

        drag-area := TouchArea {
            width: parent.width - 40px;
            height: parent.height;
            x: 0;
            y: 0;
            moved => {
                if (self.pressed) {
                    // Pointer in *canvas* (workspace) space: the grab bar moves with the frame, so
                    // local (mouse-pressed) fights the model and causes visible jitter.
                    root.drag-moved(root.x + self.mouse-x, root.y + self.mouse-y);
                }
            }
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down) {
                    root.drag-started(self.mouse-x, self.mouse-y);
                } else if (event.kind == PointerEventKind.up) {
                    root.drag-ended();
                }
            }

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: start;
                spacing: 8px;

                Text {
                    text: model.title;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    font-weight: Theme.weight-medium;
                    vertical-alignment: center;
                }
            }
        }

        close-area := TouchArea {
            x: parent.width - 32px;
            y: 4px;
            width: 24px;
            height: 24px;
            clicked => { root.close-clicked(); }

            Rectangle {
                background: close-area.has-hover ? Theme.surface-raised : transparent;
                border-radius: Theme.radius-md;

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    content := Rectangle {
        x: 0;
        y: 32px;
        width: parent.width;
        height: parent.height - 32px;
        background: Theme.surface-base;

        if model.type-id == "terminal" : Rectangle {
            width: parent.width;
            height: parent.height;
            // Viewport must track terminal content only. Emitting on the shared `content` area
            // fired for every widget and on drag-induced layout noise (x/y) → PTY/rebuild loop.
            changed width => { root.terminal-viewport-changed(self.width, self.height); }
            changed height => { root.terminal-viewport-changed(self.width, self.height); }

            TerminalView {
                width: parent.width;
                height: parent.height;
                cols: model.terminal-cols;
                rows: model.terminal-rows;
                cells: model.terminal-cells;
                pixels: model.terminal-pixels;
                cursor-col: model.terminal-cursor-col;
                cursor-row: model.terminal-cursor-row;
                cursor-visible: model.terminal-cursor-visible;
                cell-width: model.terminal-cell-width;
                cell-height: model.terminal-cell-height;
                key-pressed(text) => { root.terminal-key-pressed(text); }
            }
        }

        if model.type-id == "weather" : WeatherView {
            width: parent.width;
            height: parent.height;
            model: root.model.weather;
        }

        if model.type-id == "moon" : MoonView {
            width: parent.width;
            height: parent.height;
            model: root.model.moon;
        }

        if model.type-id == "system" : SystemView {
            width: parent.width;
            height: parent.height;
            model: root.model.system;
        }

        if model.type-id == "rss" : RssView {
            width: parent.width;
            height: parent.height;
            model: root.model.rss;
            item-clicked(link) => { root.rss-item-clicked(link); }
        }

        if model.type-id == "universal-search" || model.type-id == "search" : SearchView {
            width: parent.width;
            height: parent.height;
            model: root.model.search;
            query-changed(q) => { root.search-query-changed(root.model.instance-id, q); }
            candidate-activated(id) => { root.search-candidate-activated(root.model.instance-id, id); }
            selection-changed(idx) => { root.search-selection-changed(root.model.instance-id, idx); }
        }

        if model.type-id == "media" || model.type-id == "media-player" : MediaView {
            width: parent.width;
            height: parent.height;
            model: root.model.media;
            play-pause => { root.media-play-pause(); }
            next => { root.media-next(); }
            previous => { root.media-previous(); }
        }

        if model.type-id == "password" || model.type-id == "password-manager" : PasswordView {
            width: parent.width;
            height: parent.height;
            model: root.model.password;
            search-changed(q) => { root.password-search-changed(q); }
            entry-clicked(id) => { root.password-entry-clicked(id); }
            copy-password(id) => { root.password-copy-password(id); }
            copy-username(id) => { root.password-copy-username(id); }
            copy-totp(id) => { root.password-copy-totp(id); }
            open-url(url) => { root.password-open-url(url); }
        }

        if model.type-id == "viewer" : Rectangle {
            width: parent.width;
            height: parent.height;
            changed width => { root.viewer-viewport-changed(root.model.instance-id, self.width, self.height); }
            changed height => { root.viewer-viewport-changed(root.model.instance-id, self.width, self.height); }

            ViewerView {
                width: parent.width;
                height: parent.height;
                model: root.model.viewer;

                image-zoom-in => { root.viewer-image-zoom-in(root.model.instance-id); }
                image-zoom-out => { root.viewer-image-zoom-out(root.model.instance-id); }
                image-fit => { root.viewer-image-fit(root.model.instance-id); }
                image-actual-size => { root.viewer-image-actual-size(root.model.instance-id); }
                image-rotate-cw => { root.viewer-image-rotate-cw(root.model.instance-id); }
                image-rotate-ccw => { root.viewer-image-rotate-ccw(root.model.instance-id); }
                image-pan(dx, dy) => { root.viewer-image-pan(root.model.instance-id, dx, dy); }

                pdf-prev-page => { root.viewer-pdf-prev-page(root.model.instance-id); }
                pdf-next-page => { root.viewer-pdf-next-page(root.model.instance-id); }
                pdf-fit-width => { root.viewer-pdf-fit-width(root.model.instance-id, parent.width); }
                pdf-fit-page => { root.viewer-pdf-fit-page(root.model.instance-id, parent.width, parent.height); }
                pdf-zoom-in => { root.viewer-pdf-zoom-in(root.model.instance-id); }
                pdf-zoom-out => { root.viewer-pdf-zoom-out(root.model.instance-id); }
                pdf-go-to-page(p) => { root.viewer-pdf-go-to-page(root.model.instance-id, p); }

                archive-navigate-into(path) => { root.viewer-archive-navigate-into(root.model.instance-id, path); }
                archive-navigate-up => { root.viewer-archive-navigate-up(root.model.instance-id); }
                archive-select(path) => { root.viewer-archive-select(root.model.instance-id, path); }

            }
        }

        if model.type-id == "file-manager" : FileManagerView {
            width: parent.width;
            height: parent.height;
            model: root.model.file-manager;

            sidebar-clicked(id) => { root.fm-sidebar-clicked(id); }
            toggle-dual-pane => { root.fm-toggle-dual-pane(); }
            toggle-show-hidden => { root.fm-toggle-show-hidden(); }
            toggle-click-behavior => { root.fm-toggle-click-behavior(); }
            pane-clicked(p) => { root.fm-pane-clicked(p); }
            tab-clicked(p, id) => { root.fm-tab-clicked(p, id); }
            tab-closed(p, id) => { root.fm-tab-closed(p, id); }
            tab-new(p) => { root.fm-tab-new(p); }
            new-folder(p) => { root.fm-new-folder(p); }
            nav-back(p) => { root.fm-nav-back(p); }
            nav-forward(p) => { root.fm-nav-forward(p); }
            nav-up(p) => { root.fm-nav-up(p); }
            breadcrumb-clicked(p, path) => { root.fm-breadcrumb-clicked(p, path); }
            view-mode-cycle(p) => { root.fm-view-mode-cycle(p); }
            sort-cycle(p) => { root.fm-sort-cycle(p); }
            sort-column-clicked(p, col) => { root.fm-sort-column-clicked(p, col); }
            quick-filter-changed(p, q) => { root.fm-quick-filter-changed(p, q); }
            entry-clicked(p, path, ctrl) => { root.fm-entry-clicked(p, path, ctrl); }
            entry-shift-clicked(p, path) => { root.fm-entry-shift-clicked(p, path); }
            entry-double-clicked(p, path, is_dir) => { root.fm-entry-double-clicked(p, path, is_dir); }
            entry-context(p, path, x, y) => { root.fm-entry-context(p, path, x, y); }
            context-action(id, paths) => { root.fm-context-action(id, paths); }
            context-dismiss => { root.fm-context-dismiss(); }
            confirm-yes => { root.fm-confirm-yes(); }
            confirm-no => { root.fm-confirm-no(); }
            rename-commit(old, new) => { root.fm-rename-commit(old, new); }
            rename-cancel => { root.fm-rename-cancel(); }
            tag-commit(tag) => { root.fm-tag-commit(tag); }
            tag-cancel => { root.fm-tag-cancel(); }
            passphrase-commit(pw) => { root.fm-passphrase-commit(pw); }
            passphrase-cancel => { root.fm-passphrase-cancel(); }
            select-all(p) => { root.fm-select-all(p); }
            delete-selected(p) => { root.fm-delete-selected(p); }
            copy-selected(p) => { root.fm-copy-selected(p); }
            paste-clipboard(p) => { root.fm-paste-clipboard(p); }
            rename-selected(p) => { root.fm-rename-selected(p); }
            deselect-all(p) => { root.fm-deselect-all(p); }
            open-selected(p) => { root.fm-open-selected(p); }
            entry-drag-start(p, path) => { root.fm-entry-drag-start(p, path); }
            entry-drag-hover(p, path) => { root.fm-entry-drag-hover(p, path); }
            entry-drag-drop(p, path) => { root.fm-entry-drag-drop(p, path); }
            entry-drag-cancel(p) => { root.fm-entry-drag-cancel(p); }
            pane-drag-hover(p) => { root.fm-pane-drag-hover(p); }
            drop-on-current-dir(p) => { root.fm-drop-on-current-dir(p); }
        }
    }

    resize-se := TouchArea {
        x: parent.width - 12px;
        y: parent.height - 12px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nwse-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("se", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }

    resize-sw := TouchArea {
        x: 0;
        y: parent.height - 12px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nesw-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("sw", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }

    resize-ne := TouchArea {
        x: parent.width - 12px;
        y: 32px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nesw-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("ne", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }

    resize-nw := TouchArea {
        x: 0;
        y: 32px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nwse-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("nw", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }
}
