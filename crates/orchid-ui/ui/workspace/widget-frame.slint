import { Theme } from "../theme_global.slint";
import { WidgetFrameModel, TerminalCellModel } from "defs.slint";
import { TerminalView } from "terminal-view.slint";
import { TerminalTabs } from "../widgets/terminal/terminal-tabs.slint";
import { TerminalSplitView } from "../widgets/terminal/terminal-split-view.slint";
import { GroupTabs } from "group-tabs.slint";
import { WeatherView } from "../widgets/weather.slint";
import { MoonView } from "../widgets/moon.slint";
import { SystemView } from "../widgets/system.slint";
import { RssView } from "../widgets/rss.slint";
import { RecentFilesView } from "../widgets/recent_files.slint";
import { SearchView } from "../widgets/search.slint";
import { MediaView } from "../widgets/media.slint";
import { PasswordView } from "../widgets/password.slint";
import { ViewerView } from "../widgets/viewer/viewer.slint";
import { FileManagerView } from "../widgets/file-manager/file-manager.slint";
import { WidgetCloseConfirmDialog } from "widget-close-confirm-dialog.slint";

export component WidgetFrame inherits Rectangle {
    in property <WidgetFrameModel> model;

    callback close-clicked();
    callback close-confirm-save(string);
    callback close-confirm-discard(string);
    callback close-confirm-cancel(string);
    callback drag-started(length, length);
    callback drag-moved(length, length);
    callback drag-ended();
    callback resize-started(string, length, length);
    callback resize-moved(length, length);
    callback resize-ended();
    callback group-tab-clicked(string);
    callback group-tab-closed(string);
    callback group-dissolve-clicked();
    callback terminal-key-pressed(string, bool, bool, bool);
    callback terminal-viewport-changed(length, length);
    callback terminal-tab-clicked(int);
    callback terminal-tab-closed(int);
    callback terminal-tab-new();
    callback terminal-split-horizontal();
    callback terminal-split-vertical();
    callback terminal-pane-clicked(string);
    callback terminal-pane-closed(string);
    callback terminal-split-drag-moved(string, string, float, float);
    callback terminal-shortcut(string);
    callback rss-item-clicked(string);
    callback recent-files-item-clicked(string);
    callback search-query-changed(string, string);
    callback search-candidate-activated(string, string);
    callback search-selection-changed(string, int);

    // Media
    callback media-play-pause();
    callback media-next();
    callback media-previous();

    // Password
    callback password-search-changed(string);
    callback password-entry-clicked(string);
    callback password-copy-password(string);
    callback password-copy-username(string);
    callback password-copy-totp(string);
    callback password-open-url(string);
    callback password-unlock-submit(string);
    callback password-unlock-biometric();
    callback password-lock-vault();
    callback password-add-entry-request();
    callback password-add-entry-commit(string, string, string, string);
    callback password-add-entry-cancel();
    callback password-add-entry-generate-password();

    callback viewer-image-zoom-in(string);
    callback viewer-image-zoom-out(string);
    callback viewer-image-fit(string);
    callback viewer-image-actual-size(string);
    callback viewer-image-rotate-cw(string);
    callback viewer-image-rotate-ccw(string);
    callback viewer-image-flip-h(string);
    callback viewer-image-flip-v(string);
    callback viewer-image-pan(string, length, length);
    callback viewer-viewport-changed(string, length, length);

    callback viewer-pdf-prev-page(string);
    callback viewer-pdf-next-page(string);
    callback viewer-pdf-fit-width(string, length);
    callback viewer-pdf-fit-page(string, length, length);
    callback viewer-pdf-zoom-in(string);
    callback viewer-pdf-zoom-out(string);
    callback viewer-pdf-go-to-page(string, int);

    callback viewer-archive-navigate-into(string, string);
    callback viewer-archive-navigate-up(string);
    callback viewer-archive-select(string, string);
    callback viewer-archive-extract-selected(string);
    callback viewer-archive-extract-all(string);

    callback viewer-text-toggle-edit(string);
    callback viewer-text-save(string);
    callback viewer-text-edited(string, string);

    callback fm-sidebar-clicked(string, string);
    callback fm-toggle-dual-pane(string);
    callback fm-toggle-show-hidden(string);
    callback fm-toggle-click-behavior(string);
    callback fm-pane-clicked(string, int);
    callback fm-tab-clicked(string, int, string);
    callback fm-tab-closed(string, int, string);
    callback fm-tab-new(string, int);
    callback fm-new-folder(string, int);
    callback fm-nav-back(string, int);
    callback fm-nav-forward(string, int);
    callback fm-nav-up(string, int);
    callback fm-breadcrumb-clicked(string, int, string);
    callback fm-view-mode-cycle(string, int);
    callback fm-sort-cycle(string, int);
    callback fm-sort-column-clicked(string, int, int);
    callback fm-quick-filter-changed(string, int, string);
    callback fm-entry-clicked(string, int, string, bool);
    callback fm-entry-shift-clicked(string, int, string);
    callback fm-entry-double-clicked(string, int, string, bool);
    callback fm-entry-context(string, int, string, length, length);
    callback fm-context-action(string, string, [string]);
    callback fm-context-dismiss(string);
    callback fm-confirm-yes(string);
    callback fm-confirm-no(string);
    callback fm-rename-commit(string, string, string);
    callback fm-rename-cancel(string);
    callback fm-tag-commit(string, string);
    callback fm-tag-cancel(string);
    callback fm-passphrase-commit(string, string);
    callback fm-passphrase-cancel(string);
    callback fm-passphrase-biometric(string);
    callback fm-managed-policy-close(string);
    callback fm-select-all(string, int);
    callback fm-delete-selected(string, int);
    callback fm-copy-selected(string, int);
    callback fm-paste-clipboard(string, int);
    callback fm-rename-selected(string, int);
    callback fm-deselect-all(string, int);
    callback fm-open-selected(string, int);
    callback fm-entry-drag-start(string, int, string);
    callback fm-entry-drag-hover(string, int, string);
    callback fm-entry-drag-drop(string, int, string);
    callback fm-entry-drag-cancel(string, int);
    callback fm-pane-drag-hover(string, int);
    callback fm-drop-on-current-dir(string, int);
    callback fm-entry-drag-scroll(string, int, length, length, length, length);
    callback fm-error-action(string, int);

    background: Theme.surface-raised;
    border-width: model.placement-valid ? 1px : 2px;
    border-color: model.placement-valid ? Theme.border-default : #e35d6a;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.reduce-motion ? 0px : (drag-area.pressed ? 16px : 8px);
    drop-shadow-color: #00000040;
    drop-shadow-offset-y: Theme.reduce-motion ? 0px : (drag-area.pressed ? 4px : 0px);
    clip: true;
    animate border-color, drop-shadow-blur, drop-shadow-offset-y {
        duration: Theme.reduce-motion ? 0ms : 100ms;
        easing: ease-out;
    }

    header := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 32px;
        background: Theme.surface-base;

        Rectangle {
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: Theme.border-default;
        }

        drag-area := TouchArea {
            width: parent.width - 40px;
            height: parent.height;
            x: 0;
            y: 0;
            mouse-cursor: MouseCursor.move;
            moved => {
                if (self.pressed) {
                    // Pointer in *canvas* (workspace) space: the grab bar moves with the frame, so
                    // local (mouse-pressed) fights the model and causes visible jitter.
                    root.drag-moved(root.x + self.mouse-x, root.y + self.mouse-y);
                }
            }
            pointer-event(event) => {
                if (event.kind == PointerEventKind.down) {
                    root.drag-started(self.mouse-x, self.mouse-y);
                } else if (event.kind == PointerEventKind.up) {
                    root.drag-ended();
                }
            }

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: start;
                spacing: 8px;

                Text {
                    text: model.title;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    font-weight: Theme.weight-medium;
                    vertical-alignment: center;
                }
            }
        }

        close-area := TouchArea {
            x: parent.width - 32px;
            y: 4px;
            width: 24px;
            height: 24px;
            clicked => { root.close-clicked(); }

            Rectangle {
                background: close-area.has-hover ? Theme.surface-raised : transparent;
                border-radius: Theme.radius-md;

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    content := Rectangle {
        x: 0;
        y: 32px;
        width: parent.width;
        height: parent.height - 32px;
        background: Theme.surface-base;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 0;

            if model.group-tabs.length > 1 : GroupTabs {
                tabs: model.group-tabs;
                tab-clicked(id) => { root.group-tab-clicked(id); }
                tab-closed(id) => { root.group-tab-closed(id); }
                dissolve-clicked => { root.group-dissolve-clicked(); }
            }

            body := Rectangle {
                vertical-stretch: 1;

                if model.type-id == "terminal" : VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    spacing: 0;

                    TerminalTabs {
                        tabs: model.terminal-tabs;
                        active-tab: model.terminal-active-tab;
                        tab-clicked(idx) => { root.terminal-tab-clicked(idx); }
                        tab-closed(idx) => { root.terminal-tab-closed(idx); }
                        tab-new => { root.terminal-tab-new(); }
                        split-horizontal => { root.terminal-split-horizontal(); }
                        split-vertical => { root.terminal-split-vertical(); }
                    }

                    viewport := Rectangle {
                        vertical-stretch: 1;
                        changed width => { root.terminal-viewport-changed(self.width, self.height); }
                        changed height => { root.terminal-viewport-changed(self.width, self.height); }

                        TerminalSplitView {
                            width: parent.width;
                            height: parent.height;
                            panes: model.terminal-panes;
                            dividers: model.terminal-dividers;
                            cell-width: model.terminal-cell-width;
                            cell-height: model.terminal-cell-height;
                            pane-clicked(sid) => { root.terminal-pane-clicked(sid); }
                            pane-closed(sid) => { root.terminal-pane-closed(sid); }
                            split-drag-moved(a, b, fx, fy) => {
                                root.terminal-split-drag-moved(a, b, fx, fy);
                            }
                            shortcut(action) => { root.terminal-shortcut(action); }
                            key-pressed(text, ctrl, shift, alt) => {
                                root.terminal-key-pressed(text, ctrl, shift, alt);
                            }
                        }
                    }
                }

                if model.type-id == "weather" : WeatherView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.weather;
                }

                if model.type-id == "moon" : MoonView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.moon;
                }

                if model.type-id == "system" : SystemView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.system;
                }

                if model.type-id == "rss" : RssView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.rss;
                    item-clicked(link) => { root.rss-item-clicked(link); }
                }

                if model.type-id == "recent-files" : RecentFilesView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.recent-files;
                    item-clicked(path) => { root.recent-files-item-clicked(path); }
                }

                if model.type-id == "universal-search" || model.type-id == "search" : SearchView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.search;
                    query-changed(q) => { root.search-query-changed(root.model.instance-id, q); }
                    candidate-activated(id) => { root.search-candidate-activated(root.model.instance-id, id); }
                    selection-changed(idx) => { root.search-selection-changed(root.model.instance-id, idx); }
                }

                if model.type-id == "media" || model.type-id == "media-player" : MediaView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.media;
                    play-pause => { root.media-play-pause(); }
                    next => { root.media-next(); }
                    previous => { root.media-previous(); }
                }

                if model.type-id == "password" || model.type-id == "password-manager" : PasswordView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.password;
                    search-changed(q) => { root.password-search-changed(q); }
                    entry-clicked(id) => { root.password-entry-clicked(id); }
                    copy-password(id) => { root.password-copy-password(id); }
                    copy-username(id) => { root.password-copy-username(id); }
                    copy-totp(id) => { root.password-copy-totp(id); }
                    open-url(url) => { root.password-open-url(url); }
                    unlock-submit(pw) => { root.password-unlock-submit(pw); }
                    unlock-biometric => { root.password-unlock-biometric(); }
                    lock-vault => { root.password-lock-vault(); }
                    add-entry-request => { root.password-add-entry-request(); }
                    add-entry-commit(title, username, password, url) => {
                        root.password-add-entry-commit(title, username, password, url);
                    }
                    add-entry-cancel => { root.password-add-entry-cancel(); }
                    add-entry-generate-password => { root.password-add-entry-generate-password(); }
                }

                if model.type-id == "viewer" : Rectangle {
                    width: parent.width;
                    height: parent.height;
                    changed width => { root.viewer-viewport-changed(root.model.instance-id, self.width, self.height); }
                    changed height => { root.viewer-viewport-changed(root.model.instance-id, self.width, self.height); }

                    ViewerView {
                        width: parent.width;
                        height: parent.height;
                        model: root.model.viewer;

                        image-zoom-in => { root.viewer-image-zoom-in(root.model.instance-id); }
                        image-zoom-out => { root.viewer-image-zoom-out(root.model.instance-id); }
                        image-fit => { root.viewer-image-fit(root.model.instance-id); }
                        image-actual-size => { root.viewer-image-actual-size(root.model.instance-id); }
                        image-rotate-cw => { root.viewer-image-rotate-cw(root.model.instance-id); }
                        image-rotate-ccw => { root.viewer-image-rotate-ccw(root.model.instance-id); }
                        image-flip-h => { root.viewer-image-flip-h(root.model.instance-id); }
                        image-flip-v => { root.viewer-image-flip-v(root.model.instance-id); }
                        image-pan(dx, dy) => { root.viewer-image-pan(root.model.instance-id, dx, dy); }

                        pdf-prev-page => { root.viewer-pdf-prev-page(root.model.instance-id); }
                        pdf-next-page => { root.viewer-pdf-next-page(root.model.instance-id); }
                        pdf-fit-width => { root.viewer-pdf-fit-width(root.model.instance-id, parent.width); }
                        pdf-fit-page => { root.viewer-pdf-fit-page(root.model.instance-id, parent.width, parent.height); }
                        pdf-zoom-in => { root.viewer-pdf-zoom-in(root.model.instance-id); }
                        pdf-zoom-out => { root.viewer-pdf-zoom-out(root.model.instance-id); }
                        pdf-go-to-page(p) => { root.viewer-pdf-go-to-page(root.model.instance-id, p); }

                        archive-navigate-into(path) => { root.viewer-archive-navigate-into(root.model.instance-id, path); }
                        archive-navigate-up => { root.viewer-archive-navigate-up(root.model.instance-id); }
                        archive-select(path) => { root.viewer-archive-select(root.model.instance-id, path); }
                        archive-extract-selected => { root.viewer-archive-extract-selected(root.model.instance-id); }
                        archive-extract-all => { root.viewer-archive-extract-all(root.model.instance-id); }

                        text-toggle-edit => { root.viewer-text-toggle-edit(root.model.instance-id); }
                        text-save => { root.viewer-text-save(root.model.instance-id); }
                        text-edited(t) => { root.viewer-text-edited(root.model.instance-id, t); }
                    }
                }

                if model.type-id == "file-manager" : FileManagerView {
                    width: parent.width;
                    height: parent.height;
                    model: root.model.file-manager;

                    sidebar-clicked(id) => { root.fm-sidebar-clicked(root.model.instance-id, id); }
                    toggle-dual-pane => { root.fm-toggle-dual-pane(root.model.instance-id); }
                    toggle-show-hidden => { root.fm-toggle-show-hidden(root.model.instance-id); }
                    toggle-click-behavior => { root.fm-toggle-click-behavior(root.model.instance-id); }
                    pane-clicked(p) => { root.fm-pane-clicked(root.model.instance-id, p); }
                    tab-clicked(p, id) => { root.fm-tab-clicked(root.model.instance-id, p, id); }
                    tab-closed(p, id) => { root.fm-tab-closed(root.model.instance-id, p, id); }
                    tab-new(p) => { root.fm-tab-new(root.model.instance-id, p); }
                    new-folder(p) => { root.fm-new-folder(root.model.instance-id, p); }
                    nav-back(p) => { root.fm-nav-back(root.model.instance-id, p); }
                    nav-forward(p) => { root.fm-nav-forward(root.model.instance-id, p); }
                    nav-up(p) => { root.fm-nav-up(root.model.instance-id, p); }
                    breadcrumb-clicked(p, path) => { root.fm-breadcrumb-clicked(root.model.instance-id, p, path); }
                    view-mode-cycle(p) => { root.fm-view-mode-cycle(root.model.instance-id, p); }
                    sort-cycle(p) => { root.fm-sort-cycle(root.model.instance-id, p); }
                    sort-column-clicked(p, col) => { root.fm-sort-column-clicked(root.model.instance-id, p, col); }
                    quick-filter-changed(p, q) => { root.fm-quick-filter-changed(root.model.instance-id, p, q); }
                    entry-clicked(p, path, ctrl) => { root.fm-entry-clicked(root.model.instance-id, p, path, ctrl); }
                    entry-shift-clicked(p, path) => { root.fm-entry-shift-clicked(root.model.instance-id, p, path); }
                    entry-double-clicked(p, path, is_dir) => { root.fm-entry-double-clicked(root.model.instance-id, p, path, is_dir); }
                    entry-context(p, path, x, y) => { root.fm-entry-context(root.model.instance-id, p, path, x, y); }
                    context-action(id, paths) => { root.fm-context-action(root.model.instance-id, id, paths); }
                    context-dismiss => { root.fm-context-dismiss(root.model.instance-id); }
                    confirm-yes => { root.fm-confirm-yes(root.model.instance-id); }
                    confirm-no => { root.fm-confirm-no(root.model.instance-id); }
                    rename-commit(old, new) => { root.fm-rename-commit(root.model.instance-id, old, new); }
                    rename-cancel => { root.fm-rename-cancel(root.model.instance-id); }
                    tag-commit(tag) => { root.fm-tag-commit(root.model.instance-id, tag); }
                    tag-cancel => { root.fm-tag-cancel(root.model.instance-id); }
                    passphrase-commit(pw) => { root.fm-passphrase-commit(root.model.instance-id, pw); }
                    passphrase-cancel => { root.fm-passphrase-cancel(root.model.instance-id); }
                    passphrase-biometric => { root.fm-passphrase-biometric(root.model.instance-id); }
                    managed-policy-close => { root.fm-managed-policy-close(root.model.instance-id); }
                    select-all(p) => { root.fm-select-all(root.model.instance-id, p); }
                    delete-selected(p) => { root.fm-delete-selected(root.model.instance-id, p); }
                    copy-selected(p) => { root.fm-copy-selected(root.model.instance-id, p); }
                    paste-clipboard(p) => { root.fm-paste-clipboard(root.model.instance-id, p); }
                    rename-selected(p) => { root.fm-rename-selected(root.model.instance-id, p); }
                    deselect-all(p) => { root.fm-deselect-all(root.model.instance-id, p); }
                    open-selected(p) => { root.fm-open-selected(root.model.instance-id, p); }
                    entry-drag-start(p, path) => { root.fm-entry-drag-start(root.model.instance-id, p, path); }
                    entry-drag-hover(p, path) => { root.fm-entry-drag-hover(root.model.instance-id, p, path); }
                    entry-drag-drop(p, path) => { root.fm-entry-drag-drop(root.model.instance-id, p, path); }
                    entry-drag-cancel(p) => { root.fm-entry-drag-cancel(root.model.instance-id, p); }
                    pane-drag-hover(p) => { root.fm-pane-drag-hover(root.model.instance-id, p); }
                    drop-on-current-dir(p) => { root.fm-drop-on-current-dir(root.model.instance-id, p); }
                    entry-drag-scroll(p, mx, my, vy, w) => { root.fm-entry-drag-scroll(root.model.instance-id, p, mx, my, vy, w); }
                    error-action(p) => { root.fm-error-action(root.model.instance-id, p); }
                }
            }
        }
    }

    resize-se := TouchArea {
        x: parent.width - 12px;
        y: parent.height - 12px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nwse-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("se", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }

    resize-sw := TouchArea {
        x: 0;
        y: parent.height - 12px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nesw-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("sw", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }

    resize-ne := TouchArea {
        x: parent.width - 12px;
        y: 32px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nesw-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("ne", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }

    resize-nw := TouchArea {
        x: 0;
        y: 32px;
        width: 12px;
        height: 12px;
        mouse-cursor: MouseCursor.nwse-resize;
        moved => {
            if (self.pressed) {
                root.resize-moved(
                    root.x + self.x + self.mouse-x,
                    root.y + self.y + self.mouse-y
                );
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.resize-started("nw", root.x + self.x + self.mouse-x, root.y + self.y + self.mouse-y);
            } else if (event.kind == PointerEventKind.up) {
                root.resize-ended();
            }
        }
    }

    if model.close-confirm.visible : WidgetCloseConfirmDialog {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        dialog: model.close-confirm;
        save => { root.close-confirm-save(root.model.instance-id); }
        discard => { root.close-confirm-discard(root.model.instance-id); }
        cancel => { root.close-confirm-cancel(root.model.instance-id); }
    }
}
