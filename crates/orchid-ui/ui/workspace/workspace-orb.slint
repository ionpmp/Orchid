import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { NavigationGlobal } from "../navigation_global.slint";
import { AppState } from "../app_state_global.slint";
import { WorkspaceSummary } from "defs.slint";

/// Bottom-corner quarter-orchid control for switching and creating workspaces.
/// Opens on click (or edge-swipe / command via NavigationGlobal). Non-modal popover.
export component WorkspaceOrb inherits Rectangle {
    in property <[WorkspaceSummary]> workspaces;

    callback workspace-clicked(string);
    callback workspace-create-clicked();
    callback catalog-requested();
    callback toggle-requested();
    callback dismiss-requested();

    private property <length> orb-size: 76px;
    private property <bool> mirrored: AppState.edge-panels-mirrored;
    private property <bool> menu-visible: NavigationGlobal.workspace-orb-open;
    private property <bool> orb-active: NavigationGlobal.workspace-orb-open || orb-ta.has-hover;

    width: 100%;
    height: 100%;
    background: transparent;

    cluster := Rectangle {
        z: 100;
        x: root.mirrored ? parent.width - self.width : 0;
        y: parent.height - self.height;
        background: transparent;

        HorizontalLayout {
            alignment: root.mirrored ? end : start;

            VerticalLayout {
                alignment: end;
                spacing: 10px;

                if root.menu-visible: Rectangle {
                    // Vertical list panel — deliberately not square.
                    width: 260px;
                    height: menu-list.preferred-height + 16px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    drop-shadow-blur: Theme.reduce-motion ? 0px : 16px;
                    drop-shadow-color: #00000040;
                    drop-shadow-offset-y: Theme.reduce-motion ? 0px : 4px;
                    horizontal-stretch: 0;

                    menu-list := VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        Text {
                            text: NavigationGlobal.workspace-panel-title;
                            color: Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: Theme.weight-medium;
                            horizontal-stretch: 1;
                        }

                        // Only workspaces that exist in storage (no placeholder slots).
                        for ws[i] in root.workspaces: Rectangle {
                            height: 36px;
                            background: ws.is-active ? Theme.accent-brand : Theme.surface-base;
                            border-radius: Theme.radius-md;
                            horizontal-stretch: 1;

                            ws-ta := TouchArea {
                                clicked => {
                                    root.workspace-clicked(ws.id);
                                    root.dismiss-requested();
                                }
                            }
                            states [
                                hover when ws-ta.has-hover && !ws.is-active: {
                                    background: Theme.surface-raised;
                                }
                            ]

                            Text {
                                x: 12px;
                                width: parent.width - 24px;
                                height: 100%;
                                text: ws.name;
                                color: ws.is-active ? Theme.text-primary : Theme.text-secondary;
                                font-size: Theme.font-size-sm;
                                font-weight: ws.is-active ? Theme.weight-semibold : Theme.weight-regular;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }

                        Rectangle {
                            height: 36px;
                            background: Theme.surface-base;
                            border-radius: Theme.radius-md;
                            border-width: 1px;
                            border-color: Theme.border-default;
                            horizontal-stretch: 1;

                            add-ta := TouchArea {
                                clicked => {
                                    root.catalog-requested();
                                    root.dismiss-requested();
                                }
                            }
                            states [
                                hover when add-ta.has-hover: {
                                    border-color: Theme.accent-brand;
                                }
                            ]

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: "⊞";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-md;
                                    font-weight: Theme.weight-semibold;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: Strings.dock-add-label;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle {
                            height: 36px;
                            background: Theme.surface-base;
                            border-radius: Theme.radius-md;
                            border-width: 1px;
                            border-color: Theme.border-default;
                            horizontal-stretch: 1;

                            new-ta := TouchArea {
                                clicked => {
                                    root.workspace-create-clicked();
                                    root.dismiss-requested();
                                }
                            }
                            states [
                                hover when new-ta.has-hover: {
                                    border-color: Theme.accent-brand;
                                }
                            ]

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: "+";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-lg;
                                    font-weight: Theme.weight-semibold;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: Strings.workspace-new-label;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }
                }

                orb := Rectangle {
                    width: root.orb-size;
                    height: root.orb-size;
                    background: transparent;
                    clip: true;
                    horizontal-stretch: 0;

                    orb-ta := TouchArea {
                        clicked => {
                            root.toggle-requested();
                        }
                    }

                    // Soft brand glow behind the quarter.
                    Rectangle {
                        x: root.mirrored ? parent.width - root.orb-size * 1.15 : -root.orb-size * 0.15;
                        y: parent.height - root.orb-size * 1.15;
                        width: root.orb-size * 1.3;
                        height: root.orb-size * 1.3;
                        border-radius: root.orb-size;
                        background: root.mirrored ? #7a4ea833 : #c49be633;
                    }

                    // Outer quarter disc (petal field), center at screen corner.
                    Path {
                        width: 100%;
                        height: 100%;
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: 100;
                        viewbox-height: 100;
                        fill: Theme.accent-brand;
                        MoveTo { x: root.mirrored ? 100 : 0; y: 100; }
                        LineTo { x: root.mirrored ? 100 : 0; y: 0; }
                        ArcTo {
                            radius-x: 100;
                            radius-y: 100;
                            x: root.mirrored ? 0 : 100;
                            y: 100;
                            sweep: !root.mirrored;
                        }
                        Close {}
                    }

                    // Inner petal lobe — labellum-inspired curve toward the arc.
                    Path {
                        width: 100%;
                        height: 100%;
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: 100;
                        viewbox-height: 100;
                        fill: #ffffff33;
                        MoveTo { x: root.mirrored ? 100 : 0; y: 100; }
                        CubicTo {
                            control-1-x: root.mirrored ? 100 : 0;
                            control-1-y: 55;
                            control-2-x: root.mirrored ? 55 : 45;
                            control-2-y: 35;
                            x: root.mirrored ? 28 : 72;
                            y: 28;
                        }
                        CubicTo {
                            control-1-x: root.mirrored ? 48 : 52;
                            control-1-y: 58;
                            control-2-x: root.mirrored ? 70 : 30;
                            control-2-y: 78;
                            x: root.mirrored ? 100 : 0;
                            y: 100;
                        }
                        Close {}
                    }

                    // Secondary petal lobe along the floor.
                    Path {
                        width: 100%;
                        height: 100%;
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: 100;
                        viewbox-height: 100;
                        fill: #00000022;
                        MoveTo { x: root.mirrored ? 100 : 0; y: 100; }
                        CubicTo {
                            control-1-x: root.mirrored ? 70 : 30;
                            control-1-y: 100;
                            control-2-x: root.mirrored ? 40 : 60;
                            control-2-y: 88;
                            x: root.mirrored ? 22 : 78;
                            y: 72;
                        }
                        CubicTo {
                            control-1-x: root.mirrored ? 50 : 50;
                            control-1-y: 92;
                            control-2-x: root.mirrored ? 78 : 22;
                            control-2-y: 100;
                            x: root.mirrored ? 100 : 0;
                            y: 100;
                        }
                        Close {}
                    }

                    // Petal veins (suggesting workspace parts without fixed slots).
                    Path {
                        width: 100%;
                        height: 100%;
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: 100;
                        viewbox-height: 100;
                        stroke: #ffffff55;
                        stroke-width: 1.25px;
                        fill: transparent;
                        MoveTo { x: root.mirrored ? 100 : 0; y: 100; }
                        LineTo {
                            x: root.mirrored ? 100 - 88 * 0.866 : 88 * 0.866;
                            y: 100 - 88 * 0.5;
                        }
                        MoveTo { x: root.mirrored ? 100 : 0; y: 100; }
                        LineTo {
                            x: root.mirrored ? 100 - 88 * 0.5 : 88 * 0.5;
                            y: 100 - 88 * 0.866;
                        }
                    }

                    // Column / stigma core at the corner.
                    Rectangle {
                        x: root.mirrored ? parent.width - 16px : 0;
                        y: parent.height - 16px;
                        width: 16px;
                        height: 16px;
                        border-radius: 16px;
                        background: #ffffffcc;
                    }
                    Rectangle {
                        x: root.mirrored ? parent.width - 10px : 0;
                        y: parent.height - 10px;
                        width: 10px;
                        height: 10px;
                        border-radius: 10px;
                        background: Theme.accent-brand;
                    }

                    // Hover / open highlight rim.
                    if root.orb-active: Path {
                        width: 100%;
                        height: 100%;
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: 100;
                        viewbox-height: 100;
                        stroke: #ffffffaa;
                        stroke-width: 2px;
                        fill: transparent;
                        MoveTo { x: root.mirrored ? 100 : 0; y: 0; }
                        ArcTo {
                            radius-x: 100;
                            radius-y: 100;
                            x: root.mirrored ? 0 : 100;
                            y: 100;
                            sweep: !root.mirrored;
                        }
                    }
                }
            }
        }
    }
}
