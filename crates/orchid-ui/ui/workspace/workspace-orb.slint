import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { NavigationGlobal } from "../navigation_global.slint";
import { AppState } from "../app_state_global.slint";
import { WorkspaceSummary } from "defs.slint";

/// Bottom-corner Crest-orchid control for switching and creating workspaces.
/// Opens on click (or edge-swipe / command via NavigationGlobal). Non-modal popover.
export component WorkspaceOrb inherits Rectangle {
    in property <[WorkspaceSummary]> workspaces;

    callback workspace-clicked(string);
    callback workspace-create-clicked();
    callback catalog-requested();
    callback toggle-requested();
    callback dismiss-requested();

    private property <length> orb-size: 88px;
    private property <bool> mirrored: AppState.edge-panels-mirrored;
    private property <bool> menu-visible: NavigationGlobal.workspace-orb-open;
    private property <bool> orb-active: NavigationGlobal.workspace-orb-open || orb-ta.has-hover;

    width: 100%;
    height: 100%;
    background: transparent;

    cluster := Rectangle {
        z: 100;
        x: root.mirrored ? parent.width - self.width : 0;
        y: parent.height - self.height;
        background: transparent;

        HorizontalLayout {
            alignment: root.mirrored ? end : start;

            VerticalLayout {
                alignment: end;
                spacing: 10px;

                if root.menu-visible: Rectangle {
                    // Vertical list panel — deliberately not square.
                    width: 260px;
                    height: menu-list.preferred-height + 16px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    drop-shadow-blur: Theme.reduce-motion ? 0px : 16px;
                    drop-shadow-color: #00000040;
                    drop-shadow-offset-y: Theme.reduce-motion ? 0px : 4px;
                    horizontal-stretch: 0;

                    menu-list := VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        Text {
                            text: NavigationGlobal.workspace-panel-title;
                            color: Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: Theme.weight-medium;
                            horizontal-stretch: 1;
                        }

                        // Only workspaces that exist in storage (no placeholder slots).
                        for ws[i] in root.workspaces: Rectangle {
                            height: 36px;
                            background: ws.is-active ? Theme.accent-brand : Theme.surface-base;
                            border-radius: Theme.radius-md;
                            horizontal-stretch: 1;

                            ws-ta := TouchArea {
                                clicked => {
                                    root.workspace-clicked(ws.id);
                                    root.dismiss-requested();
                                }
                            }
                            states [
                                hover when ws-ta.has-hover && !ws.is-active: {
                                    background: Theme.surface-raised;
                                }
                            ]

                            Text {
                                x: 12px;
                                width: parent.width - 24px;
                                height: 100%;
                                text: ws.name;
                                color: ws.is-active ? Theme.text-primary : Theme.text-secondary;
                                font-size: Theme.font-size-sm;
                                font-weight: ws.is-active ? Theme.weight-semibold : Theme.weight-regular;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }

                        Rectangle {
                            height: 36px;
                            background: Theme.surface-base;
                            border-radius: Theme.radius-md;
                            border-width: 1px;
                            border-color: Theme.border-default;
                            horizontal-stretch: 1;

                            add-ta := TouchArea {
                                clicked => {
                                    root.catalog-requested();
                                    root.dismiss-requested();
                                }
                            }
                            states [
                                hover when add-ta.has-hover: {
                                    border-color: Theme.accent-brand;
                                }
                            ]

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: "⊞";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-md;
                                    font-weight: Theme.weight-semibold;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: Strings.dock-add-label;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle {
                            height: 36px;
                            background: Theme.surface-base;
                            border-radius: Theme.radius-md;
                            border-width: 1px;
                            border-color: Theme.border-default;
                            horizontal-stretch: 1;

                            new-ta := TouchArea {
                                clicked => {
                                    root.workspace-create-clicked();
                                    root.dismiss-requested();
                                }
                            }
                            states [
                                hover when new-ta.has-hover: {
                                    border-color: Theme.accent-brand;
                                }
                            ]

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: start;

                                Text {
                                    text: "+";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-lg;
                                    font-weight: Theme.weight-semibold;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: Strings.workspace-new-label;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }
                }

                orb := Rectangle {
                    width: root.orb-size;
                    height: root.orb-size;
                    background: transparent;
                    clip: false;
                    horizontal-stretch: 0;

                    orb-ta := TouchArea {
                        clicked => {
                            root.toggle-requested();
                        }
                    }

                    // Soft brand glow behind the Crest flower (circular, not a square plate).
                    Rectangle {
                        x: (parent.width - root.orb-size * 0.9) / 2;
                        y: (parent.height - root.orb-size * 0.9) / 2;
                        width: root.orb-size * 0.9;
                        height: root.orb-size * 0.9;
                        border-radius: root.orb-size;
                        background: root.orb-active ? #c49be655 : #c49be633;
                    }

                    Image {
                        width: 100%;
                        height: 100%;
                        source: @image-url("../assets/orchid-icon.png");
                        image-fit: contain;
                        opacity: root.orb-active ? 1.0 : 0.92;
                    }
                }
            }
        }
    }
}
