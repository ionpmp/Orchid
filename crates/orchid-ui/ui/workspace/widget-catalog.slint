                            card-visible: WidgetCatalog.show-system;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "terminal"; glyph: ">_"; label: Strings.dock-widget-terminal;
                            description: Strings.widget-terminal-desc;
                            card-visible: WidgetCatalog.show-terminal;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "viewer"; glyph: "V"; label: Strings.dock-widget-viewer;
                            description: Strings.widget-viewer-desc;
                            card-visible: WidgetCatalog.show-viewer;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "weather"; glyph: "W"; label: Strings.dock-widget-weather;
                            description: Strings.widget-weather-desc;
                            card-visible: WidgetCatalog.show-weather;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "processes"; glyph: "P"; label: Strings.dock-widget-processes;
                            description: Strings.widget-processes-desc;
                            card-visible: WidgetCatalog.show-processes;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "calculator"; glyph: "="; label: Strings.dock-widget-calculator;
                            description: Strings.widget-calculator-desc;
                            card-visible: WidgetCatalog.show-calculator;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "notes"; glyph: "≡"; label: Strings.dock-widget-notes;
                            description: Strings.widget-notes-desc;
                            card-visible: WidgetCatalog.show-notes;
                            pick(id) => { root.pick(id); }
                        }
                    }
                }

                // ---- Z–A ----
                if root.sort-mode == 2 : VerticalLayout {
                    width: 100%;
                    spacing: 8px;

                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "weather"; glyph: "W"; label: Strings.dock-widget-weather;
                            description: Strings.widget-weather-desc;
                            card-visible: WidgetCatalog.show-weather;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "viewer"; glyph: "V"; label: Strings.dock-widget-viewer;
                            description: Strings.widget-viewer-desc;
                            card-visible: WidgetCatalog.show-viewer;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "terminal"; glyph: ">_"; label: Strings.dock-widget-terminal;
                            description: Strings.widget-terminal-desc;
                            card-visible: WidgetCatalog.show-terminal;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "system"; glyph: "S"; label: Strings.dock-widget-system;
                            description: Strings.widget-system-desc;
                            card-visible: WidgetCatalog.show-system;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "search"; glyph: "/"; label: Strings.dock-widget-search;
                            description: Strings.widget-search-desc;
                            card-visible: WidgetCatalog.show-search;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "recent-files"; glyph: "R"; label: Strings.dock-widget-recent-files;
                            description: Strings.widget-recent-files-desc;
                            card-visible: WidgetCatalog.show-recent-files;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "password"; glyph: "*"; label: Strings.dock-widget-password;
                            description: Strings.widget-password-desc;
                            card-visible: WidgetCatalog.show-password;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "rss"; glyph: "N"; label: Strings.dock-widget-rss;
                            description: Strings.widget-rss-desc;
                            card-visible: WidgetCatalog.show-rss;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "moon"; glyph: "O"; label: Strings.dock-widget-moon;
                            description: Strings.widget-moon-desc;
                            card-visible: WidgetCatalog.show-moon;
                            pick(id) => { root.pick(id); }
