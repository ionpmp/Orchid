import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { WidgetCatalog } from "../widget_catalog_global.slint";

/// One catalog row — hardcoded type-id, labels from Strings.
component CatalogRow inherits Rectangle {
    in property <string> type-id;
    in property <string> label;
    in property <string> description;
    in property <bool> row-visible: true;
    callback pick(string);

    height: root.row-visible ? (root.description != "" ? 56px : 40px) : 0px;
    visible: root.row-visible;
    background: item-touch.has-hover ? Theme.surface-base : transparent;
    border-radius: Theme.radius-md;
    clip: true;

    item-touch := TouchArea {
        clicked => { root.pick(root.type-id); }
    }

    VerticalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 2px;
        alignment: center;

        Text {
            text: root.label;
            color: Theme.text-primary;
            font-size: Theme.font-size-sm;
            font-weight: Theme.weight-semibold;
            vertical-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        if root.description != "" : Text {
            text: root.description;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
            wrap: no-wrap;
            overflow: elide;
        }
    }
}

/// Widget picker catalog panel.
///
/// Rows are hardcoded (labels from Strings) because Slint `for` over a model
/// passed into this overlay has repeatedly painted an empty list. Visibility
/// of each row is driven by `WidgetCatalog.show-*` flags from Rust filtering.
export component WidgetCatalogPanel inherits Rectangle {
    callback pick(string);
    callback dismiss();
    callback search-changed(string);

    width: 300px;
    height: 380px;
    background: Theme.surface-raised;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    drop-shadow-blur: Theme.reduce-motion ? 0px : 12px;
    drop-shadow-color: #00000050;
    clip: true;

    property <string> draft-query: "";
    property <string> mirrored-query: WidgetCatalog.search-query;

    changed mirrored-query => {
        root.draft-query = root.mirrored-query;
    }

    VerticalLayout {
        width: 100%;
        height: 100%;
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: Theme.spacing-unit;

            Text {
                text: Strings.catalog-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 28px;
                height: 28px;
                background: close-ta.has-hover ? Theme.surface-base : transparent;
                border-radius: Theme.radius-md;

                close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: catalog-input.has-focus ? Theme.accent-brand : Theme.border-default;
            clip: true;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 100%;

                    if root.draft-query == "" : Text {
                        width: parent.width;
                        height: parent.height;
                        text: Strings.catalog-search-placeholder;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    catalog-input := TextInput {
                        width: parent.width;
                        height: parent.height;
                        text <=> root.draft-query;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        single-line: true;
                        edited => {
                            root.search-changed(self.text);
                        }
                    }
                }
            }
        }

        if WidgetCatalog.is-empty : Text {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            text: Strings.catalog-no-results;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        if !WidgetCatalog.is-empty : Flickable {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            height: 300px;
            viewport-width: self.width;
            viewport-height: max(300px, catalog-list.preferred-height);

            catalog-list := VerticalLayout {
                spacing: 2px;
                width: parent.width;

                CatalogRow {
                    type-id: "terminal";
                    label: Strings.dock-widget-terminal;
                    description: Strings.widget-terminal-desc;
                    row-visible: WidgetCatalog.show-terminal;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "weather";
                    label: Strings.dock-widget-weather;
                    description: Strings.widget-weather-desc;
                    row-visible: WidgetCatalog.show-weather;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "moon";
                    label: Strings.dock-widget-moon;
                    description: Strings.widget-moon-desc;
                    row-visible: WidgetCatalog.show-moon;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "system";
                    label: Strings.dock-widget-system;
                    description: Strings.widget-system-desc;
                    row-visible: WidgetCatalog.show-system;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "rss";
                    label: Strings.dock-widget-rss;
                    description: Strings.widget-rss-desc;
                    row-visible: WidgetCatalog.show-rss;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "recent-files";
                    label: Strings.dock-widget-recent-files;
                    description: Strings.widget-recent-files-desc;
                    row-visible: WidgetCatalog.show-recent-files;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "search";
                    label: Strings.dock-widget-search;
                    description: Strings.widget-search-desc;
                    row-visible: WidgetCatalog.show-search;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "media";
                    label: Strings.dock-widget-media;
                    description: Strings.widget-media-desc;
                    row-visible: WidgetCatalog.show-media;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "password";
                    label: Strings.dock-widget-password;
                    description: Strings.widget-password-desc;
                    row-visible: WidgetCatalog.show-password;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "viewer";
                    label: Strings.dock-widget-viewer;
                    description: Strings.widget-viewer-desc;
                    row-visible: WidgetCatalog.show-viewer;
                    pick(id) => { root.pick(id); }
                }
                CatalogRow {
                    type-id: "file-manager";
                    label: Strings.dock-widget-fm;
                    description: Strings.widget-fm-desc;
                    row-visible: WidgetCatalog.show-file-manager;
                    pick(id) => { root.pick(id); }
                }
            }
        }
    }
}
