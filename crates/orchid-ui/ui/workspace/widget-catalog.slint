import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { WidgetCatalog } from "../widget_catalog_global.slint";

/// Wide catalog tile: icon on the left, title + wrapped description on the right.
component CatalogCard inherits Rectangle {
    in property <string> type-id;
    in property <string> label;
    in property <string> description;
    in property <string> glyph;
    in property <bool> card-visible: true;
    callback pick(string);

    horizontal-stretch: 1;
    min-width: 220px;
    height: root.card-visible ? 88px : 0px;
    visible: root.card-visible;
    background: card-ta.has-hover ? Theme.surface-base : transparent;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: card-ta.has-hover ? Theme.accent-brand : Theme.border-default;
    clip: true;

    card-ta := TouchArea {
        clicked => { root.pick(root.type-id); }
    }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding: 12px;
        spacing: 12px;
        alignment: center;

        Rectangle {
            width: 40px;
            height: 40px;
            background: Theme.accent-brand;
            border-radius: 8px;
            opacity: 0.92;

            Text {
                width: 100%;
                height: 100%;
                text: root.glyph;
                color: #ffffff;
                font-size: 15px;
                font-weight: Theme.weight-semibold;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;

            Text {
                text: root.label;
                color: Theme.text-primary;
                font-size: Theme.font-size-sm;
                font-weight: Theme.weight-semibold;
                wrap: no-wrap;
                overflow: elide;
            }

            Text {
                text: root.description;
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                wrap: word-wrap;
                overflow: elide;
            }
        }
    }
}

/// Widget picker: 2-column card grid with room for descriptions.
export component WidgetCatalogPanel inherits Rectangle {
    callback pick(string);
    callback dismiss();
    callback search-changed(string);

    width: 640px;
    height: 520px;
    background: Theme.surface-raised;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    drop-shadow-blur: Theme.reduce-motion ? 0px : 12px;
    drop-shadow-color: #00000050;
    clip: true;

    property <string> draft-query: "";
    /// 0 = default (logical), 1 = A–Z, 2 = Z–A
    property <int> sort-mode: 0;

    pure function sort-label() -> string {
        return root.sort-mode == 1 ? Strings.catalog-sort-name-asc
            : root.sort-mode == 2 ? Strings.catalog-sort-name-desc
            : Strings.catalog-sort-default;
    }

    VerticalLayout {
        width: 100%;
        height: 100%;
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            height: 28px;
            spacing: Theme.spacing-unit;

            Text {
                text: Strings.catalog-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: sort-label-text.preferred-width + 20px;
                height: 28px;
                background: sort-ta.has-hover ? Theme.surface-base : transparent;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;

                sort-ta := TouchArea {
                    clicked => {
                        root.sort-mode = root.sort-mode >= 2 ? 0 : root.sort-mode + 1;
                    }
                }

                sort-label-text := Text {
                    width: 100%;
                    height: 100%;
                    text: root.sort-label();
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                width: 28px;
                height: 28px;
                background: close-ta.has-hover ? Theme.surface-base : transparent;
                border-radius: Theme.radius-md;

                close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }

                Text {
                    width: 100%;
                    height: 100%;
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: catalog-input.has-focus ? Theme.accent-brand : Theme.border-default;
            clip: true;

            if root.draft-query == "" : Text {
                x: 10px;
                width: parent.width - 20px;
                height: 100%;
                text: Strings.catalog-search-placeholder;
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }

            catalog-input := TextInput {
                x: 10px;
                width: parent.width - 20px;
                height: 100%;
                text <=> root.draft-query;
                color: Theme.text-primary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
                single-line: true;
                edited => {
                    root.search-changed(self.text);
                }
            }
        }

        if WidgetCatalog.is-empty : Text {
            vertical-stretch: 1;
            text: Strings.catalog-no-results;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        if !WidgetCatalog.is-empty : Flickable {
            vertical-stretch: 1;
            height: 420px;
            width: 100%;
            viewport-width: self.width;
            viewport-height: 580px;

            VerticalLayout {
                width: parent.viewport-width;
                spacing: 8px;
                padding-right: 2px;

                // ---- Default (logical) order ----
                if root.sort-mode == 0 : VerticalLayout {
                    width: 100%;
                    spacing: 8px;

                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "terminal"; glyph: ">_"; label: Strings.dock-widget-terminal;
                            description: Strings.widget-terminal-desc;
                            card-visible: WidgetCatalog.show-terminal;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "weather"; glyph: "W"; label: Strings.dock-widget-weather;
                            description: Strings.widget-weather-desc;
                            card-visible: WidgetCatalog.show-weather;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "moon"; glyph: "O"; label: Strings.dock-widget-moon;
                            description: Strings.widget-moon-desc;
                            card-visible: WidgetCatalog.show-moon;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "clock"; glyph: "C"; label: Strings.dock-widget-clock;
                            description: Strings.widget-clock-desc;
                            card-visible: WidgetCatalog.show-clock;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "system"; glyph: "S"; label: Strings.dock-widget-system;
                            description: Strings.widget-system-desc;
                            card-visible: WidgetCatalog.show-system;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "rss"; glyph: "N"; label: Strings.dock-widget-rss;
                            description: Strings.widget-rss-desc;
                            card-visible: WidgetCatalog.show-rss;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "recent-files"; glyph: "R"; label: Strings.dock-widget-recent-files;
                            description: Strings.widget-recent-files-desc;
                            card-visible: WidgetCatalog.show-recent-files;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "search"; glyph: "/"; label: Strings.dock-widget-search;
                            description: Strings.widget-search-desc;
                            card-visible: WidgetCatalog.show-search;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "media"; glyph: "M"; label: Strings.dock-widget-media;
                            description: Strings.widget-media-desc;
                            card-visible: WidgetCatalog.show-media;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "password"; glyph: "*"; label: Strings.dock-widget-password;
                            description: Strings.widget-password-desc;
                            card-visible: WidgetCatalog.show-password;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "viewer"; glyph: "V"; label: Strings.dock-widget-viewer;
                            description: Strings.widget-viewer-desc;
                            card-visible: WidgetCatalog.show-viewer;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "file-manager"; glyph: "#"; label: Strings.dock-widget-fm;
                            description: Strings.widget-fm-desc;
                            card-visible: WidgetCatalog.show-file-manager;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "processes"; glyph: "P"; label: Strings.dock-widget-processes;
                            description: Strings.widget-processes-desc;
                            card-visible: WidgetCatalog.show-processes;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "calculator"; glyph: "="; label: Strings.dock-widget-calculator;
                            description: Strings.widget-calculator-desc;
                            card-visible: WidgetCatalog.show-calculator;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "notes"; glyph: "≡"; label: Strings.dock-widget-notes;
                            description: Strings.widget-notes-desc;
                            card-visible: WidgetCatalog.show-notes;
                            pick(id) => { root.pick(id); }
                        }
                    }
                }

                // ---- A–Z ----
                if root.sort-mode == 1 : VerticalLayout {
                    width: 100%;
                    spacing: 8px;

                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "file-manager"; glyph: "#"; label: Strings.dock-widget-fm;
                            description: Strings.widget-fm-desc;
                            card-visible: WidgetCatalog.show-file-manager;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "media"; glyph: "M"; label: Strings.dock-widget-media;
                            description: Strings.widget-media-desc;
                            card-visible: WidgetCatalog.show-media;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "moon"; glyph: "O"; label: Strings.dock-widget-moon;
                            description: Strings.widget-moon-desc;
                            card-visible: WidgetCatalog.show-moon;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "clock"; glyph: "C"; label: Strings.dock-widget-clock;
                            description: Strings.widget-clock-desc;
                            card-visible: WidgetCatalog.show-clock;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "rss"; glyph: "N"; label: Strings.dock-widget-rss;
                            description: Strings.widget-rss-desc;
                            card-visible: WidgetCatalog.show-rss;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "password"; glyph: "*"; label: Strings.dock-widget-password;
                            description: Strings.widget-password-desc;
                            card-visible: WidgetCatalog.show-password;
                            pick(id) => { root.pick(id); }
                        }
                        CatalogCard {
                            type-id: "recent-files"; glyph: "R"; label: Strings.dock-widget-recent-files;
                            description: Strings.widget-recent-files-desc;
                            card-visible: WidgetCatalog.show-recent-files;
                            pick(id) => { root.pick(id); }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        height: 88px;
                        CatalogCard {
                            type-id: "search"; glyph: "/"; label: Strings.dock-widget-search;
                            description: Strings.widget-search-desc;
