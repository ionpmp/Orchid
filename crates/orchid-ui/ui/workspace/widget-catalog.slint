import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { WidgetCatalog } from "../widget_catalog_global.slint";

export component WidgetCatalogPanel inherits Rectangle {
    callback pick(string);
    callback dismiss();
    callback search-changed(string);

    width: 300px;
    height: 380px;
    background: Theme.surface-raised;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    drop-shadow-blur: 12px;
    drop-shadow-color: #00000050;
    clip: true;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        Text {
            text: Strings.catalog-title;
            color: Theme.text-primary;
            font-size: Theme.font-size-md;
            font-weight: Theme.weight-semibold;
        }

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: catalog-input.has-focus ? Theme.accent-brand : Theme.border-default;

            catalog-input := TextInput {
                width: 100%;
                height: 100%;
                text <=> WidgetCatalog.search-query;
                edited => {
                    root.search-changed(self.text);
                }
            }
        }

        Flickable {
            viewport-height: 300px;
            height: 300px;

            VerticalLayout {
                spacing: 2px;
                for item[i] in WidgetCatalog.items: Rectangle {
                    height: 40px;
                    background: item-touch.has-hover ? Theme.surface-base : transparent;
                    border-radius: Theme.radius-md;

                    item-touch := TouchArea {
                        clicked => {
                            root.pick(item.type-id);
                        }
                    }

                    Text {
                        x: 12px;
                        text: item.label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
