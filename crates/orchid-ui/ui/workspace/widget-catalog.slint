import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { DockWidgetType } from "defs.slint";

export component WidgetCatalogPanel inherits Rectangle {
    in property <[DockWidgetType]> items;
    /// Driven from Rust only when the catalog opens/clears; typing updates via `edited`.
    in property <string> search-query;
    in property <bool> is-empty;

    callback pick(string);
    callback dismiss();
    callback search-changed(string);

    width: 300px;
    height: 380px;
    background: Theme.surface-raised;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    drop-shadow-blur: Theme.reduce-motion ? 0px : 12px;
    drop-shadow-color: #00000050;
    clip: true;

    // Local draft so one-way `in` search-query resets do not fight keystrokes mid-edit.
    property <string> draft-query: "";
    property <bool> editing: false;

    changed search-query => {
        if (!root.editing) {
            root.draft-query = root.search-query;
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: Theme.spacing-unit;

            Text {
                text: Strings.catalog-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 28px;
                height: 28px;
                background: close-ta.has-hover ? Theme.surface-base : transparent;
                border-radius: Theme.radius-md;

                close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: catalog-input.has-focus ? Theme.accent-brand : Theme.border-default;
            clip: true;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 100%;

                    if root.draft-query == "" : Text {
                        width: parent.width;
                        height: parent.height;
                        text: Strings.catalog-search-placeholder;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    catalog-input := TextInput {
                        width: parent.width;
                        height: parent.height;
                        text <=> root.draft-query;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        single-line: true;
                        edited => {
                            root.editing = true;
                            root.search-changed(self.text);
                        }
                        accepted => {
                            root.editing = false;
                        }
                        changed has-focus => {
                            if (!self.has-focus) {
                                root.editing = false;
                                root.draft-query = root.search-query;
                            }
                        }
                    }
                }
            }
        }

        if root.is-empty : Text {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            text: Strings.catalog-no-results;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        if !root.is-empty : Flickable {
            vertical-stretch: 1;
            viewport-width: self.width;
            // Fixed min viewport so the list always has paint space on first mount.
            viewport-height: max(300px, catalog-list.preferred-height);
            height: 300px;

            catalog-list := VerticalLayout {
                spacing: 2px;
                width: parent.width;

                for item[i] in root.items: Rectangle {
                    height: item.description != "" ? 56px : 40px;
                    background: item-touch.has-hover ? Theme.surface-base : transparent;
                    border-radius: Theme.radius-md;

                    item-touch := TouchArea {
                        clicked => { root.pick(item.type-id); }
                    }

                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 2px;
                        alignment: center;

                        Text {
                            text: item.label;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            font-weight: Theme.weight-semibold;
                            vertical-alignment: center;
                            wrap: no-wrap;
                            overflow: elide;
                        }

                        if item.description != "" : Text {
                            text: item.description;
                            color: Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            wrap: no-wrap;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }
}
