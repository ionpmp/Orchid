import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { DockWidgetType } from "defs.slint";

export component WidgetCatalogPanel inherits Rectangle {
    // Prefer a local model property: `for` over a global model is unreliable when
    // the panel is mounted under `if WidgetCatalog.visible`.
    in property <[DockWidgetType]> items;
    in property <string> search-query;

    callback pick(string);
    callback dismiss();
    callback search-changed(string);

    width: 300px;
    height: 380px;
    background: Theme.surface-raised;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    drop-shadow-blur: Theme.reduce-motion ? 0px : 12px;
    drop-shadow-color: #00000050;
    clip: true;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: Theme.spacing-unit;

            Text {
                text: Strings.catalog-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 28px;
                height: 28px;
                background: close-ta.has-hover ? Theme.surface-base : transparent;
                border-radius: Theme.radius-md;

                close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: catalog-input.has-focus ? Theme.accent-brand : Theme.border-default;
            clip: true;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 100%;

                    if root.search-query == "" : Text {
                        width: parent.width;
                        height: parent.height;
                        text: Strings.catalog-search-placeholder;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    catalog-input := TextInput {
                        width: parent.width;
                        height: parent.height;
                        text: root.search-query;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        single-line: true;
                        edited => {
                            root.search-changed(self.text);
                        }
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            clip: true;

            if root.items.length == 0 : Text {
                width: parent.width;
                height: parent.height;
                text: Strings.catalog-no-results;
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: max(self.height, catalog-list.preferred-height);

                catalog-list := VerticalLayout {
                    spacing: 2px;
                    width: parent.width;

                    for item[i] in root.items: Rectangle {
                        height: item.description != "" ? 56px : 40px;
                        background: item-touch.has-hover ? Theme.surface-base : transparent;
                        border-radius: Theme.radius-md;

                        item-touch := TouchArea {
                            clicked => {
                                root.pick(item.type-id);
                            }
                        }

                        VerticalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            padding-top: 8px;
                            padding-bottom: 8px;
                            spacing: 2px;
                            alignment: center;

                            Text {
                                text: item.label;
                                color: Theme.text-primary;
                                font-size: Theme.font-size-sm;
                                font-weight: Theme.weight-semibold;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }

                            if item.description != "" : Text {
                                text: item.description;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}
