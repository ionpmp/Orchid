import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { NavigationGlobal } from "../navigation_global.slint";
import { WidgetCatalog } from "../widget_catalog_global.slint";

export component WidgetCatalogPanel inherits Rectangle {
    callback pick(string);
    callback dismiss();
    callback search-changed(string);

    width: 300px;
    height: 380px;
    background: Theme.surface-raised;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    drop-shadow-blur: Theme.reduce-motion ? 0px : 12px;
    drop-shadow-color: #00000050;
    clip: true;

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: Theme.spacing-unit;

            Text {
                text: Strings.catalog-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-semibold;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 28px;
                height: 28px;
                background: close-ta.has-hover ? Theme.surface-base : transparent;
                border-radius: Theme.radius-md;

                close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }
                if close-ta.has-hover : Rectangle {
                    x: parent.x + parent.width - close-hint.preferred-width - 12px;
                    y: parent.height + 2px;
                    width: close-hint.preferred-width + 12px;
                    height: close-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    close-hint := Text {
                        x: 6px; y: 3px;
                        text: NavigationGlobal.panel-dismiss-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                Text {
                    text: "×";
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-lg;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: catalog-input.has-focus ? Theme.accent-brand : Theme.border-default;
            clip: true;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 100%;

                    if WidgetCatalog.search-query == "" : Text {
                        width: parent.width;
                        height: parent.height;
                        text: Strings.catalog-search-placeholder;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    catalog-input := TextInput {
                        width: parent.width;
                        height: parent.height;
                        text <=> WidgetCatalog.search-query;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        single-line: true;
                        edited => {
                            root.search-changed(self.text);
                        }
                    }
                }
            }
        }

        Flickable {
            viewport-height: 300px;
            height: 300px;

            VerticalLayout {
                spacing: 2px;
                for item[i] in WidgetCatalog.items: Rectangle {
                    height: 40px;
                    background: item-touch.has-hover ? Theme.surface-base : transparent;
                    border-radius: Theme.radius-md;

                    item-touch := TouchArea {
                        clicked => {
                            root.pick(item.type-id);
                        }
                    }

                    Text {
                        x: 12px;
                        text: item.label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
