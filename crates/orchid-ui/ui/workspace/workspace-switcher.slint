import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { WorkspaceSummary } from "defs.slint";

export component WorkspaceSwitcher inherits Rectangle {
    in property <[WorkspaceSummary]> workspaces;
    in property <string> active-workspace-id;

    callback workspace-clicked(string);
    callback workspace-create-clicked();

    background: Theme.surface-raised;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.border-default;
    }

    HorizontalLayout {
        padding: 4px;
        spacing: 4px;
        alignment: start;

        for ws[i] in workspaces: Rectangle {
            width: 120px;
            height: 32px;
            background: ws.is-active ? Theme.accent-brand : Theme.surface-base;
            border-radius: Theme.radius-md;

            ws-ta := TouchArea {
                clicked => { root.workspace-clicked(ws.id); }
            }
            if ws-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: ws-hint.preferred-width + 12px;
                height: ws-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                ws-hint := Text {
                    x: 6px; y: 3px;
                    text: ws.name;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            Text {
                text: ws.name;
                color: ws.is-active ? Theme.text-primary : Theme.text-secondary;
                font-size: Theme.font-size-sm;
                font-weight: ws.is-active ? Theme.weight-semibold : Theme.weight-regular;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: no-wrap;
                overflow: elide;
            }
        }

        Rectangle {
            width: 32px;
            height: 32px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;

            new-ta := TouchArea {
                clicked => { root.workspace-create-clicked(); }
            }
            if new-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: new-hint.preferred-width + 12px;
                height: new-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                new-hint := Text {
                    x: 6px; y: 3px;
                    text: Strings.workspace-new-label;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            Text {
                text: "+";
                color: Theme.text-secondary;
                font-size: Theme.font-size-lg;
                font-weight: Theme.weight-semibold;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
