import { Theme } from "theme_global.slint";
import { Strings } from "strings_global.slint";
import { SettingsGlobal } from "settings_global.slint";
import { CheckBox, ComboBox, LineEdit } from "std-widgets.slint";

export component SettingsPanel inherits Rectangle {
    callback dismiss();
    callback section-selected(int);
    callback field-changed(string, string, string);
    callback open-config();

    background: Theme.surface-raised;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-default;
    drop-shadow-blur: Theme.reduce-motion ? 0px : 16px;
    drop-shadow-color: #00000060;
    clip: true;

    HorizontalLayout {
        padding: 0;
        spacing: 0;

        // Section sidebar
        Rectangle {
            width: 148px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;

            VerticalLayout {
                padding: 8px;
                spacing: 2px;

                for sec[i] in SettingsGlobal.sections: Rectangle {
                    height: 36px;
                    background:
                        i == SettingsGlobal.selected-section-index
                            ? Theme.surface-raised
                            : (sec-ta.has-hover ? Theme.surface-raised : transparent);
                    border-radius: Theme.radius-md;
                    border-width: i == SettingsGlobal.selected-section-index ? 1px : 0px;
                    border-color: i == SettingsGlobal.selected-section-index
                        ? Theme.accent-brand : transparent;

                    sec-ta := TouchArea {
                        clicked => {
                            root.section-selected(i);
                        }
                    }
                    if sec-ta.has-hover : Rectangle {
                        x: parent.width + 4px;
                        y: parent.y;
                        width: sec-hint.preferred-width + 12px;
                        height: sec-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        sec-hint := Text {
                            x: 6px; y: 3px;
                            text: sec.label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    Text {
                        x: 12px;
                        text: sec.label;
                        color: i == SettingsGlobal.selected-section-index
                            ? Theme.accent-brand : Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        wrap: no-wrap;
                        overflow: elide;
                        width: parent.width - 16px;
                    }
                }
            }
        }

        // Content
        VerticalLayout {
            padding: 20px;
            spacing: 12px;
            horizontal-stretch: 1;

            Text {
                text: SettingsGlobal.panel-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-lg;
                font-weight: Theme.weight-semibold;
            }

            Text {
                text: SettingsGlobal.hint-text;
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                wrap: word-wrap;
            }

            if SettingsGlobal.coming-soon-text != "" : Text {
                text: SettingsGlobal.coming-soon-text;
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                wrap: word-wrap;
            }

            if SettingsGlobal.config-path != "" : VerticalLayout {
                spacing: 6px;

                Text {
                    text: SettingsGlobal.config-path;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 32px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;

                    open-cfg-ta := TouchArea {
                        clicked => { root.open-config(); }
                    }
                    if open-cfg-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: open-cfg-hint.preferred-width + 12px;
                        height: open-cfg-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        open-cfg-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.settings_open_in_editor;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    Text {
                        text: Strings.settings_open_config_file;
                        color: Theme.accent-brand;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Flickable {
                vertical-stretch: 1;
                viewport-width: parent.width;
                viewport-height: field-list.preferred-height;

                field-list := VerticalLayout {
                    width: parent.viewport-width;
                    spacing: 8px;

                    for row in SettingsGlobal.fields: HorizontalLayout {
                        spacing: 12px;
                        min-height: 32px;

                        Text {
                            width: 42%;
                            text: row.label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                            wrap: word-wrap;
                            vertical-alignment: center;
                        }

                        if row.kind == 0 : Text {
                            horizontal-stretch: 1;
                            text: row.value;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            wrap: word-wrap;
                            vertical-alignment: center;
                        }

                        if row.kind == 1 : CheckBox {
                            horizontal-stretch: 1;
                            checked: row.bool-value;
                            toggled => {
                                root.field-changed(
                                    SettingsGlobal.current-section-id,
                                    row.key,
                                    self.checked ? "true" : "false",
                                );
                            }
                        }

                        if row.kind == 2 : LineEdit {
                            horizontal-stretch: 1;
                            text: row.value;
                            font-size: Theme.font-size-sm;
                            accepted(text) => {
                                root.field-changed(
                                    SettingsGlobal.current-section-id,
                                    row.key,
                                    text,
                                );
                            }
                        }

                        if row.kind == 3 : ComboBox {
                            horizontal-stretch: 1;
                            model: row.combo-options;
                            current-index: row.combo-index;
                            selected(_value) => {
                                root.field-changed(
                                    SettingsGlobal.current-section-id,
                                    row.key,
                                    row.combo-values[self.current-index],
                                );
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 36px;
                background: Theme.accent-brand;
                border-radius: Theme.radius-md;
                opacity: close-ta.has-hover ? 0.88 : 1.0;

                close-ta := TouchArea {
                    clicked => { root.dismiss(); }
                }
                if close-ta.has-hover : Rectangle {
                    x: parent.x;
                    y: parent.height + 2px;
                    width: close-hint.preferred-width + 12px;
                    height: close-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    close-hint := Text {
                        x: 6px; y: 3px;
                        text: Strings.settings_panel_ok;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                Text {
                    text: Strings.settings_panel_ok;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-md;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
