            }

            if NavigationGlobal.notification-center-visible: Rectangle {
                width: 100%;
                height: 100%;

                TouchArea {
                    clicked => { root.notification-center-dismiss(); }
                }

                NotificationCenter {
                    // Default: right. Mirrored: left.
                    x: AppState.edge-panels-mirrored ? 0 : parent.width - self.width;
                    y: 0;
                    height: parent.height;
                    dismiss => { root.notification-center-dismiss(); }
                }
            }

            if CommandPaletteGlobal.visible: Rectangle {
                width: 100%;
                height: 100%;
                background: #00000050;

                palette-backdrop := TouchArea {
                    clicked => {
                        root.command-palette-dismiss();
                    }
                }

                CommandPalettePanel {
                    width: min(parent.width - 32px, 560px);
                    height: min(parent.height - 120px, 420px);
                    x: (parent.width - self.width) / 2;
                    y: parent.height * 0.12;
                    query-changed(q) => {
                        root.command-palette-query-changed(q);
                    }
                    candidate-activated(id) => {
                        root.command-palette-candidate-activated(id);
                    }
                    selection-changed(idx) => {
                        root.command-palette-selection-changed(idx);
                    }
                    dismiss => {
                        root.command-palette-dismiss();
                    }
                }
            }

            if SettingsGlobal.visible: Rectangle {
                width: 100%;
                height: 100%;
                background: #00000050;

                TouchArea {
                    clicked => {
                        root.settings-dismiss();
                    }
                }

                SettingsPanel {
                    width: min(parent.width - 48px, 720px);
                    height: min(parent.height - 80px, 480px);
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    dismiss => {
                        root.settings-dismiss();
                    }
                    section-selected(idx) => {
                        root.settings-section-selected(idx);
                    }
                    field-changed(section, key, value) => {
                        root.settings-field-changed(section, key, value);
                    }
                    open-config => {
                        root.settings-open-config();
                    }
                }
            }
        }
    }

    if OnboardingGlobal.overlay-visible: OnboardingOverlay {
        next-clicked => { root.onboarding-next-clicked(); }
        back-clicked => { root.onboarding-back-clicked(); }
        skip-clicked => { root.onboarding-skip-clicked(); }
    }
    }
}

