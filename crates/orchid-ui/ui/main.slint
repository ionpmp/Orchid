export component MainWindow inherits Window {
    title: Strings.window-title;
    icon: @image-url("assets/orchid-icon.png");
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 800px;
    min-height: 600px;
    background: Theme.surface-base;
    default-font-family: Theme.font-family-sans;
    default-font-size: Theme.font-size-md;

    callback get-started-clicked();
