    callback ui-tick();

    root-layer := Rectangle {
        width: 100%;
        height: 100%;

    VerticalLayout {
        width: 100%;
        height: 100%;
        padding: 0;

        Timer {
            interval: 16ms;
            running: AppState.mode == 1;
            triggered => { root.ui-tick(); }
        }

        if AppState.mode == 0: VerticalLayout {
            padding: Theme.spacing-unit * 8;
            spacing: Theme.spacing-unit * 4;
            alignment: center;

            Text {
                text: Strings.welcome;
                color: Theme.text-primary;
                font-size: Theme.font-size-3xl;
                font-weight: Theme.weight-semibold;
                horizontal-alignment: center;
            }

            Text {
                text: Strings.subtitle;
                color: Theme.text-secondary;
                font-size: Theme.font-size-lg;
                horizontal-alignment: center;
            }

            Rectangle {
                width: 320px;
                height: 56px;
                background: Theme.accent-brand;
                border-radius: Theme.radius-md;
                opacity: start-ta.has-hover ? 0.88 : 1.0;

                start-ta := TouchArea {
                    clicked => { root.get-started-clicked(); }
                }
                if start-ta.has-hover : Rectangle {
                    x: parent.x;
                    y: parent.height + 2px;
                    width: start-hint.preferred-width + 12px;
                    height: start-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    start-hint := Text {
                        x: 6px; y: 3px;
                        text: Strings.get-started-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                Text {
                    text: Strings.get-started-label;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-lg;
                    font-weight: Theme.weight-semibold;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                spacing: Theme.spacing-unit;
                alignment: center;

                Text {
                    text: Strings.version-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                }

                HorizontalLayout {
                    spacing: Theme.spacing-unit * 3;
                    alignment: center;

                    Text {
                        text: Strings.theme-label + " " + AppState.current-theme-id;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                    }
                    Text {
                        text: Strings.language-label + " " + AppState.current-language;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                    }
                    Text {
                        text: Strings.density-label + " " + AppState.current-density;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                    }
                }
            }
        }

        if AppState.mode == 1: Rectangle {
            width: 100%;
            height: 100%;
            vertical-stretch: 1;
            horizontal-stretch: 1;

            WorkspaceView {
                width: 100%;
                height: 100%;
                workspace: AppState.workspace;
            workspace-clicked(id) => { root.workspace-clicked(id); }
            workspace-create-clicked => { root.workspace-create-clicked(); }
            workspace-orb-dismiss => { root.workspace-orb-dismiss(); }
            workspace-orb-toggle => { root.workspace-orb-toggle(); }
            widget-close-clicked(id) => { root.widget-close-clicked(id); }
            widget-settings-clicked(id) => { root.widget-settings-clicked(id); }
            widget-settings-field-changed(id, key, value) => {
                root.widget-settings-field-changed(id, key, value);
            }
            widget-settings-dismiss(id) => { root.widget-settings-dismiss(id); }
            widget-close-confirm-save(id) => { root.widget-close-confirm-save(id); }
            widget-close-confirm-discard(id) => { root.widget-close-confirm-discard(id); }
            widget-close-confirm-cancel(id) => { root.widget-close-confirm-cancel(id); }
