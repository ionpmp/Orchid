import { SettingsSectionEntry, SettingsFieldRow } from "workspace/defs.slint";

export global SettingsGlobal {
    in property <bool> visible;
    in property <string> panel-title;
    in property <string> hint-text;
    in property <string> config-path;
    in property <string> current-section-id;
    in property <int> selected-section-index;
    in property <[SettingsSectionEntry]> sections;
    in property <[SettingsFieldRow]> fields;
}
