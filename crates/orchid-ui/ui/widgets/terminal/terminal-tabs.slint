import { Theme } from "../../theme_global.slint";
import { Strings } from "../../strings_global.slint";
import { TerminalTabModel } from "../../workspace/defs.slint";

export component TerminalTabs inherits Rectangle {
    in property <[TerminalTabModel]> tabs;
    in property <int> active-tab;

    callback tab-clicked(int);
    callback tab-closed(int);
    callback tab-new();
    callback split-horizontal();
    callback split-vertical();

    height: 29px;
    background: Theme.surface-raised;

    HorizontalLayout {
        padding: 2px;
        spacing: 2px;

        for tab[i] in tabs : Rectangle {
            width: 140px;
            height: 25px;
            background: i == active-tab ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            tab-ta := TouchArea {
                clicked => { root.tab-clicked(i); }
            }

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;

                Text {
                    text: tab.title;
                    color: i == active-tab ? Theme.text-primary : Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                    overflow: elide;
                }

                Rectangle {
                    width: 18px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: close-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: 9px;

                    close-ta := TouchArea {
                        clicked => { root.tab-closed(i); }
                    }
                    if close-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: close-hint.preferred-width + 12px;
                        height: close-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        close-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.terminal-tooltip-tab-close;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    Text {
                        text: "×";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            width: 28px;
            height: 25px;
            background: split-h-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            split-h-ta := TouchArea {
                clicked => { root.split-horizontal(); }
            }

            if split-h-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: hint-h.preferred-width + 12px;
                height: hint-h.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;

                hint-h := Text {
                    x: 6px;
                    y: 3px;
                    text: Strings.terminal-tooltip-split-h;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            Text {
                text: "▥";
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            width: 28px;
            height: 25px;
            background: split-v-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            split-v-ta := TouchArea {
                clicked => { root.split-vertical(); }
            }

            if split-v-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: hint-v.preferred-width + 12px;
                height: hint-v.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;

                hint-v := Text {
                    x: 6px;
                    y: 3px;
                    text: Strings.terminal-tooltip-split-v;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            Text {
                text: "▤";
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            width: 28px;
            height: 25px;
            background: new-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            new-ta := TouchArea {
                clicked => { root.tab-new(); }
            }

            if new-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: hint-n.preferred-width + 12px;
                height: hint-n.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;

                hint-n := Text {
                    x: 6px;
                    y: 3px;
                    text: Strings.terminal-tooltip-tab-new;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            Text {
                text: "+";
                color: Theme.text-secondary;
                font-size: Theme.font-size-md;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
