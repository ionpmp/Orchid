import { Theme } from "../../theme_global.slint";
import { TerminalPaneModel, TerminalDividerModel } from "../../workspace/defs.slint";
import { TerminalView } from "../../workspace/terminal-view.slint";

export component TerminalSplitView inherits Rectangle {
    in property <[TerminalPaneModel]> panes;
    in property <[TerminalDividerModel]> dividers;
    in property <length> cell-width;
    in property <length> cell-height;

    callback pane-clicked(string);
    callback pane-closed(string);
    callback key-pressed(string, bool, bool, bool);
    callback shortcut(string);
    callback split-drag-moved(string, string, float, float);

    for pane[i] in panes : Rectangle {
        x: parent.width * pane.left;
        y: parent.height * pane.top;
        width: parent.width * (pane.right - pane.left);
        height: parent.height * (pane.bottom - pane.top);
        clip: true;
        background: Theme.surface-base;
        border-width: pane.is-focused ? 1px : 0px;
        border-color: Theme.accent-brand;

        TerminalView {
            width: parent.width;
            height: parent.height;
            input-enabled: pane.is-focused;
            cols: pane.cols;
            rows: pane.rows;
            cells: pane.cells;
            pixels: pane.pixels;
            cursor-col: pane.cursor-col;
            cursor-row: pane.cursor-row;
            cursor-visible: pane.cursor-visible;
            cell-width: root.cell-width;
            cell-height: root.cell-height;
            key-pressed(text, ctrl, shift, alt) => { root.key-pressed(text, ctrl, shift, alt); }
            shortcut(action) => { root.shortcut(action); }
        }

        if !pane.is-focused : TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.pane-clicked(pane.session-id); }
        }

        if pane.show-close : Rectangle {
            x: parent.width - 20px;
            y: 2px;
            width: 18px;
            height: 18px;
            background: close-ta.has-hover ? Theme.surface-raised : transparent;
            border-radius: 9px;

            close-ta := TouchArea {
                clicked => { root.pane-closed(pane.session-id); }
            }

            Text {
                text: "×";
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    for div in dividers : Rectangle {
        x: parent.width * div.left;
        y: parent.height * div.top;
        width: div.horizontal ? max(parent.width * (div.right - div.left), 6px) : parent.width * (div.right - div.left);
        height: !div.horizontal ? max(parent.height * (div.bottom - div.top), 6px) : parent.height * (div.bottom - div.top);
        background: div-ta.has-hover || div-ta.pressed ? Theme.accent-brand : Theme.border-default;

        div-ta := TouchArea {
            moved => {
                if (self.pressed) {
                    let fx = (parent.x + self.mouse-x) / root.width;
                    let fy = (parent.y + self.mouse-y) / root.height;
                    root.split-drag-moved(div.first-session-id, div.second-session-id, fx, fy);
                }
            }
        }
    }
}
