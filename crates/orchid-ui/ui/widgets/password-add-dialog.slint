import { Theme } from "../theme_global.slint";
import { PasswordAddDialogState } from "../workspace/defs.slint";

export component PasswordAddDialog inherits Rectangle {
    in property <PasswordAddDialogState> state;
    callback commit(string, string, string, string);
    callback cancel();
    callback generate-password();

    property <string> title-value: "";
    property <string> username-value: "";
    property <string> password-value: "";
    property <string> url-value: "";
    property <int> gen-seq: state.gen-seq;
    property <string> gen-password: state.gen-password;

    changed gen-seq => {
        root.password-value = root.gen-password;
    }

    background: #00000080;

    backdrop-ta := TouchArea {
        clicked => { root.cancel(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 400px;
        height: lay.preferred-height + 16px;
        background: Theme.surface-raised;
        border-radius: Theme.radius-md;
        drop-shadow-blur: Theme.reduce-motion ? 0px : 16px;
        drop-shadow-color: #00000080;

        lay := VerticalLayout {
            padding: 16px;
            spacing: 10px;

            Text {
                text: state.title;
                color: Theme.text-primary;
                font-size: Theme.font-size-lg;
                font-weight: Theme.weight-semibold;
            }

            VerticalLayout {
                spacing: 4px;
                Text {
                    text: state.title-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                }
                Rectangle {
                    height: 32px;
                    background: Theme.surface-base;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: title-fs.has-focus ? Theme.accent-brand : Theme.border-default;
                    title-fs := FocusScope {
                        width: parent.width;
                        height: parent.height;
                        init => { if (state.request-autofocus) { self.focus(); } }
                        TouchArea { clicked => { title-fs.focus(); } }
                        TextInput {
                            text: root.title-value;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-md;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            single-line: true;
                            edited => { root.title-value = self.text; }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text {
                    text: state.username-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                }
                Rectangle {
                    height: 32px;
                    background: Theme.surface-base;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: user-fs.has-focus ? Theme.accent-brand : Theme.border-default;
                    user-fs := FocusScope {
                        width: parent.width;
                        height: parent.height;
                        TouchArea { clicked => { user-fs.focus(); } }
                        TextInput {
                            text: root.username-value;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-md;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            single-line: true;
                            edited => { root.username-value = self.text; }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text {
                    text: state.password-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                }
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        background: Theme.surface-base;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: pw-fs.has-focus ? Theme.accent-brand : Theme.border-default;
                        pw-fs := FocusScope {
                            width: parent.width;
                            height: parent.height;
                            TouchArea { clicked => { pw-fs.focus(); } }
                            TextInput {
                                text: root.password-value;
                                color: Theme.text-primary;
                                font-size: Theme.font-size-md;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                single-line: true;
                                input-type: password;
                                edited => { root.password-value = self.text; }
                            }
                        }
                    }
                    Rectangle {
                        width: 88px;
                        height: 32px;
                        background: gen-ta.has-hover ? Theme.accent-brand : Theme.surface-base;
                        border-radius: Theme.radius-md;
                        gen-ta := TouchArea { clicked => { root.generate-password(); } }
                        Text {
                            text: state.generate-label;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text {
                    text: state.url-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                }
                Rectangle {
                    height: 32px;
                    background: Theme.surface-base;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: url-fs.has-focus ? Theme.accent-brand : Theme.border-default;
                    url-fs := FocusScope {
                        width: parent.width;
                        height: parent.height;
                        TouchArea { clicked => { url-fs.focus(); } }
                        TextInput {
                            text: root.url-value;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-md;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            single-line: true;
                            edited => { root.url-value = self.text; }
                        }
                    }
                }
            }

            if state.error != "" : Text {
                text: state.error;
                color: #ef4444;
                font-size: Theme.font-size-sm;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: end;

                Rectangle {
                    width: 96px;
                    height: 32px;
                    background: cancel-ta.has-hover ? Theme.surface-base : transparent;
                    border-radius: Theme.radius-md;
                    cancel-ta := TouchArea { clicked => { root.cancel(); } }
                    Text {
                        text: state.cancel-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 96px;
                    height: 32px;
                    background: submit-ta.has-hover ? Theme.accent-brand : Theme.surface-base;
                    border-radius: Theme.radius-md;
                    submit-ta := TouchArea {
                        clicked => {
                            root.commit(
                                root.title-value,
                                root.username-value,
                                root.password-value,
                                root.url-value,
                            );
                        }
                    }
                    Text {
                        text: state.submit-label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
