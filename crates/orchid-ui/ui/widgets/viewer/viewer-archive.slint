import { Theme } from "../../theme_global.slint";
import { ViewerArchiveModel } from "../../workspace/defs.slint";

export component ViewerArchiveView inherits Rectangle {
    in property <ViewerArchiveModel> model;

    callback navigate-into(string);
    callback navigate-up();
    callback select(string);
    callback extract-selected();
    callback extract-all();

    background: transparent;

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 36px;
            background: Theme.surface-base;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;

                Text {
                    text: model.header-label;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }

                Text {
                    text: " │ ";
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: 100%;

                    path-ta := TouchArea { }
                    if path-ta.has-hover && model.path-label != "" : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: path-hint.preferred-width + 12px;
                        height: path-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        path-hint := Text {
                            x: 6px; y: 3px;
                            text: model.path-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    Text {
                        text: model.path-label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                        wrap: no-wrap;
                        overflow: elide;
                    }
                }

                Rectangle {
                    height: 28px;
                    background: extract-all-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                    border-radius: Theme.radius-md;

                    extract-all-ta := TouchArea {
                        clicked => { root.extract-all(); }
                    }
                    if extract-all-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: extract-all-hint.preferred-width + 12px;
                        height: extract-all-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        extract-all-hint := Text {
                            x: 6px; y: 3px;
                            text: model.extract-all-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        Text {
                            text: model.extract-all-label;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    height: 28px;
                    background:
                        !model.has-file-selected ? Theme.surface-base :
                        (extract-sel-ta.has-hover ? Theme.accent-brand : Theme.surface-raised);
                    border-radius: Theme.radius-md;

                    // Keep TouchArea enabled so disabled state can still show a hover hint.
                    extract-sel-ta := TouchArea {
                        clicked => {
                            if model.has-file-selected {
                                root.extract-selected();
                            }
                        }
                    }
                    if extract-sel-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: extract-sel-hint.preferred-width + 12px;
                        height: extract-sel-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        extract-sel-hint := Text {
                            x: 6px; y: 3px;
                            text: model.has-file-selected
                                ? model.extract-selected-label
                                : model.nothing-selected-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        Text {
                            text: model.extract-selected-label;
                            color: model.has-file-selected ? Theme.text-primary : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        if model.info-text != "" : Rectangle {
            height: 24px;
            background: Theme.surface-raised;

            Text {
                x: 8px;
                width: parent.width - 16px;
                text: model.info-text;
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
                wrap: no-wrap;
                overflow: elide;
            }
        }

        HorizontalLayout {
            spacing: 0;
            vertical-stretch: 1;

            Rectangle {
                width: parent.width * 0.55;
                background: Theme.surface-base;

                Flickable {
                    width: parent.width;
                    height: parent.height;
                    viewport-width: self.width;
                    viewport-height: list-stack.preferred-height;

                    list-stack := VerticalLayout {
                        spacing: 0;

                        for entry[i] in model.entries : Rectangle {
                            height: 28px;
                            background: entry.path-in-archive == model.selected-path
                                ? Theme.accent-brand
                                : (entry-ta.has-hover ? Theme.surface-raised : transparent);

                            entry-ta := TouchArea {
                                clicked => {
                                    if (entry.is-up) {
                                        root.navigate-up();
                                    } else if (entry.is-dir) {
                                        root.navigate-into(entry.path-in-archive);
                                    } else {
                                        root.select(entry.path-in-archive);
                                    }
                                }
                            }
                            if entry-ta.has-hover : Rectangle {
                                x: 8px;
                                y: parent.height + 2px;
                                width: entry-hint.preferred-width + 12px;
                                height: entry-hint.preferred-height + 6px;
                                background: Theme.surface-raised;
                                border-radius: Theme.radius-md;
                                border-width: 1px;
                                border-color: Theme.border-default;
                                z: 100;
                                entry-hint := Text {
                                    x: 6px; y: 3px;
                                    text: entry.is-up ? entry.name
                                        : entry.path-in-archive != "" ? entry.path-in-archive
                                        : entry.name;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-sm;
                                }
                            }

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 6px;

                                Text {
                                    // ASCII/BMP — color emoji missing in Slint's default Windows font.
                                    text: entry.is-up ? "^" : (entry.is-dir ? "D" : "F");
                                    color: Theme.accent-brand;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: entry.is-up ? ".." : entry.name;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    wrap: no-wrap;
                                    overflow: elide;
                                }

                                if !entry.is-up && !entry.is-dir : Text {
                                    text: entry.size-text;
                                    color: Theme.text-tertiary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                }

                                if !entry.is-up : Text {
                                    text: entry.modified-text;
                                    color: Theme.text-tertiary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.border-default;
            }

            Rectangle {
                horizontal-stretch: 1;
                background: Theme.surface-base;

                if model.preview-kind == 0 : VerticalLayout {
                    alignment: center;
                    Text {
                        text: model.preview-text;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                if model.preview-kind == 1 : Flickable {
                    width: parent.width;
                    height: parent.height;
                    viewport-width: preview-text-element.preferred-width;
                    viewport-height: preview-text-element.preferred-height;

                    preview-text-element := Text {
                        text: model.preview-text;
                        color: Theme.text-primary;
                        font-family: Theme.font-family-mono;
                        font-size: Theme.font-size-sm;
                        wrap: no-wrap;
                    }
                }

                if model.preview-kind == 2 : VerticalLayout {
                    alignment: center;
                    spacing: 8px;
                    Text {
                        text: model.preview-binary-size;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-md;
                        font-weight: Theme.weight-semibold;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
