import { Theme } from "../../theme_global.slint";
import { Strings } from "../../strings_global.slint";
import { ViewerTextModel } from "../../workspace/defs.slint";

export component ViewerTextView inherits Rectangle {
    in property <ViewerTextModel> model;

    callback toggle-edit();
    callback save();
    callback text-edited(string);
    // Kept for API compatibility; selectable TextInput scrolls locally.
    callback text-scroll(int);

    background: transparent;

    // Local draft while editing; re-synced when entering edit mode or when the
    // model path / read-only flag changes from the backend snapshot.
    property <string> draft-text: model.plain-text;
    property <bool> was-read-only: true;
    property <bool> locally-dirty: false;

    changed model => {
        if model.read-only {
            root.draft-text = model.plain-text;
            root.was-read-only = true;
            root.locally-dirty = false;
        } else if root.was-read-only {
            root.draft-text = model.plain-text;
            root.was-read-only = false;
            root.locally-dirty = model.dirty;
        } else if root.draft-text == model.plain-text {
            root.locally-dirty = model.dirty;
        } else {
            root.locally-dirty = true;
        }
    }

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 36px;
            background: Theme.surface-base;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                alignment: start;

                Rectangle {
                    width: max(72px, mode-label.preferred-width + 16px);
                    height: 28px;
                    background: !model.read-only ? Theme.surface-raised
                        : mode-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    mode-ta := TouchArea { clicked => { root.toggle-edit(); } }
                    if mode-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: mode-hint.preferred-width + 12px;
                        height: mode-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        mode-hint := Text {
                            x: 6px; y: 3px;
                            text: model.mode-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    mode-label := Text {
                        text: model.mode-label;
                        color: model.read-only ? Theme.text-secondary : Theme.accent-brand;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if !model.read-only : Rectangle {
                    width: max(56px, save-label.preferred-width + 16px);
                    height: 28px;
                    background: (model.dirty || root.locally-dirty) ? Theme.surface-raised
                        : save-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    save-ta := TouchArea { clicked => { root.save(); } }
                    if save-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: save-hint.preferred-width + 12px;
                        height: save-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        save-hint := Text {
                            x: 6px; y: 3px;
                            text: model.save-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    save-label := Text {
                        text: model.save-label;
                        color: (model.dirty || root.locally-dirty)
                            ? Theme.accent-brand : Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                if model.dirty || root.locally-dirty : Rectangle {
                    width: 18px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;

                    dirty-ta := TouchArea { }
                    if dirty-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: dirty-hint.preferred-width + 12px;
                        height: dirty-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        dirty-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.viewer-text-dirty-indicator;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    Text {
                        text: "●";
                        color: #eab308;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            background: Theme.surface-base;
            vertical-stretch: 1;
            clip: true;

            // Read-only uses a selectable TextInput so OS copy (Ctrl+C) works.
            // Edit mode keeps the same control without read-only.
            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: max(self.height, edit-pad.preferred-height);

                edit-pad := HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 4px;
                    padding-bottom: 4px;

                    edit-input := TextInput {
                        width: parent.width - 16px;
                        text: root.draft-text;
                        single-line: false;
                        wrap: no-wrap;
                        read-only: model.read-only;
                        color: Theme.text-primary;
                        font-family: Theme.font-family-mono;
                        font-size: Theme.font-size-sm;
                        key-pressed(event) => {
                            if (event.modifiers.control
                                && !event.modifiers.shift
                                && !event.modifiers.alt
                                && (event.text == "s" || event.text == "S"))
                            {
                                if (!model.read-only) {
                                    root.save();
                                    return accept;
                                }
                            }
                            return reject;
                        }
                        edited => {
                            if (model.read-only) {
                                return;
                            }
                            root.draft-text = self.text;
                            root.locally-dirty = true;
                            root.text-edited(self.text);
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 24px;
            background: Theme.surface-raised;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 12px;

                Text {
                    text: model.encoding;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }
                Text {
                    text: model.line-ending;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }
                Text {
                    text: model.language;
                    color: Theme.accent-brand;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }
                Text {
                    text: model.lines-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                if model.dirty || root.locally-dirty : Text {
                    text: "●";
                    color: #eab308;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }
            }
        }
    }
}
