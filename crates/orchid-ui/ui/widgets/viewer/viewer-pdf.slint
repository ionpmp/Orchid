import { Theme } from "../../theme_global.slint";
import { Strings } from "../../strings_global.slint";
import { ViewerPdfModel } from "../../workspace/defs.slint";

export component ViewerPdfView inherits Rectangle {
    in property <ViewerPdfModel> model;

    callback prev-page();
    callback next-page();
    callback fit-width();
    callback fit-page();
    callback zoom-in();
    callback zoom-out();
    callback go-to-page(int);

    background: transparent;

    property <string> page-draft: "" + model.current-page;
    property <bool> page-editing: false;

    changed model => {
        if !root.page-editing {
            root.page-draft = "" + model.current-page;
        }
    }

    if !model.available : VerticalLayout {
        alignment: center;
        padding: 16px;
        spacing: 8px;
        // ASCII/BMP glyph — color emoji missing in Slint's default font on Windows.
        Text { text: "P"; color: Theme.text-tertiary; font-size: 32px; horizontal-alignment: center; }
        Text { text: model.unavailable-reason; color: Theme.text-secondary; font-size: Theme.font-size-md; horizontal-alignment: center; wrap: word-wrap; }
    }

    if model.available : VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 36px;
            background: Theme.surface-base;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                alignment: start;

                Rectangle {
                    width: 28px; height: 28px;
                    background: prev-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    prev-ta := TouchArea { clicked => { root.prev-page(); } }
                    if prev-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: prev-hint.preferred-width + 12px;
                        height: prev-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        prev-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.viewer-pdf-prev-page;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "◀"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    width: 44px;
                    height: 28px;
                    y: (parent.height - self.height) / 2;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    clip: true;

                    page-input := TextInput {
                        x: 4px;
                        width: parent.width - 8px;
                        height: parent.height;
                        text: root.page-draft;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        single-line: true;
                        edited => {
                            root.page-editing = true;
                            root.page-draft = self.text;
                        }
                        accepted => {
                            root.commit-page-jump();
                        }
                    }
                }

                Rectangle {
                    height: 28px;
                    y: (parent.height - self.height) / 2;
                    width: max(28px, page-total.preferred-width + 8px);

                    page-total-ta := TouchArea { }
                    if page-total-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: page-of-hint.preferred-width + 12px;
                        height: page-of-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        page-of-hint := Text {
                            x: 6px; y: 3px;
                            text: model.page-of-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    page-total := Text {
                        text: "/ " + model.page-count;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 40px; height: 28px;
                    background: go-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    go-ta := TouchArea { clicked => { root.commit-page-jump(); } }
                    Text {
                        text: model.go-label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 28px; height: 28px;
                    background: next-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    next-ta := TouchArea { clicked => { root.next-page(); } }
                    if next-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: next-hint.preferred-width + 12px;
                        height: next-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        next-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.viewer-pdf-next-page;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "▶"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle { width: 8px; }

                Rectangle {
                    min-width: 72px; height: 28px;
                    background: fw-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    fw-ta := TouchArea { clicked => { root.fit-width(); } }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        Text {
                            text: model.fit-width-label;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    min-width: 72px; height: 28px;
                    background: fp-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    fp-ta := TouchArea { clicked => { root.fit-page(); } }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        Text {
                            text: model.fit-page-label;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle { width: 8px; }

                Rectangle {
                    width: 28px; height: 28px;
                    background: zi-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    zi-ta := TouchArea { clicked => { root.zoom-in(); } }
                    if zi-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: zi-hint.preferred-width + 12px;
                        height: zi-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        zi-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.viewer-image-zoom-in;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "+"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    width: 28px; height: 28px;
                    background: zo-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    zo-ta := TouchArea { clicked => { root.zoom-out(); } }
                    if zo-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: zo-hint.preferred-width + 12px;
                        height: zo-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        zo-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.viewer-image-zoom-out;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "−"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        Rectangle {
            background: #80808020;
            vertical-stretch: 1;
            clip: true;

            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-width: model.page-width-px * 1px;
                viewport-height: model.page-height-px * 1px;

                Image {
                    source: model.page-image;
                    width: model.page-width-px * 1px;
                    height: model.page-height-px * 1px;
                    image-fit: fill;
                }
            }
        }

        if model.info-text != "" : Rectangle {
            height: 24px;
            background: Theme.surface-base;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                Text { text: model.info-text; color: Theme.text-tertiary; font-size: Theme.font-size-sm; vertical-alignment: center; }
            }
        }
    }

    function commit-page-jump() {
        root.page-editing = false;
        // Digits-only parse: ignore non-numeric draft and clamp later in Rust.
        if root.page-draft == "" || !root.page-draft.is-float() {
            root.page-draft = "" + model.current-page;
            return;
        }
        root.go-to-page(Math.round(root.page-draft.to-float()));
    }
}
