import { Theme } from "../../theme_global.slint";
import { Strings } from "../../strings_global.slint";
import { ViewerImageModel } from "../../workspace/defs.slint";

export component ViewerImageView inherits Rectangle {
    in property <ViewerImageModel> model;

    callback zoom-in();
    callback zoom-out();
    callback fit();
    callback actual-size();
    callback rotate-cw();
    callback rotate-ccw();
    callback flip-h();
    callback flip-v();
    callback pan(length, length);

    background: transparent;

    property <length> last-mx: 0px;
    property <length> last-my: 0px;
    property <length> pan-step: 40px;

    img-keys := FocusScope {
        width: 100%;
        height: 100%;
        init => { self.focus(); }

        key-pressed(event) => {
            if (event.text == "+" || event.text == "=") {
                root.zoom-in();
                return accept;
            }
            if (event.text == "-" || event.text == "−") {
                root.zoom-out();
                return accept;
            }
            if (event.text == "f" || event.text == "F") {
                root.fit();
                return accept;
            }
            if (event.text == "1") {
                root.actual-size();
                return accept;
            }
            if (event.text == "r" || event.text == "R") {
                if (event.modifiers.shift) {
                    root.rotate-ccw();
                } else {
                    root.rotate-cw();
                }
                return accept;
            }
            if (event.text == "h" || event.text == "H") {
                root.flip-h();
                return accept;
            }
            if (event.text == "v" || event.text == "V") {
                root.flip-v();
                return accept;
            }
            if (event.text == Key.LeftArrow) {
                root.pan(root.pan-step, 0px);
                return accept;
            }
            if (event.text == Key.RightArrow) {
                root.pan(-root.pan-step, 0px);
                return accept;
            }
            if (event.text == Key.UpArrow) {
                root.pan(0px, root.pan-step);
                return accept;
            }
            if (event.text == Key.DownArrow) {
                root.pan(0px, -root.pan-step);
                return accept;
            }
            return reject;
        }

    VerticalLayout {
        spacing: 0;

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 6px;
                alignment: start;

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: zoom-out-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    zoom-out-ta := TouchArea {
                        clicked => {
                            root.zoom-out();
                            img-keys.focus();
                        }
                    }
                    if zoom-out-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: zoom-out-hint.preferred-width + 12px;
                        height: zoom-out-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        zoom-out-hint := Text {
                            x: 6px;
                            y: 3px;
                            text: Strings.viewer-image-zoom-out;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "−"; color: Theme.text-primary; font-size: Theme.font-size-lg; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    width: 56px;
                    height: 28px;
                    y: (parent.height - self.height) / 2;
                    Text {
                        text: floor(model.zoom * 100) + "%";
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: zoom-in-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    zoom-in-ta := TouchArea {
                        clicked => {
                            root.zoom-in();
                            img-keys.focus();
                        }
                    }
                    if zoom-in-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: zoom-in-hint.preferred-width + 12px;
                        height: zoom-in-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        zoom-in-hint := Text {
                            x: 6px;
                            y: 3px;
                            text: Strings.viewer-image-zoom-in;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "+"; color: Theme.text-primary; font-size: Theme.font-size-lg; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle { width: 8px; }

                Rectangle {
                    min-width: 40px;
                    height: 28px;
                    background: model.fit-mode ? Theme.surface-raised
                        : fit-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    fit-ta := TouchArea {
                        clicked => {
                            root.fit();
                            img-keys.focus();
                        }
                    }
                    if fit-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: fit-hint.preferred-width + 12px;
                        height: fit-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        fit-hint := Text {
                            x: 6px; y: 3px;
                            text: model.fit-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        Text {
                            text: model.fit-label;
                            color: model.fit-mode ? Theme.accent-brand : Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    min-width: 40px;
                    height: 28px;
                    background: !model.fit-mode ? Theme.surface-raised
                        : actual-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    actual-ta := TouchArea {
                        clicked => {
                            root.actual-size();
                            img-keys.focus();
                        }
                    }
                    if actual-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: actual-hint.preferred-width + 12px;
                        height: actual-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        actual-hint := Text {
                            x: 6px; y: 3px;
                            text: model.actual-size-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        Text {
                            text: model.actual-size-label;
                            color: !model.fit-mode ? Theme.accent-brand : Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle { width: 8px; }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: rcw-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    rcw-ta := TouchArea {
                        clicked => {
                            root.rotate-cw();
                            img-keys.focus();
                        }
                    }
                    if rcw-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: rcw-hint.preferred-width + 12px;
                        height: rcw-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        rcw-hint := Text {
                            x: 6px;
                            y: 3px;
                            text: Strings.viewer-image-rotate-cw;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "↻"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: rccw-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    rccw-ta := TouchArea {
                        clicked => {
                            root.rotate-ccw();
                            img-keys.focus();
                        }
                    }
                    if rccw-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: rccw-hint.preferred-width + 12px;
                        height: rccw-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        rccw-hint := Text {
                            x: 6px;
                            y: 3px;
                            text: Strings.viewer-image-rotate-ccw;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text { text: "↺"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle { width: 8px; }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: model.flipped-h ? Theme.surface-raised
                        : flip-h-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    flip-h-ta := TouchArea {
                        clicked => {
                            root.flip-h();
                            img-keys.focus();
                        }
                    }
                    if flip-h-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: flip-h-hint.preferred-width + 12px;
                        height: flip-h-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        flip-h-hint := Text {
                            x: 6px;
                            y: 3px;
                            text: Strings.viewer-image-flip-h;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text {
                        text: "⇄";
                        color: model.flipped-h ? Theme.accent-brand : Theme.text-primary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: model.flipped-v ? Theme.surface-raised
                        : flip-v-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    y: (parent.height - self.height) / 2;
                    flip-v-ta := TouchArea {
                        clicked => {
                            root.flip-v();
                            img-keys.focus();
                        }
                    }
                    if flip-v-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: flip-v-hint.preferred-width + 12px;
                        height: flip-v-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        flip-v-hint := Text {
                            x: 6px;
                            y: 3px;
                            text: Strings.viewer-image-flip-v;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }
                    Text {
                        text: "⇅";
                        color: model.flipped-v ? Theme.accent-brand : Theme.text-primary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            background: Theme.surface-base;
            vertical-stretch: 1;
            clip: true;

            Image {
                source: model.rgba-image;
                x: (parent.width - self.width) / 2 + model.pan-x;
                y: (parent.height - self.height) / 2 + model.pan-y;
                width: model.width-px * 1px * model.zoom;
                height: model.height-px * 1px * model.zoom;
                image-fit: fill;
                transform-rotation: model.rotation-deg * 1deg;
                transform-scale-x: model.flipped-h ? -1 : 1;
                transform-scale-y: model.flipped-v ? -1 : 1;
            }

            pan-area := TouchArea {
                width: parent.width;
                height: parent.height;
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        root.last-mx = self.mouse-x;
                        root.last-my = self.mouse-y;
                        img-keys.focus();
                    }
                }
                moved => {
                    if (self.pressed) {
                        root.pan(self.mouse-x - root.last-mx, self.mouse-y - root.last-my);
                        root.last-mx = self.mouse-x;
                        root.last-my = self.mouse-y;
                    }
                }
            }
        }

        if model.info-text != "" : Rectangle {
            height: 24px;
            background: Theme.surface-base;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                Text {
                    text: model.info-text;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }
    } // VerticalLayout
    } // FocusScope
}
