import { Theme } from "../theme_global.slint";
import { MoonModel } from "../workspace/defs.slint";

export component MoonView inherits Rectangle {
    in property <MoonModel> model;

    pure function moon-icon-glyph(name: string) -> string {
        return
            name == "moon-new" ? "🌑" :
            name == "moon-waxing-crescent" ? "🌒" :
            name == "moon-first-quarter" ? "🌓" :
            name == "moon-waxing-gibbous" ? "🌔" :
            name == "moon-full" ? "🌕" :
            name == "moon-waning-gibbous" ? "🌖" :
            name == "moon-last-quarter" ? "🌗" :
            name == "moon-waning-crescent" ? "🌘" :
            "🌑";
    }

    background: transparent;

    VerticalLayout {
        padding: 16px;
        spacing: 12px;
        alignment: start;

        if model.phase-icon != "" : Text {
            text: moon-icon-glyph(model.phase-icon);
            color: Theme.text-primary;
            font-size: 64px;
            horizontal-alignment: center;
        }

        Text {
            text: model.phase-label;
            color: Theme.text-primary;
            font-size: Theme.font-size-lg;
            font-weight: Theme.weight-semibold;
            horizontal-alignment: center;
        }

        Text {
            text: model.illumination;
            color: Theme.accent-brand;
            font-size: Theme.font-size-md;
            horizontal-alignment: center;
        }

        Rectangle {
            height: 1px;
            background: Theme.border-default;
            horizontal-stretch: 1;
        }

        for entry[i] in model.values : HorizontalLayout {
            spacing: 8px;
            alignment: space-between;

            Text {
                text: entry.label;
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }

            Text {
                text: entry.value;
                color: Theme.text-primary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
                horizontal-alignment: right;
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
