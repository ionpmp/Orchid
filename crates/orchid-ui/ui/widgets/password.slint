import { Theme } from "../theme_global.slint";
import { Strings } from "../strings_global.slint";
import { PasswordModel } from "../workspace/defs.slint";
import { PasswordAddDialog } from "password-add-dialog.slint";

export component PasswordView inherits Rectangle {
    in property <PasswordModel> model;

    callback search-changed(string);
    callback entry-clicked(string);
    callback copy-password(string);
    callback copy-username(string);
    callback copy-totp(string);
    callback open-url(string);
    callback unlock-submit(string);
    callback unlock-biometric();
    callback lock-vault();
    callback add-entry-request();
    callback add-entry-commit(string, string, string, string);
    callback add-entry-cancel();

    property <string> unlock-passphrase: "";

    background: transparent;

    // Locked state
    if !model.is-unlocked : VerticalLayout {
        alignment: center;
        padding: 24px;
        spacing: 12px;
        max-width: 360px;

        Text {
            text: "🔒";
            color: Theme.text-tertiary;
            font-size: 48px;
            horizontal-alignment: center;
        }

        Text {
            text: model.lock-reason != "" ? model.lock-reason : Strings.password_locked;
            color: Theme.text-secondary;
            font-size: Theme.font-size-md;
            horizontal-alignment: center;
        }

        Text {
            text: Strings.password_unlock_label;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
            horizontal-alignment: center;
        }

        Rectangle {
            height: 36px;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: unlock-fs.has-focus ? Theme.accent-brand : Theme.border-default;

            unlock-fs := FocusScope {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;

                init => {
                    if (model.request-autofocus) {
                        self.focus();
                    }
                }

                TouchArea {
                    clicked => { unlock-fs.focus(); }
                }

                Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    background: transparent;

                    if unlock-input.text == "" : Text {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        text: Strings.password_unlock_placeholder;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-md;
                        vertical-alignment: center;
                    }

                    unlock-input := TextInput {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        text: root.unlock-passphrase;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        single-line: true;
                        input-type: password;
                        edited => {
                            root.unlock-passphrase = self.text;
                        }
                        accepted => {
                            root.unlock-submit(root.unlock-passphrase);
                            root.unlock-passphrase = "";
                        }
                    }
                }
            }
        }

        if model.unlock-error != "" : Text {
            text: model.unlock-error;
            color: #ef4444;
            font-size: Theme.font-size-sm;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 120px;
                height: 32px;
                background: unlock-btn-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                border-radius: Theme.radius-md;

                unlock-btn-ta := TouchArea {
                    clicked => {
                        root.unlock-submit(root.unlock-passphrase);
                        root.unlock-passphrase = "";
                    }
                }

                Text {
                    text: Strings.password_unlock_submit;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if model.biometric-available : Rectangle {
                height: 32px;
                background: bio-btn-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                border-radius: Theme.radius-md;

                bio-btn-ta := TouchArea {
                    clicked => { root.unlock-biometric(); }
                }

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    Text {
                        text: Strings.password_unlock_biometric;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // Unlocked state
    if model.is-unlocked : VerticalLayout {
        padding: 8px;
        spacing: 8px;

        // Search row + lock
        HorizontalLayout {
            spacing: 8px;

            Rectangle {
                horizontal-stretch: 1;
                height: 36px;
                background: Theme.surface-base;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: search-fs.has-focus ? Theme.accent-brand : Theme.border-default;

            search-fs := FocusScope {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;

                init => {
                    if (model.request-autofocus) {
                        self.focus();
                    }
                }

                TouchArea {
                    clicked => { search-fs.focus(); }
                }

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 8px;

                    Text {
                        text: "🔍";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-md;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 100%;
                        background: transparent;

                        if search-input.text == "" : Text {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height;
                            text: Strings.password_search_placeholder;
                            color: Theme.text-tertiary;
                            font-size: Theme.font-size-md;
                            vertical-alignment: center;
                        }

                        search-input := TextInput {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height;
                            text: model.search-query;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-md;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            single-line: true;
                            edited => {
                                root.search-changed(self.text);
                            }
                        }
                    }
                }
            }
            }

            Rectangle {
                width: 72px;
                height: 36px;
                background: add-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                border-radius: Theme.radius-md;

                add-ta := TouchArea {
                    clicked => { root.add-entry-request(); }
                }

                Text {
                    text: Strings.password_action_add;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                width: 72px;
                height: 36px;
                background: lock-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                border-radius: Theme.radius-md;

                lock-ta := TouchArea {
                    clicked => { root.lock-vault(); }
                }

                Text {
                    text: Strings.password_action_lock;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Two-column split
        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 1;

            // Left: entries list (40% width)
            Rectangle {
                width: parent.width * 0.4;
                background: Theme.surface-base;
                border-radius: Theme.radius-md;

                Flickable {
                    x: 0; y: 0;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: self.width;
                    viewport-height: list-layout.preferred-height;

                    list-layout := VerticalLayout {
                        spacing: 0px;

                        if model.entries.length == 0 : VerticalLayout {
                            padding: 24px;
                            Text {
                                text: Strings.password_no_entries;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                                horizontal-alignment: center;
                            }
                        }

                        for e[i] in model.entries : Rectangle {
                            height: 56px;
                            background:
                                (model.selected.has-selection && model.selected.id == e.id)
                                    ? Theme.accent-brand
                                    : (entry-ta.has-hover ? Theme.surface-raised : transparent);

                            entry-ta := TouchArea {
                                clicked => { root.entry-clicked(e.id); }
                            }

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 8px;

                                // Color label dot
                                if e.color-label != "" : Rectangle {
                                    width: 4px;
                                    height: 40px;
                                    y: (parent.height - self.height) / 2;
                                    background: e.color-label == "red" ? #ef4444
                                              : e.color-label == "orange" ? #f97316
                                              : e.color-label == "yellow" ? #eab308
                                              : e.color-label == "green" ? #22c55e
                                              : e.color-label == "blue" ? #3b82f6
                                              : e.color-label == "purple" ? #a855f7
                                              : Theme.accent-brand;
                                    border-radius: 2px;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 2px;

                                    Text {
                                        text: e.title;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-size-md;
                                        font-weight: Theme.weight-semibold;
                                        wrap: no-wrap;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: e.username;
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-size-sm;
                                        wrap: no-wrap;
                                        overflow: elide;
                                    }
                                }

                                if e.has-totp : Text {
                                    text: "🔑";
                                    color: Theme.accent-brand;
                                    font-size: Theme.font-size-md;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            // Right: detail pane
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.surface-base;
                border-radius: Theme.radius-md;

                if !model.selected.has-selection : VerticalLayout {
                    alignment: center;
                    Text {
                        text: Strings.password_select_entry;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                    }
                }

                if model.selected.has-selection : Flickable {
                    x: 0; y: 0;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: self.width;
                    viewport-height: detail-layout.preferred-height;

                    detail-layout := VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        // Title
                        Text {
                            text: model.selected.title;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-xl;
                            font-weight: Theme.weight-semibold;
                        }

                        // Username row
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: Strings.password_label_username;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: model.selected.username;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-size-md;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    wrap: no-wrap;
                                    overflow: elide;
                                }
                                Rectangle {
                                    width: 72px;
                                    height: 28px;
                                    background: copy-user-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                                    border-radius: Theme.radius-md;

                                    copy-user-ta := TouchArea {
                                        clicked => { root.copy-username(model.selected.id); }
                                    }

                                    Text {
                                        text: Strings.password_action_copy;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-size-sm;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // Password row
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: Strings.password_label_password;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "••••••••••";
                                    color: Theme.text-primary;
                                    font-size: Theme.font-size-md;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                Rectangle {
                                    width: 72px;
                                    height: 28px;
                                    background: copy-pw-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                                    border-radius: Theme.radius-md;

                                    copy-pw-ta := TouchArea {
                                        clicked => { root.copy-password(model.selected.id); }
                                    }

                                    Text {
                                        text: Strings.password_action_copy;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-size-sm;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // URL row
                        if model.selected.url != "" : VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: Strings.password_label_url;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: model.selected.url;
                                    color: Theme.accent-brand;
                                    font-size: Theme.font-size-md;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    wrap: no-wrap;
                                    overflow: elide;
                                }
                                Rectangle {
                                    width: 72px;
                                    height: 28px;
                                    background: open-url-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                                    border-radius: Theme.radius-md;

                                    open-url-ta := TouchArea {
                                        clicked => { root.open-url(model.selected.url); }
                                    }

                                    Text {
                                        text: Strings.password_action_open;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-size-sm;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // TOTP row
                        if model.selected.totp-code != "" : VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: Strings.password_label_totp;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: model.selected.totp-code;
                                    color: Theme.text-primary;
                                    font-family: Theme.font-family-mono;
                                    font-size: Theme.font-size-xl;
                                    font-weight: Theme.weight-semibold;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                // Countdown bar (0..30s)
                                Rectangle {
                                    width: 40px;
                                    height: 8px;
                                    background: Theme.surface-raised;
                                    border-radius: 4px;
                                    y: (parent.height - self.height) / 2;
                                    Rectangle {
                                        x: 0; y: 0;
                                        width: parent.width * (model.selected.totp-remaining / 30.0);
                                        height: parent.height;
                                        background:
                                            model.selected.totp-remaining <= 5 ? #ef4444 :
                                            model.selected.totp-remaining <= 10 ? #eab308 :
                                            Theme.accent-brand;
                                        border-radius: 4px;
                                    }
                                }

                                Rectangle {
                                    width: 72px;
                                    height: 28px;
                                    background: copy-totp-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                                    border-radius: Theme.radius-md;

                                    copy-totp-ta := TouchArea {
                                        clicked => { root.copy-totp(model.selected.id); }
                                    }

                                    Text {
                                        text: Strings.password_action_copy;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-size-sm;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // Notes
                        if model.selected.notes != "" : VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: Strings.password_label_notes;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                            }
                            Text {
                                text: model.selected.notes;
                                color: Theme.text-primary;
                                font-size: Theme.font-size-sm;
                                wrap: word-wrap;
                            }
                        }

                        // Tags
                        if model.selected.tags.length > 0 : HorizontalLayout {
                            spacing: 6px;
                            for tag[j] in model.selected.tags : Rectangle {
                                background: Theme.surface-raised;
                                border-radius: Theme.radius-md;
                                horizontal-stretch: 0;

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    padding-top: 4px;
                                    padding-bottom: 4px;
                                    Text {
                                        text: tag.label;
                                        color: Theme.accent-brand;
                                        font-size: Theme.font-size-sm;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Toast (copy feedback)
        if model.toast-visible : Rectangle {
            height: 32px;
            background: Theme.accent-brand;
            border-radius: Theme.radius-md;

            Text {
                text: model.toast-message;
                color: Theme.text-primary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    if model.add-dialog.visible : PasswordAddDialog {
        width: parent.width;
        height: parent.height;
        state: model.add-dialog;
        commit(title, username, password, url) => {
            root.add-entry-commit(title, username, password, url);
        }
        cancel => { root.add-entry-cancel(); }
    }
}

