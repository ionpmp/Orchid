import { Theme } from "../theme_global.slint";
import { CalculatorModel, CalcHistoryEntry } from "../workspace/defs.slint";

component CalcBtn inherits Rectangle {
    in property <string> label;
    in property <string> id;
    in property <string> tip;
    in property <int> kind: 0; // 0 digit, 1 fn, 2 op, 3 equals, 4 accent
    in property <bool> active: false;
    callback pressed(string);

    border-radius: Theme.radius-md;
    background: root.active ? Theme.accent-brand :
        kind == 3 ? Theme.accent-brand :
        kind == 2 ? Theme.surface-raised :
        kind == 4 ? Theme.surface-raised :
        Theme.surface-base;
    border-width: 1px;
    border-color: Theme.border-default;

    ta := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.pressed(root.id); }
    }

    Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: (root.active || kind == 3) ? Theme.surface-base :
            kind == 2 ? Theme.accent-brand :
            Theme.text-primary;
        font-size: Theme.font-size-md;
        font-weight: kind == 0 ? Theme.weight-semibold : Theme.weight-medium;
        font-family: Theme.font-family-sans;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if ta.has-hover && !root.active : Rectangle {
        width: 100%;
        height: 100%;
        border-radius: Theme.radius-md;
        background: #ffffff18;
    }

    if ta.has-hover && tip != "" : Rectangle {
        x: (parent.width - tip-box.preferred-width - 12px) / 2;
        y: -tip-box.preferred-height - 10px;
        width: tip-box.preferred-width + 12px;
        height: tip-box.preferred-height + 6px;
        background: Theme.surface-raised;
        border-radius: Theme.radius-md;
        border-width: 1px;
        border-color: Theme.border-default;
        z: 50;
        tip-box := Text {
            x: 6px; y: 3px;
            text: root.tip;
            color: Theme.text-secondary;
            font-size: Theme.font-size-sm;
        }
    }
}

export component CalculatorView inherits Rectangle {
    in property <CalculatorModel> model;

    callback button-pressed(string);
    callback history-clicked(int);
    callback key-input(string, bool, bool);

    background: transparent;

    keys := FocusScope {
        width: 100%;
        height: 100%;
        init => { self.focus(); }

        key-pressed(event) => {
            if (event.text == Key.Backspace) {
                root.button-pressed("bs");
                return accept;
            }
            if (event.text == Key.Delete) {
                root.button-pressed("ce");
                return accept;
            }
            if (event.text == Key.Escape) {
                root.button-pressed("c");
                return accept;
            }
            if (event.text == Key.Return) {
                root.button-pressed("eq");
                return accept;
            }
            root.key-input(event.text, event.modifiers.control, event.modifiers.shift);
            return accept;
        }

        HorizontalLayout {
            padding: 8px;
            spacing: 8px;

            // Main calculator column
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;

                // Mode + angle + memory
                HorizontalLayout {
                    spacing: 4px;
                    height: 28px;

                    Rectangle {
                        width: 72px; height: 28px;
                        background: model.mode == 0 ? Theme.surface-raised : transparent;
                        border-radius: Theme.radius-md;
                        TouchArea { clicked => { root.button-pressed("mode-std"); keys.focus(); } }
                        Text {
                            width: 100%; height: 100%;
                            text: model.mode-standard-label;
                            color: model.mode == 0 ? Theme.accent-brand : Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 80px; height: 28px;
                        background: model.mode == 1 ? Theme.surface-raised : transparent;
                        border-radius: Theme.radius-md;
                        TouchArea { clicked => { root.button-pressed("mode-sci"); keys.focus(); } }
                        Text {
                            width: 100%; height: 100%;
                            text: model.mode-scientific-label;
                            color: model.mode == 1 ? Theme.accent-brand : Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    if model.mode == 1 : Rectangle {
                        width: 52px; height: 28px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        TouchArea { clicked => { root.button-pressed("angle"); keys.focus(); } }
                        Text {
                            width: 100%; height: 100%;
                            text: model.angle-label;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }

                    if model.memory-set : Text {
                        text: "M";
                        color: Theme.accent-brand;
                        font-size: Theme.font-size-sm;
                        font-weight: Theme.weight-semibold;
                        vertical-alignment: center;
                    }
                }

                // Display
                Rectangle {
                    height: 72px;
                    background: Theme.surface-base;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;

                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 2px;

                        Text {
                            text: model.expression;
                            color: Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-family: Theme.font-family-mono;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                            height: 18px;
                            overflow: elide;
                        }
                        Text {
                            text: model.display-text;
                            color: model.has-error ? #ef4444 : Theme.text-primary;
                            font-size: Theme.font-size-2xl;
                            font-weight: Theme.weight-semibold;
                            font-family: Theme.font-family-mono;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                            vertical-stretch: 1;
                            overflow: elide;
                        }
                    }
                }

                // Memory row
                HorizontalLayout {
                    spacing: 4px;
                    height: 32px;
                    CalcBtn { label: "MC"; id: "mc"; tip: model.tip-mc; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "MR"; id: "mr"; tip: model.tip-mr; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "M+"; id: "mplus"; tip: model.tip-mplus; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "M-"; id: "mminus"; tip: model.tip-mminus; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "MS"; id: "ms"; tip: model.tip-ms; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }

                // Scientific pad
                if model.mode == 1 : VerticalLayout {
                    spacing: 4px;

                    HorizontalLayout {
                        spacing: 4px; height: 34px;
                        CalcBtn { label: "2nd"; id: "2nd"; tip: model.tip-2nd; kind: 4; active: model.second; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "π"; id: "pi"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "e"; id: "e"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "C"; id: "c"; tip: model.tip-c; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "⌫"; id: "bs"; tip: model.tip-bs; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    }
                    HorizontalLayout {
                        spacing: 4px; height: 34px;
                        CalcBtn {
                            label: model.second ? "sin⁻¹" : "sin";
                            id: "sin"; kind: 1;
                            pressed(id) => { root.button-pressed(id); keys.focus(); }
                        }
                        CalcBtn {
                            label: model.second ? "cos⁻¹" : "cos";
                            id: "cos"; kind: 1;
                            pressed(id) => { root.button-pressed(id); keys.focus(); }
                        }
                        CalcBtn {
                            label: model.second ? "tan⁻¹" : "tan";
                            id: "tan"; kind: 1;
                            pressed(id) => { root.button-pressed(id); keys.focus(); }
                        }
                        CalcBtn { label: "("; id: "("; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: ")"; id: ")"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    }
                    HorizontalLayout {
                        spacing: 4px; height: 34px;
                        CalcBtn { label: "xʸ"; id: "pow"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "ʸ√x"; id: "yroot"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "x³"; id: "cube"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "∛x"; id: "cbrt"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "n!"; id: "fact"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    }
                    HorizontalLayout {
                        spacing: 4px; height: 34px;
                        CalcBtn {
                            label: model.second ? "10ˣ" : "log";
                            id: "log"; kind: 1;
                            pressed(id) => { root.button-pressed(id); keys.focus(); }
                        }
                        CalcBtn {
                            label: model.second ? "eˣ" : "ln";
                            id: "ln"; kind: 1;
                            pressed(id) => { root.button-pressed(id); keys.focus(); }
                        }
                        CalcBtn { label: "|x|"; id: "abs"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "mod"; id: "mod"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "exp"; id: "exp"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    }
                    HorizontalLayout {
                        spacing: 4px; height: 34px;
                        CalcBtn { label: "sinh"; id: "sinh"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "cosh"; id: "cosh"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "tanh"; id: "tanh"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "1/x"; id: "inv"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                        CalcBtn { label: "x²"; id: "sqr"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    }
                }

                // Standard function row (always)
                if model.mode == 0 : HorizontalLayout {
                    spacing: 4px; height: 36px;
                    CalcBtn { label: "%"; id: "pct"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "CE"; id: "ce"; tip: model.tip-ce; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "C"; id: "c"; tip: model.tip-c; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "⌫"; id: "bs"; tip: model.tip-bs; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }

                if model.mode == 0 : HorizontalLayout {
                    spacing: 4px; height: 36px;
                    CalcBtn { label: "1/x"; id: "inv"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "x²"; id: "sqr"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "√"; id: "sqrt"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "÷"; id: "div"; kind: 2; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }

                // Shared keypad
                HorizontalLayout {
                    spacing: 4px; height: model.mode == 1 ? 34px : 36px;
                    if model.mode == 1 : CalcBtn { label: "√"; id: "sqrt"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    if model.mode == 1 : CalcBtn { label: "%"; id: "pct"; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    if model.mode == 1 : CalcBtn { label: "CE"; id: "ce"; tip: model.tip-ce; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    if model.mode == 1 : CalcBtn { label: "÷"; id: "div"; kind: 2; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    if model.mode == 0 : CalcBtn { label: "7"; id: "7"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    if model.mode == 0 : CalcBtn { label: "8"; id: "8"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    if model.mode == 0 : CalcBtn { label: "9"; id: "9"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    if model.mode == 0 : CalcBtn { label: "×"; id: "mul"; kind: 2; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }

                if model.mode == 1 : HorizontalLayout {
                    spacing: 4px; height: 34px;
                    CalcBtn { label: "7"; id: "7"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "8"; id: "8"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "9"; id: "9"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "×"; id: "mul"; kind: 2; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }

                HorizontalLayout {
                    spacing: 4px; height: model.mode == 1 ? 34px : 36px;
                    CalcBtn { label: "4"; id: "4"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "5"; id: "5"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "6"; id: "6"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "−"; id: "sub"; kind: 2; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }
                HorizontalLayout {
                    spacing: 4px; height: model.mode == 1 ? 34px : 36px;
                    CalcBtn { label: "1"; id: "1"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "2"; id: "2"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "3"; id: "3"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "+"; id: "add"; kind: 2; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }
                HorizontalLayout {
                    spacing: 4px; height: model.mode == 1 ? 34px : 36px;
                    CalcBtn { label: "±"; id: "neg"; tip: model.tip-neg; kind: 1; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "0"; id: "0"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "."; id: "dec"; kind: 0; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                    CalcBtn { label: "="; id: "eq"; tip: model.tip-eq; kind: 3; pressed(id) => { root.button-pressed(id); keys.focus(); } }
                }
            }

            // History panel
            if model.show-history : Rectangle {
                width: 140px;
                background: Theme.surface-base;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;

                VerticalLayout {
                    padding: 8px;
                    spacing: 4px;

                    HorizontalLayout {
                        Text {
                            text: model.history-title;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                            font-weight: Theme.weight-medium;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        if model.history.length > 0 : Rectangle {
                            width: 44px; height: 22px;
                            background: clear-ta.has-hover ? Theme.surface-raised : transparent;
                            border-radius: Theme.radius-md;
                            clear-ta := TouchArea { clicked => { root.button-pressed("hist-clear"); } }
                            Text {
                                width: 100%; height: 100%;
                                text: model.history-clear-label;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    if model.history.length == 0 : Text {
                        text: model.history-empty-label;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-stretch: 1;
                    }

                    if model.history.length > 0 : Flickable {
                        viewport-width: parent.width - 16px;
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 6px;
                            width: parent.width;

                            for h[i] in model.history : Rectangle {
                                height: 44px;
                                background: hta.has-hover ? Theme.surface-raised : transparent;
                                border-radius: Theme.radius-md;
                                hta := TouchArea { clicked => { root.history-clicked(i); keys.focus(); } }
                                VerticalLayout {
                                    padding: 4px;
                                    spacing: 2px;
                                    Text {
                                        text: h.expression;
                                        color: Theme.text-tertiary;
                                        font-size: Theme.font-size-sm;
                                        font-family: Theme.font-family-mono;
                                        horizontal-alignment: right;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: h.result;
                                        color: Theme.text-primary;
                                        font-size: Theme.font-size-md;
                                        font-family: Theme.font-family-mono;
                                        font-weight: Theme.weight-medium;
                                        horizontal-alignment: right;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
