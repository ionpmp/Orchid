import { Theme } from "../theme_global.slint";
import { WeatherModel } from "../workspace/defs.slint";

export component WeatherView inherits Rectangle {
    in property <WeatherModel> model;

    callback open-cities();
    callback close-cities();
    callback select-city(int);
    callback remove-city(int);
    callback search-cities(string);
    callback add-city(string, float, float, string);
    callback select-day(int);

    // ASCII/BMP glyphs — color emoji missing in Slint's default Windows font.
    pure function weather-icon-glyph(name: string) -> string {
        return
            name == "weather-clear" ? "*" :
            name == "weather-partly-cloudy" ? "+" :
            name == "weather-cloudy" ? "=" :
            name == "weather-overcast" ? "=" :
            name == "weather-fog" ? "~" :
            name == "weather-drizzle" ? "," :
            name == "weather-rain" ? "/" :
            name == "weather-snow" ? "*" :
            name == "weather-sleet" ? "%" :
            name == "weather-thunderstorm" ? "!" :
            name == "weather-hail" ? "%" :
            name == "weather-windy" ? "~" :
            name == "weather-unknown" ? "." :
            ".";
    }

    background: transparent;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;
            alignment: space-between;

            Rectangle {
                horizontal-stretch: 1;
                height: 24px;

                location-ta := TouchArea {
                    clicked => { root.open-cities(); }
                }

                HorizontalLayout {
                    spacing: 4px;
                    width: 100%;
                    height: 100%;

                    Text {
                        text: model.location;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        font-weight: Theme.weight-medium;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        wrap: no-wrap;
                        overflow: elide;
                    }

                    Text {
                        text: ">";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                width: 16px;
                height: 16px;
                y: (parent.height - self.height) / 2;

                status-ta := TouchArea { }
                if status-ta.has-hover : Rectangle {
                    x: parent.x + parent.width - status-hint.preferred-width - 12px;
                    y: parent.height + 2px;
                    width: status-hint.preferred-width + 12px;
                    height: status-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    status-hint := Text {
                        x: 6px; y: 3px;
                        text: model.status-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                Rectangle {
                    width: 8px;
                    height: 8px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    border-radius: 4px;
                    background:
                        model.status == 0 ? #22c55e :
                        model.status == 1 ? #eab308 :
                        model.status == 2 ? #6b7280 :
                        #ef4444;
                }
            }
        }

        if model.cities.length > 1 : Flickable {
            height: 28px;
            viewport-height: self.height;
            viewport-width: city-row.preferred-width.max(self.width);
            interactive: true;

            city-row := HorizontalLayout {
                spacing: 6px;
                alignment: start;

                for city[i] in model.cities : Rectangle {
                    height: 24px;
                    width: max(48px, city-label.preferred-width + 16px);
                    background: city.active ? Theme.accent-brand : Theme.surface-base;
                    border-radius: Theme.radius-md;

                    city-ta := TouchArea {
                        clicked => { root.select-city(i); }
                    }

                    city-label := Text {
                        text: city.name;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                        wrap: no-wrap;
                        overflow: elide;
                    }
                }
            }
        }

        Text {
            text: model.current-temp;
            color: Theme.text-primary;
            font-size: Theme.font-size-3xl;
            font-weight: Theme.weight-semibold;
        }

        HorizontalLayout {
            spacing: 8px;

            if model.condition-icon != "" : Text {
                text: weather-icon-glyph(model.condition-icon);
                color: Theme.accent-brand;
                font-size: Theme.font-size-xl;
                vertical-alignment: center;
            }

            Text {
                text: model.condition-label;
                color: Theme.text-secondary;
                font-size: Theme.font-size-md;
                vertical-alignment: center;
            }
        }

        if model.feels-like != "" : Text {
            text: model.feels-like;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
        }

        if model.humidity != "" || model.wind != "" : HorizontalLayout {
            spacing: 8px;

            if model.humidity != "" : Rectangle {
                background: Theme.surface-base;
                border-radius: Theme.radius-md;
                horizontal-stretch: 0;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 4px;
                    padding-bottom: 4px;

                    Text {
                        text: model.humidity;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }
            }

            if model.wind != "" : Rectangle {
                background: Theme.surface-base;
                border-radius: Theme.radius-md;
                horizontal-stretch: 0;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 4px;
                    padding-bottom: 4px;

                    Text {
                        text: model.wind;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.border-default;
            horizontal-stretch: 1;
        }

        if model.day-detail != "" : Text {
            text: model.day-detail;
            color: Theme.text-secondary;
            font-size: Theme.font-size-sm;
            wrap: word-wrap;
        }

        // Swipe horizontally to see more forecast days (up to 16). Tap a day for details.
        Flickable {
            height: 100px;
            viewport-height: self.height;
            viewport-width: forecast-row.preferred-width.max(self.width);
            interactive: true;

            forecast-row := HorizontalLayout {
                spacing: 6px;
                alignment: start;

                for day[i] in model.forecast : Rectangle {
                    width: 72px;
                    height: 96px;
                    background: day.selected ? Theme.surface-base : transparent;
                    border-radius: Theme.radius-md;
                    border-width: day.selected ? 1px : 0px;
                    border-color: Theme.accent-brand;

                    day-ta := TouchArea {
                        clicked => { root.select-day(i); }
                    }

                    VerticalLayout {
                        padding-top: 4px;
                        padding-bottom: 4px;
                        spacing: 4px;
                        alignment: center;
                        width: 100%;
                        height: 100%;

                        Text {
                            text: day.day-label;
                            color: day.selected ? Theme.text-primary : Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                            font-weight: day.selected ? Theme.weight-medium : Theme.weight-regular;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: weather-icon-glyph(day.icon);
                            color: Theme.accent-brand;
                            font-size: Theme.font-size-lg;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: day.range-text;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                        }

                        if day.precip-text != "" : Text {
                            text: day.precip-text;
                            color: Theme.accent-brand;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        Text {
            text: model.last-updated;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
            horizontal-alignment: end;
        }
    }

    if model.picker-open : Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000088;
        z: 50;

        TouchArea {
            clicked => { root.close-cities(); }
        }

        Rectangle {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;
            background: Theme.surface-raised;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: Theme.border-default;

            // Eat backdrop clicks so the panel stays open while interacting.
            TouchArea { }

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: space-between;

                    Text {
                        text: model.picker-title;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        font-weight: Theme.weight-medium;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Rectangle {
                        width: max(56px, close-label.preferred-width + 16px);
                        height: 28px;
                        background: close-ta.has-hover ? Theme.accent-brand : Theme.surface-base;
                        border-radius: Theme.radius-md;

                        close-ta := TouchArea {
                            clicked => { root.close-cities(); }
                        }
                        close-label := Text {
                            text: model.close-picker-label;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    height: 32px;
                    background: Theme.surface-base;
                    border-radius: Theme.radius-md;

                    search-input := TextInput {
                        x: 8px; y: 4px;
                        width: parent.width - 16px;
                        height: parent.height - 8px;
                        text: model.search-query;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        single-line: true;
                        edited => {
                            root.search-cities(self.text);
                        }
                    }
                    if model.search-query == "" : Text {
                        x: 8px; y: 4px;
                        width: parent.width - 16px;
                        height: parent.height - 8px;
                        text: model.search-placeholder;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }

                if model.cities.length > 0 : Flickable {
                    height: min(96px, cities-list.preferred-height);
                    viewport-width: self.width;
                    viewport-height: cities-list.preferred-height;
                    interactive: true;

                    cities-list := VerticalLayout {
                        spacing: 4px;

                        for city[i] in model.cities : Rectangle {
                            height: 32px;
                            background: city.active ? Theme.accent-brand : (saved-ta.has-hover ? Theme.surface-base : transparent);
                            border-radius: Theme.radius-md;

                            saved-ta := TouchArea {
                                clicked => { root.select-city(i); }
                            }

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 4px;

                                Text {
                                    text: city.name;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-size-sm;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    wrap: no-wrap;
                                    overflow: elide;
                                }

                                if model.cities.length > 1 : Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    y: 2px;
                                    background: remove-ta.has-hover ? Theme.surface-raised : transparent;
                                    border-radius: Theme.radius-md;

                                    remove-ta := TouchArea {
                                        clicked => { root.remove-city(i); }
                                    }
                                    if remove-ta.has-hover : Rectangle {
                                        x: parent.x - remove-hint.preferred-width;
                                        y: parent.height + 2px;
                                        width: remove-hint.preferred-width + 12px;
                                        height: remove-hint.preferred-height + 6px;
                                        background: Theme.surface-raised;
                                        border-radius: Theme.radius-md;
                                        border-width: 1px;
                                        border-color: Theme.border-default;
                                        z: 100;
                                        remove-hint := Text {
                                            x: 6px; y: 3px;
                                            text: model.remove-city-hint;
                                            color: Theme.text-secondary;
                                            font-size: Theme.font-size-sm;
                                        }
                                    }
                                    Text {
                                        text: "x";
                                        color: Theme.text-secondary;
                                        font-size: Theme.font-size-sm;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Theme.border-default;
                    horizontal-stretch: 1;
                }

                if model.search-busy : Text {
                    text: model.searching-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                }

                if !model.search-busy && model.search-query != "" && model.search-results.length == 0 : Text {
                    text: model.no-results-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                }

                Flickable {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: results-list.preferred-height.max(self.height);
                    interactive: true;

                    results-list := VerticalLayout {
                        spacing: 4px;

                        for hit[i] in model.search-results : Rectangle {
                            height: 48px;
                            background: hit-ta.has-hover ? Theme.surface-base : transparent;
                            border-radius: Theme.radius-md;

                            hit-ta := TouchArea {
                                clicked => {
                                    root.add-city(hit.name, hit.latitude, hit.longitude, hit.timezone);
                                }
                            }
                            if hit-ta.has-hover : Rectangle {
                                x: parent.x + 8px;
                                y: parent.height - 2px;
                                width: add-hint.preferred-width + 12px;
                                height: add-hint.preferred-height + 6px;
                                background: Theme.surface-raised;
                                border-radius: Theme.radius-md;
                                border-width: 1px;
                                border-color: Theme.border-default;
                                z: 100;
                                add-hint := Text {
                                    x: 6px; y: 3px;
                                    text: model.add-city-hint;
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-size-sm;
                                }
                            }

                            VerticalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                padding-top: 6px;
                                padding-bottom: 6px;
                                spacing: 2px;

                                Text {
                                    text: hit.name;
                                    color: Theme.text-primary;
                                    font-size: Theme.font-size-sm;
                                    wrap: no-wrap;
                                    overflow: elide;
                                }
                                if hit.detail != "" : Text {
                                    text: hit.detail;
                                    color: Theme.text-tertiary;
                                    font-size: Theme.font-size-sm;
                                    wrap: no-wrap;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
