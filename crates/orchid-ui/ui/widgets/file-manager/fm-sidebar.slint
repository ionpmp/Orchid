import { Theme } from "../../theme_global.slint";
import { FmSidebarItem } from "../../workspace/defs.slint";

export component FmSidebar inherits Rectangle {
    in property <[FmSidebarItem]> items;
    callback clicked(string);

    background: transparent;

    // ASCII/BMP glyphs — color emoji and many Unicode symbols are missing in Slint's default font on Windows.
    pure function sidebar-glyph(icon: string) -> string {
        return
            icon == "sidebar-favorites" ? "*" :
            icon == "sidebar-starred" ? "*" :
            icon == "sidebar-tags" ? "#" :
            icon == "sidebar-recent" ? "R" :
            icon == "sidebar-categories" ? ">" :
            icon == "sidebar-images" ? "I" :
            icon == "sidebar-documents" ? "D" :
            icon == "sidebar-video" ? "V" :
            icon == "sidebar-audio" ? "A" :
            icon == "sidebar-archives" ? "Z" :
            icon == "sidebar-managed" ? "M" :
            icon == "sidebar-network" ? "N" :
            icon == "sidebar-mount" ? "-" :
            "+";
    }

    Flickable {
        width: parent.width;
        height: parent.height;
        viewport-width: self.width;
        viewport-height: vlay.preferred-height;

        vlay := VerticalLayout {
            spacing: 1px;
            padding: 4px;

            for item[i] in items : Rectangle {
                height: item.is-section-header ? 28px : 32px;
                background: item.is-active
                    ? Theme.accent-brand
                    : (item-ta.has-hover && !item.is-section-header ? Theme.surface-raised : transparent);
                border-radius: Theme.radius-md;

                item-ta := TouchArea {
                    enabled: !item.is-section-header;
                    clicked => { root.clicked(item.id); }
                }

                HorizontalLayout {
                    padding-left: 8px + (item.indent * 12px);
                    padding-right: 8px;
                    spacing: 8px;

                    Text {
                        text: sidebar-glyph(item.icon);
                        color: item.is-section-header ? Theme.text-tertiary : Theme.accent-brand;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    Text {
                        text: item.label;
                        color: item.is-section-header ? Theme.text-tertiary : Theme.text-primary;
                        font-size: item.is-section-header ? Theme.font-size-sm : Theme.font-size-md;
                        font-weight: item.is-section-header ? Theme.weight-semibold : Theme.weight-regular;
                        vertical-alignment: center;
                        wrap: no-wrap;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                }
            }
        }
    }
}

