import { Theme } from "../../theme_global.slint";
import { FmConfirmDialog } from "../../workspace/defs.slint";

export component FmConfirmDialog inherits Rectangle {
    in property <FmConfirmDialog> dialog;
    callback yes();
    callback no();

    property <bool> info-only: dialog.pending-action == "" && dialog.cancel-label == "";

    background: #00000080;

    backdrop-ta := TouchArea {
        clicked => { root.no(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 360px;
        height: lay.preferred-height + 16px;
        background: Theme.surface-raised;
        border-radius: Theme.radius-md;
        drop-shadow-blur: 16px;
        drop-shadow-color: #00000080;

        lay := VerticalLayout {
            padding: 16px;
            spacing: 12px;

            Text {
                text: dialog.title;
                color: Theme.text-primary;
                font-size: Theme.font-size-lg;
                font-weight: Theme.weight-semibold;
            }

            Text {
                text: dialog.message;
                color: Theme.text-secondary;
                font-size: Theme.font-size-md;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: end;

                if dialog.cancel-label != "" : Rectangle {
                    width: 96px;
                    height: 32px;
                    background: no-ta.has-hover ? Theme.surface-base : transparent;
                    border-radius: Theme.radius-md;
                    no-ta := TouchArea { clicked => { root.no(); } }
                    Text {
                        text: dialog.cancel-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 96px;
                    height: 32px;
                    background: root.info-only
                        ? (yes-ta.has-hover ? Theme.accent-brand : #4d82ff88)
                        : (yes-ta.has-hover ? #ef4444 : #ef444488);
                    border-radius: Theme.radius-md;
                    yes-ta := TouchArea { clicked => { root.yes(); } }
                    Text {
                        text: dialog.confirm-label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
