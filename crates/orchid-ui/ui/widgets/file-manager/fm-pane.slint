import { Theme } from "../../theme_global.slint";
import { Strings } from "../../strings_global.slint";
import { FmPane as FmPaneModel, FmRenameState } from "../../workspace/defs.slint";
import { FmTabs } from "fm-tabs.slint";
import { FmToolbar } from "fm-toolbar.slint";
import { FmBreadcrumbs } from "fm-breadcrumbs.slint";
import { FmEntryList } from "fm-entry-list.slint";
import { FmEntryGrid } from "fm-entry-grid.slint";

export component FmPane inherits Rectangle {
    in property <FmPaneModel> pane;
    in property <int> pane-index;
    in property <bool> is-active;
    in property <string> clipboard-hint;
    in property <string> activity-hint;
    in property <bool> transfer-active;
    in property <float> transfer-progress;
    in property <FmRenameState> rename;
    in property <bool> drag-active;
    in property <string> drag-drop-target;
    in property <bool> drag-pane-target;

    callback tab-clicked(int, string);
    callback tab-closed(int, string);
    callback tab-new();
    callback new-folder();
    callback nav-back();
    callback nav-forward();
    callback nav-up();
    callback nav-home();
    callback breadcrumb-clicked(string);
    callback view-mode-cycle();
    callback sort-cycle();
    callback sort-column-clicked(int);
    callback quick-filter-changed(string);
    callback entry-clicked(string, bool);
    callback entry-shift-clicked(string);
    callback entry-double-clicked(string, bool);
    callback entry-context(string, length, length);
    callback pane-focused();
    callback select-all();
    callback delete-selected();
    callback copy-selected();
    callback paste-clipboard();
    callback rename-selected();
    callback deselect-all();
    callback open-selected();
    callback move-selection(int, bool);
    callback rename-commit(string, string);
    callback rename-cancel();
    callback entry-drag-start(string);
    callback entry-drag-hover(string);
    callback entry-drag-drop(string);
    callback entry-drag-cancel();
    callback pane-drag-hover();
    callback drop-on-current-dir();
    callback entry-drag-scroll(length, length, length, length);
    callback error-action();
    callback crumb-drag-hover(string);
    callback crumb-drag-drop(string);

    background: Theme.surface-base;

    property <bool> grid-view: pane.tabs.length > pane.active-tab && pane.active-tab >= 0
        && (pane.tabs[pane.active-tab].view-mode == 0 || pane.tabs[pane.active-tab].view-mode == 3);
    property <length> grid-tile: grid-view && pane.tabs[pane.active-tab].view-mode == 3 ? 220px : 100px;
    property <int> grid-cols: max(1, floor((root.width - 8px) / (grid-tile + 8px)));

    pane-keys := FocusScope {
        width: parent.width;
        height: parent.height;
        enabled: root.is-active;
        key-pressed(event) => {
            if (!root.is-active) {
                return reject;
            }
            if (event.modifiers.control && (event.text == "a" || event.text == "A")) {
                root.select-all();
                return accept;
            }
            if (event.modifiers.control && (event.text == "c" || event.text == "C")) {
                root.copy-selected();
                return accept;
            }
            if (event.modifiers.control && (event.text == "v" || event.text == "V")) {
                root.paste-clipboard();
                return accept;
            }
            if (event.modifiers.control && event.modifiers.shift
                && (event.text == "n" || event.text == "N")) {
                root.new-folder();
                return accept;
            }
            if (event.text == Key.F2) {
                root.rename-selected();
                return accept;
            }
            if (rename.active && event.text == Key.Escape) {
                root.rename-cancel();
                return accept;
            }
            if (drag-active && event.text == Key.Escape) {
                root.entry-drag-cancel();
                return accept;
            }
            if (event.text == Key.Delete) {
                root.delete-selected();
                return accept;
            }
            if (event.text == Key.Return) {
                if (!rename.active) {
                    root.open-selected();
                    return accept;
                }
                return reject;
            }
            if (event.text == Key.Backspace) {
                if (!rename.active) {
                    root.nav-up();
                    return accept;
                }
                return reject;
            }
            if (!rename.active) {
                if (event.text == Key.UpArrow) {
                    root.move-selection(root.grid-view ? -root.grid-cols : -1, event.modifiers.shift);
                    return accept;
                }
                if (event.text == Key.DownArrow) {
                    root.move-selection(root.grid-view ? root.grid-cols : 1, event.modifiers.shift);
                    return accept;
                }
                if (event.text == Key.LeftArrow) {
                    if (root.grid-view) {
                        root.move-selection(-1, event.modifiers.shift);
                        return accept;
                    }
                    return reject;
                }
                if (event.text == Key.RightArrow) {
                    if (root.grid-view) {
                        root.move-selection(1, event.modifiers.shift);
                        return accept;
                    }
                    return reject;
                }
                if (event.text == Key.Home) {
                    root.move-selection(-100000, event.modifiers.shift);
                    return accept;
                }
                if (event.text == Key.End) {
                    root.move-selection(100000, event.modifiers.shift);
                    return accept;
                }
            }
            if (event.text == Key.Escape) {
                root.deselect-all();
                return accept;
            }
            return reject;
        }
    }

    pane-ta := TouchArea {
        clicked => {
            root.pane-focused();
            pane-keys.focus();
        }
    }

    VerticalLayout {
        spacing: 0;

        FmTabs {
            height: 32px;
            tabs: pane.tabs;
            active-tab: pane.active-tab;
            tab-clicked(idx, id) => { root.tab-clicked(idx, id); }
            tab-closed(idx, id) => { root.tab-closed(idx, id); }
            tab-new => { root.tab-new(); }
        }

        if pane.tabs.length > pane.active-tab && pane.active-tab >= 0 : VerticalLayout {
            spacing: 0;
            vertical-stretch: 1;

            FmToolbar {
                height: 36px;
                tab: pane.tabs[pane.active-tab];
                new-folder => { root.new-folder(); }
                back => { root.nav-back(); }
                forward => { root.nav-forward(); }
                up => { root.nav-up(); }
                home => { root.nav-home(); }
                view-mode-cycle => { root.view-mode-cycle(); }
                sort-cycle => { root.sort-cycle(); }
                quick-filter-changed(q) => { root.quick-filter-changed(q); }
            }

            FmBreadcrumbs {
                height: 28px;
                breadcrumbs: pane.tabs[pane.active-tab].breadcrumbs;
                drag-active: root.drag-active;
                drag-drop-target: root.drag-drop-target;
                clicked(p) => { root.breadcrumb-clicked(p); }
                crumb-drag-hover(p) => { root.crumb-drag-hover(p); }
                crumb-drag-drop(p) => { root.crumb-drag-drop(p); }
            }

            Rectangle {
                vertical-stretch: 1;

                if pane.tabs[pane.active-tab].is-loading : VerticalLayout {
                    alignment: center;
                    Text {
                        text: Strings.fm-loading;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                    }
                }

                if !pane.tabs[pane.active-tab].is-loading
                    && pane.tabs[pane.active-tab].error == ""
                    && pane.tabs[pane.active-tab].entries.length == 0 : VerticalLayout {
                    alignment: center;
                    Text {
                        text: Strings.fm-empty-folder;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-md;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                if !pane.tabs[pane.active-tab].is-loading
                    && pane.tabs[pane.active-tab].error == ""
                    && pane.tabs[pane.active-tab].entries.length > 0
                    && (pane.tabs[pane.active-tab].view-mode == 1 || pane.tabs[pane.active-tab].view-mode == 2) :
                    FmEntryList {
                        width: parent.width;
                        height: parent.height;
                        entries: pane.tabs[pane.active-tab].entries;
                        rename: root.rename;
                        drag-active: root.drag-active;
                        drag-drop-target: root.drag-drop-target;
                        details: pane.tabs[pane.active-tab].view-mode == 2;
                        sort-by: pane.tabs[pane.active-tab].sort-by;
                        sort-descending: pane.tabs[pane.active-tab].sort-descending;
                        sort-name-label: pane.tabs[pane.active-tab].sort-name-label;
                        sort-size-label: pane.tabs[pane.active-tab].sort-size-label;
                        sort-modified-label: pane.tabs[pane.active-tab].sort-modified-label;
                        sort-type-label: pane.tabs[pane.active-tab].sort-type-label;
                        entry-clicked(p, ctrl) => {
                            root.pane-focused();
                            root.entry-clicked(p, ctrl);
                        }
                        entry-shift-clicked(p) => {
                            root.pane-focused();
                            root.entry-shift-clicked(p);
                        }
                        entry-double-clicked(p, is_dir) => {
                            root.pane-focused();
                            root.entry-double-clicked(p, is_dir);
                        }
                        entry-context(p, x, y) => { root.entry-context(p, x, y); }
                        sort-column-clicked(col) => { root.sort-column-clicked(col); }
                        rename-commit(old, new) => { root.rename-commit(old, new); }
                        rename-cancel => { root.rename-cancel(); }
                        entry-drag-start(p) => { root.entry-drag-start(p); }
                        entry-drag-hover(p) => { root.entry-drag-hover(p); }
                        entry-drag-drop(p) => { root.entry-drag-drop(p); }
                        entry-drag-cancel => { root.entry-drag-cancel(); }
                        pane-drag-hover => { root.pane-drag-hover(); }
                        drop-on-current-dir => { root.drop-on-current-dir(); }
                        drag-scroll-changed(mx, my, vy, w) => { root.entry-drag-scroll(mx, my, vy, w); }
                    }

                if !pane.tabs[pane.active-tab].is-loading
                    && pane.tabs[pane.active-tab].error == ""
                    && pane.tabs[pane.active-tab].entries.length > 0
                    && (pane.tabs[pane.active-tab].view-mode == 0 || pane.tabs[pane.active-tab].view-mode == 3) :
                    FmEntryGrid {
                        width: parent.width;
                        height: parent.height;
                        entries: pane.tabs[pane.active-tab].entries;
                        rename: root.rename;
                        drag-active: root.drag-active;
                        drag-drop-target: root.drag-drop-target;
                        large: pane.tabs[pane.active-tab].view-mode == 3;
                        entry-clicked(p, ctrl) => {
                            root.pane-focused();
                            root.entry-clicked(p, ctrl);
                        }
                        entry-shift-clicked(p) => {
                            root.pane-focused();
                            root.entry-shift-clicked(p);
                        }
                        entry-double-clicked(p, is_dir) => {
                            root.pane-focused();
                            root.entry-double-clicked(p, is_dir);
                        }
                        entry-context(p, x, y) => { root.entry-context(p, x, y); }
                        rename-commit(old, new) => { root.rename-commit(old, new); }
                        rename-cancel => { root.rename-cancel(); }
                        entry-drag-start(p) => { root.entry-drag-start(p); }
                        entry-drag-hover(p) => { root.entry-drag-hover(p); }
                        entry-drag-drop(p) => { root.entry-drag-drop(p); }
                        entry-drag-cancel => { root.entry-drag-cancel(); }
                        pane-drag-hover => { root.pane-drag-hover(); }
                        drop-on-current-dir => { root.drop-on-current-dir(); }
                        drag-scroll-changed(mx, my, vy, w) => { root.entry-drag-scroll(mx, my, vy, w); }
                    }

                if pane.tabs[pane.active-tab].error != "" : VerticalLayout {
                    alignment: center;
                    spacing: 8px;
                    Text {
                        text: pane.tabs[pane.active-tab].error;
                        color: #ef4444;
                        font-size: Theme.font-size-md;
                        font-weight: Theme.weight-semibold;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    if pane.tabs[pane.active-tab].error-action-label != "" : Rectangle {
                        height: 32px;
                        background: err-action-ta.has-hover ? Theme.accent-brand : Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;

                        err-action-ta := TouchArea {
                            clicked => { root.error-action(); }
                        }

                        Text {
                            text: pane.tabs[pane.active-tab].error-action-label;
                            color: err-action-ta.has-hover ? Theme.text-primary : Theme.accent-brand;
                            font-size: Theme.font-size-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle {
                height: transfer-active && transfer-progress > 0 ? 27px : 24px;
                background: Theme.surface-raised;
                VerticalLayout {
                    if transfer-active && transfer-progress > 0 : Rectangle {
                        height: 3px;
                        background: Theme.border-default;
                        Rectangle {
                            width: parent.width * transfer-progress;
                            height: parent.height;
                            background: Theme.accent-brand;
                        }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 12px;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 100%;

                            status-ta := TouchArea { }

                            Text {
                                text: pane.tabs[pane.active-tab].status-text;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }

                        if activity-hint != "" : Rectangle {
                            height: 100%;

                            activity-ta := TouchArea { }

                            Text {
                                text: activity-hint;
                                color: Theme.accent-brand;
                                font-size: Theme.font-size-sm;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }

                        if clipboard-hint != "" : Rectangle {
                            height: 100%;

                            clipboard-ta := TouchArea { }

                            Text {
                                text: clipboard-hint;
                                color: Theme.accent-brand;
                                font-size: Theme.font-size-sm;
                                vertical-alignment: center;
                                wrap: no-wrap;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}

