import { Theme } from "../../theme_global.slint";
import { Strings } from "../../strings_global.slint";
import { FmTab } from "../../workspace/defs.slint";

export component FmToolbar inherits Rectangle {
    in property <FmTab> tab;

    callback new-folder();
    callback back();
    callback forward();
    callback up();
    callback view-mode-cycle();
    callback sort-cycle();
    callback quick-filter-changed(string);

    background: Theme.surface-raised;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 4px;

        Rectangle {
            width: 28px; height: 28px;
            y: (parent.height - self.height) / 2;
            background: back-ta.has-hover && tab.can-back ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;
            opacity: tab.can-back ? 1.0 : 0.4;

            back-ta := TouchArea {
                enabled: tab.can-back;
                clicked => { root.back(); }
            }
            if back-ta.has-hover && tab.can-back : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: back-hint.preferred-width + 12px;
                height: back-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                back-hint := Text {
                    x: 6px; y: 3px;
                    text: Strings.fm-nav-back;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }
            Text { text: "←"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
        }

        Rectangle {
            width: 28px; height: 28px;
            y: (parent.height - self.height) / 2;
            background: fwd-ta.has-hover && tab.can-forward ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;
            opacity: tab.can-forward ? 1.0 : 0.4;

            fwd-ta := TouchArea {
                enabled: tab.can-forward;
                clicked => { root.forward(); }
            }
            if fwd-ta.has-hover && tab.can-forward : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: fwd-hint.preferred-width + 12px;
                height: fwd-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                fwd-hint := Text {
                    x: 6px; y: 3px;
                    text: Strings.fm-nav-forward;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }
            Text { text: "→"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
        }

        Rectangle {
            width: 28px; height: 28px;
            y: (parent.height - self.height) / 2;
            background: up-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            up-ta := TouchArea {
                clicked => { root.up(); }
            }
            if up-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: up-hint.preferred-width + 12px;
                height: up-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                up-hint := Text {
                    x: 6px; y: 3px;
                    text: Strings.fm-nav-up;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }
            Text { text: "↑"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
        }

        Rectangle {
            width: 28px; height: 28px;
            y: (parent.height - self.height) / 2;
            background: nf-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            nf-ta := TouchArea {
                clicked => { root.new-folder(); }
            }
            if nf-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: nf-hint.preferred-width + 12px;
                height: nf-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                nf-hint := Text {
                    x: 6px; y: 3px;
                    text: Strings.fm-action-new-folder;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }
            Text { text: "+"; color: Theme.text-primary; font-size: Theme.font-size-md; horizontal-alignment: center; vertical-alignment: center; }
        }

        Rectangle { width: 8px; }

        Rectangle {
            width: 36px; height: 28px;
            y: (parent.height - self.height) / 2;
            background: sort-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            sort-ta := TouchArea {
                clicked => { root.sort-cycle(); }
            }
            if sort-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: sort-hint.preferred-width + 12px;
                height: sort-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                sort-hint := Text {
                    x: 6px; y: 3px;
                    text: tab.sort-by == 0 ? tab.sort-name-label
                        : tab.sort-by == 1 ? tab.sort-size-label
                        : tab.sort-by == 2 ? tab.sort-modified-label
                        : tab.sort-type-label;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }
            Text {
                text: tab.sort-by == 0 ? (tab.sort-descending ? "A↓" : "A↑")
                    : tab.sort-by == 1 ? (tab.sort-descending ? "S↓" : "S↑")
                    : tab.sort-by == 2 ? (tab.sort-descending ? "M↓" : "M↑")
                    : (tab.sort-descending ? "T↓" : "T↑");
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            width: 28px; height: 28px;
            y: (parent.height - self.height) / 2;
            background: vm-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            vm-ta := TouchArea {
                clicked => { root.view-mode-cycle(); }
            }
            if vm-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: vm-hint.preferred-width + 12px;
                height: vm-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                vm-hint := Text {
                    x: 6px; y: 3px;
                    text: tab.view-mode == 0 ? Strings.fm-view-icons
                        : tab.view-mode == 1 ? Strings.fm-view-list
                        : tab.view-mode == 2 ? Strings.fm-view-details
                        : Strings.fm-view-gallery;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }
            Text {
                text: tab.view-mode == 0 ? "▦"
                    : tab.view-mode == 1 ? "≡"
                    : tab.view-mode == 2 ? "☰"
                    : "▢";
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle { width: 8px; }

        Rectangle {
            horizontal-stretch: 1;
            height: 28px;
            y: (parent.height - self.height) / 2;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: filter-fs.has-focus ? Theme.accent-brand : Theme.border-default;

            filter-fs := FocusScope {
                width: parent.width;
                height: parent.height;
                TouchArea { clicked => { filter-fs.focus(); } }

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;

                    // ASCII/BMP glyph — color emoji missing in Slint's default font on Windows.
                    Text {
                        text: "?";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: parent.height;

                        if tab.quick-filter == "" : Text {
                            width: parent.width;
                            height: parent.height;
                            text: Strings.fm-quick-filter-placeholder;
                            color: Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            vertical-alignment: center;
                        }

                        TextInput {
                            width: parent.width;
                            height: parent.height;
                            text: tab.quick-filter;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            vertical-alignment: center;
                            single-line: true;
                            edited => { root.quick-filter-changed(self.text); }
                        }
                    }
                }
            }
        }
    }
}

