import { Theme } from "../../theme_global.slint";
import { FmEntry, FmRenameState } from "../../workspace/defs.slint";

export component FmEntryList inherits Rectangle {
    in property <[FmEntry]> entries;
    in property <bool> details;
    in property <int> sort-by;
    in property <bool> sort-descending;
    in property <string> sort-name-label;
    in property <string> sort-size-label;
    in property <string> sort-modified-label;
    in property <string> sort-type-label;
    in property <FmRenameState> rename;

    callback entry-clicked(string, bool);
    callback entry-shift-clicked(string);
    callback entry-double-clicked(string, bool);
    callback entry-context(string, length, length);
    callback sort-column-clicked(int);
    callback rename-commit(string, string);
    callback rename-cancel();

    background: transparent;

    Flickable {
        width: parent.width;
        height: parent.height;
        viewport-width: self.width;
        viewport-height: max(self.height, list-stack.preferred-height);

        bg-ta := TouchArea {
            width: parent.width;
            height: parent.height;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                    root.entry-context("", self.mouse-x, self.mouse-y);
                }
            }
        }

        list-stack := VerticalLayout {
            spacing: 0;

            if details : Rectangle {
                height: 28px;
                background: Theme.surface-raised;

                Rectangle {
                    y: parent.height - 1px;
                    height: 1px;
                    background: Theme.border-default;
                }

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;

                    Rectangle { width: 20px; height: 1px; }

                    Rectangle {
                        min-width: 240px;
                        height: 28px;
                        background: name-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        name-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(0); }
                        }
                        Text {
                            text: sort-name-label + (sort-by == 0 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 0 ? Theme.text-primary : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 0 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        min-width: 100px;
                        height: 28px;
                        background: size-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        size-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(1); }
                        }
                        Text {
                            text: sort-size-label + (sort-by == 1 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 1 ? Theme.text-primary : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 1 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        min-width: 140px;
                        height: 28px;
                        background: mod-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        mod-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(2); }
                        }
                        Text {
                            text: sort-modified-label + (sort-by == 2 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 2 ? Theme.text-primary : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 2 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 28px;
                        background: type-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        type-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(3); }
                        }
                        Text {
                            text: sort-type-label + (sort-by == 3 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 3 ? Theme.text-primary : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 3 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            for entry[i] in entries : Rectangle {
                height: 28px;
                background: entry.is-selected
                    ? Theme.accent-brand
                    : (row-ta.has-hover ? Theme.surface-raised : transparent);

                row-ta := TouchArea {
                    double-clicked => { root.entry-double-clicked(entry.path, entry.is-dir); }
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                            if (e.modifiers.shift) {
                                root.entry-shift-clicked(entry.path);
                            } else {
                                root.entry-clicked(entry.path, e.modifiers.control);
                            }
                        }
                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                            root.entry-context(entry.path, self.mouse-x, self.mouse-y);
                        }
                    }
                }

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;

                    if entry.color-label != "" : Rectangle {
                        width: 4px;
                        height: 16px;
                        y: (parent.height - self.height) / 2;
                        background:
                            entry.color-label == "red" ? #ef4444
                            : entry.color-label == "orange" ? #f97316
                            : entry.color-label == "yellow" ? #eab308
                            : entry.color-label == "green" ? #22c55e
                            : entry.color-label == "blue" ? #3b82f6
                            : entry.color-label == "purple" ? #a855f7
                            : Theme.accent-brand;
                        border-radius: 2px;
                    }

                    if entry.has-thumbnail : Image {
                        width: 20px;
                        height: 20px;
                        source: entry.thumbnail;
                        image-fit: contain;
                        y: (parent.height - self.height) / 2;
                    }

                    if !entry.has-thumbnail : Text {
                        text: entry.is-dir ? "📁"
                            : entry.is-encrypted ? "🔒"
                            : entry.is-managed ? "🗃"
                            : "📄";
                        color: Theme.accent-brand;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    if rename.active && entry.path == rename.path : rename-fs := FocusScope {
                        min-width: details ? 240px : 120px;
                        horizontal-stretch: details ? 0 : 1;

                        key-pressed(e) => {
                            if (e.text == Key.Return) {
                                root.rename-commit(rename.path, rename-input.text);
                                return accept;
                            }
                            if (e.text == Key.Escape) {
                                root.rename-cancel();
                                return accept;
                            }
                            return reject;
                        }

                        rename-input := TextInput {
                            text: rename.proposed-name;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            single-line: true;
                        }

                        init => { rename-fs.focus(); }
                    }

                    if !rename.active || entry.path != rename.path : Text {
                        text: entry.name;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        horizontal-stretch: details ? 0 : 1;
                        min-width: details ? 240px : 0px;
                        wrap: no-wrap;
                        overflow: elide;
                    }

                    if entry.is-starred : Text {
                        text: "★";
                        color: #eab308;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    if details : Text {
                        text: entry.size-text;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        min-width: 100px;
                    }

                    if details : Text {
                        text: entry.modified-text;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        min-width: 140px;
                    }

                    if details : Text {
                        text: entry.type-text;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }
            }
        }
    }
}
