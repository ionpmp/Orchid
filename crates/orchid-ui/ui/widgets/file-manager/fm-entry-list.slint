import { Theme } from "../../theme_global.slint";
import { FmEntry, FmRenameState } from "../../workspace/defs.slint";
import { FmEntryIcon } from "fm-icons.slint";

export component FmEntryList inherits Rectangle {
    in property <[FmEntry]> entries;
    in property <int> entry-total-count;
    in property <length> virtual-pad-top;
    in property <length> virtual-content-height;
    in property <bool> details;
    in property <int> sort-by;
    in property <bool> sort-descending;
    in property <string> sort-name-label;
    in property <string> sort-size-label;
    in property <string> sort-modified-label;
    in property <string> sort-type-label;
    in property <FmRenameState> rename;
    in property <bool> drag-active;
    in property <string> drag-drop-target;

    callback entry-clicked(string, bool);
    callback entry-shift-clicked(string);
    callback entry-double-clicked(string, bool);
    callback entry-context(string, length, length);
    callback sort-column-clicked(int);
    callback rename-commit(string, string);
    callback rename-cancel();
    callback entry-drag-start(string);
    callback entry-drag-hover(string);
    callback entry-drag-drop(string);
    callback entry-drag-cancel();
    callback pane-drag-hover();
    callback drop-on-current-dir();
    callback drag-scroll-changed(length, length, length, length);
    callback viewport-changed(length, length, length);

    background: transparent;

    property <string> pressing-path: "";
    property <length> press-x: 0px;
    property <length> press-y: 0px;
    property <length> drag-threshold: 6px;

    property <length> row-height: 28px;
    property <length> header-height: details ? 28px : 0px;
    property <bool> virtualized: virtual-content-height > 0px;
    property <length> bottom-pad: virtualized
        ? max(0px, virtual-content-height - virtual-pad-top - header-height - entries.length * row-height)
        : 0px;

    list-flick := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-width: self.width;
        viewport-height: virtualized
            ? max(self.height, virtual-content-height)
            : max(self.height, list-stack.preferred-height);

        changed viewport-y => {
            root.viewport-changed(self.viewport-y, self.height, self.width);
            if (drag-active) {
                root.drag-scroll-changed(bg-ta.mouse-x, bg-ta.mouse-y, self.viewport-y, self.width);
            }
        }

        changed width => {
            root.viewport-changed(self.viewport-y, self.height, self.width);
        }

        changed height => {
            root.viewport-changed(self.viewport-y, self.height, self.width);
        }

        bg-ta := TouchArea {
            width: parent.width;
            height: parent.height;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                    root.entry-context("", self.mouse-x, self.mouse-y);
                }
                if (drag-active) {
                    if (e.kind == PointerEventKind.move) {
                        root.pane-drag-hover();
                    }
                    if (e.kind == PointerEventKind.up) {
                        root.drop-on-current-dir();
                    }
                }
            }
        }

        list-stack := VerticalLayout {
            spacing: 0;

            if details : Rectangle {
                height: 28px;
                background: Theme.surface-raised;

                Rectangle {
                    y: parent.height - 1px;
                    height: 1px;
                    background: Theme.border-default;
                }

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;

                    Rectangle { width: 20px; height: 1px; }

                    Rectangle {
                        min-width: 240px;
                        height: 28px;
                        background: name-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        name-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(0); }
                        }
                        Text {
                            text: sort-name-label + (sort-by == 0 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 0 ? Theme.accent-brand : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 0 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        min-width: 100px;
                        height: 28px;
                        background: size-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        size-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(1); }
                        }
                        Text {
                            text: sort-size-label + (sort-by == 1 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 1 ? Theme.accent-brand : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 1 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        min-width: 140px;
                        height: 28px;
                        background: mod-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        mod-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(2); }
                        }
                        Text {
                            text: sort-modified-label + (sort-by == 2 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 2 ? Theme.accent-brand : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 2 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 28px;
                        background: type-hdr-ta.has-hover ? Theme.surface-base : transparent;

                        type-hdr-ta := TouchArea {
                            clicked => { root.sort-column-clicked(3); }
                        }
                        Text {
                            text: sort-type-label + (sort-by == 3 ? (sort-descending ? " ↓" : " ↑") : "");
                            color: sort-by == 3 ? Theme.accent-brand : Theme.text-tertiary;
                            font-size: Theme.font-size-sm;
                            font-weight: sort-by == 3 ? Theme.weight-semibold : Theme.weight-regular;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            if virtual-pad-top > 0px : Rectangle {
                height: virtual-pad-top;
            }

            for entry[i] in entries : Rectangle {
                height: row-height;
                background: entry.is-selected
                    ? Theme.accent-brand
                    : (row-ta.has-hover ? Theme.surface-raised : transparent);
                border-width: drag-active && entry.is-dir && entry.path == drag-drop-target ? 1px : 0px;
                border-color: Theme.accent-brand;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;

                    if entry.color-label != "" : Rectangle {
                        width: 4px;
                        height: 16px;
                        y: (parent.height - self.height) / 2;
                        background:
                            entry.color-label == "red" ? #ef4444
                            : entry.color-label == "orange" ? #f97316
                            : entry.color-label == "yellow" ? #eab308
                            : entry.color-label == "green" ? #22c55e
                            : entry.color-label == "blue" ? #3b82f6
                            : entry.color-label == "purple" ? #a855f7
                            : Theme.accent-brand;
                        border-radius: 2px;
                    }

                    if entry.has-thumbnail : Image {
                        width: 20px;
                        height: 20px;
                        source: entry.thumbnail;
                        image-fit: contain;
                        y: (parent.height - self.height) / 2;
                    }

                    if !entry.has-thumbnail : Rectangle {
                        width: 16px;
                        height: 20px;
                        y: (parent.height - self.height) / 2;

                        FmEntryIcon {
                            y: (parent.height - self.height) / 2;
                            icon-size: 16px;
                            is-dir: entry.is-dir;
                            is-encrypted: entry.is-encrypted;
                            is-managed: entry.is-managed;
                        }
                    }

                    if rename.active && entry.path == rename.path : rename-fs := FocusScope {
                        min-width: details ? 240px : 120px;
                        horizontal-stretch: details ? 0 : 1;

                        key-pressed(e) => {
                            if (e.text == Key.Return) {
                                root.rename-commit(rename.path, rename-input.text);
                                return accept;
                            }
                            if (e.text == Key.Escape) {
                                root.rename-cancel();
                                return accept;
                            }
                            return reject;
                        }

                        rename-input := TextInput {
                            text: rename.proposed-name;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            single-line: true;
                        }

                        init => { rename-fs.focus(); }
                    }

                    if !rename.active || entry.path != rename.path : Text {
                        text: entry.name;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        horizontal-stretch: details ? 0 : 1;
                        min-width: details ? 240px : 0px;
                        wrap: no-wrap;
                        overflow: elide;
                    }

                    if entry.is-starred : Text {
                        text: "*";
                        color: #eab308;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }

                    if details : Text {
                        text: entry.size-text;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        min-width: 100px;
                    }

                    if details : Text {
                        text: entry.modified-text;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        min-width: 140px;
                    }

                    if details : Text {
                        text: entry.type-text;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                row-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    enabled: !(rename.active && entry.path == rename.path);
                    double-clicked => {
                        root.pressing-path = "";
                        root.entry-double-clicked(entry.path, entry.is-dir);
                    }
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                            if (e.modifiers.shift) {
                                root.entry-shift-clicked(entry.path);
                            } else {
                                root.entry-clicked(entry.path, e.modifiers.control);
                            }
                            if (entry.is-selected) {
                                root.pressing-path = entry.path;
                                root.press-x = self.mouse-x;
                                root.press-y = self.mouse-y;
                            } else {
                                root.pressing-path = "";
                            }
                        }
                        if (pressing-path != "" && e.kind == PointerEventKind.move) {
                            if (abs(self.mouse-x - press-x) >= drag-threshold
                                || abs(self.mouse-y - press-y) >= drag-threshold) {
                                root.entry-drag-start(pressing-path);
                                root.pressing-path = "";
                            }
                        }
                        if (drag-active && entry.is-dir) {
                            if (e.kind == PointerEventKind.move) {
                                root.entry-drag-hover(entry.path);
                            }
                            if (e.kind == PointerEventKind.up) {
                                root.entry-drag-drop(entry.path);
                            }
                        }
                        if (e.kind == PointerEventKind.up) {
                            if (drag-active && !entry.is-dir) {
                                root.entry-drag-cancel();
                            }
                            root.pressing-path = "";
                        }
                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                            root.entry-context(entry.path, self.mouse-x, self.mouse-y);
                        }
                    }
                }
            }

            if bottom-pad > 0px : Rectangle {
                height: bottom-pad;
            }
        }
    }
}
