import { Theme } from "../../theme_global.slint";
import { Strings } from "../../strings_global.slint";
import { FmTab } from "../../workspace/defs.slint";

export component FmTabs inherits Rectangle {
    in property <[FmTab]> tabs;
    in property <int> active-tab;

    callback tab-clicked(int, string);
    callback tab-closed(int, string);
    callback tab-new();

    background: Theme.surface-raised;

    HorizontalLayout {
        padding: 2px;
        spacing: 2px;

        for tab[i] in tabs : Rectangle {
            width: 160px;
            height: 28px;
            background: i == active-tab ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;
            border-width: i == active-tab ? 1px : 0px;
            border-color: i == active-tab ? Theme.accent-brand : transparent;

            tab-ta := TouchArea {
                clicked => { root.tab-clicked(i, tab.id); }
            }
            if tab-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: tab-hint.preferred-width + 12px;
                height: tab-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                tab-hint := Text {
                    x: 6px; y: 3px;
                    text: tab.path-display;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;

                Text {
                    text: tab.path-display;
                    color: i == active-tab ? Theme.accent-brand : Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    wrap: no-wrap;
                    overflow: elide;
                }

                Rectangle {
                    width: 18px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: close-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: 9px;

                    close-ta := TouchArea {
                        clicked => { root.tab-closed(i, tab.id); }
                    }
                    if close-ta.has-hover : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: close-hint.preferred-width + 12px;
                        height: close-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        close-hint := Text {
                            x: 6px; y: 3px;
                            text: Strings.fm-action-close-tab;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    Text {
                        text: "×";
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            width: 28px;
            height: 28px;
            background: new-ta.has-hover ? Theme.surface-base : transparent;
            border-radius: Theme.radius-md;

            new-ta := TouchArea {
                clicked => { root.tab-new(); }
            }
            if new-ta.has-hover : Rectangle {
                x: parent.x;
                y: parent.height + 2px;
                width: new-hint.preferred-width + 12px;
                height: new-hint.preferred-height + 6px;
                background: Theme.surface-raised;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                z: 100;
                new-hint := Text {
                    x: 6px; y: 3px;
                    text: Strings.fm-action-new-tab;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                }
            }

            Text {
                text: "+";
                color: Theme.text-secondary;
                font-size: Theme.font-size-md;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
