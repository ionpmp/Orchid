import { Theme } from "../../theme_global.slint";

/// Folder / file glyphs drawn with rectangles (no emoji / font dependency).
export component FmEntryIcon inherits Rectangle {
    in property <bool> is-dir;
    in property <bool> is-encrypted;
    in property <bool> is-managed;
    in property <length> icon-size: 16px;

    width: icon-size;
    height: icon-size;
    background: transparent;

    if is-dir : Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        Rectangle {
            x: 1px;
            y: 2px;
            width: parent.width * 0.4;
            height: 4px;
            background: Theme.accent-brand;
            border-radius: 2px;
        }
        Rectangle {
            x: 1px;
            y: 5px;
            width: parent.width - 2px;
            height: parent.height - 7px;
            background: Theme.accent-brand;
            border-radius: 2px;
            opacity: 0.85;
        }
    }

    if !is-dir && !is-encrypted && !is-managed : Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        Rectangle {
            x: 3px;
            y: 1px;
            width: parent.width - 6px;
            height: parent.height - 2px;
            background: Theme.text-secondary;
            border-radius: 2px;
            opacity: 0.55;
        }
        Rectangle {
            x: parent.width - 7px;
            y: 1px;
            width: 4px;
            height: 4px;
            background: Theme.surface-raised;
        }
    }

    if !is-dir && is-encrypted : Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        Rectangle {
            x: (parent.width - 8px) / 2;
            y: 2px;
            width: 8px;
            height: 6px;
            border-width: 2px;
            border-color: Theme.accent-brand;
            background: transparent;
            border-radius: 3px;
        }
        Rectangle {
            x: (parent.width - 10px) / 2;
            y: 7px;
            width: 10px;
            height: 8px;
            background: Theme.accent-brand;
            border-radius: 2px;
        }
    }

    if !is-dir && is-managed && !is-encrypted : Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            border-width: 1.5px;
            border-color: Theme.accent-brand;
            background: transparent;
            border-radius: 2px;
        }
        Rectangle {
            x: 4px;
            y: 5px;
            width: parent.width - 8px;
            height: 2px;
            background: Theme.accent-brand;
        }
        Rectangle {
            x: 4px;
            y: 9px;
            width: parent.width - 8px;
            height: 2px;
            background: Theme.accent-brand;
            opacity: 0.7;
        }
    }
}

/// Sidebar item icons drawn with rectangles.
export component FmSidebarIcon inherits Rectangle {
    in property <string> icon-id;
    in property <length> icon-size: 14px;

    width: icon-size;
    height: icon-size;
    background: transparent;

    if icon-id == "sidebar-favorites" || icon-id == "sidebar-starred" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle {
            x: parent.width * 0.15;
            y: parent.height * 0.35;
            width: parent.width * 0.7;
            height: parent.height * 0.35;
            background: Theme.accent-brand;
            border-radius: 1px;
        }
        Rectangle {
            x: parent.width * 0.35;
            y: parent.height * 0.15;
            width: parent.width * 0.3;
            height: parent.height * 0.7;
            background: Theme.accent-brand;
            border-radius: 1px;
        }
    }

    if icon-id == "sidebar-tags" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle { x: 3px; y: 3px; width: 2px; height: parent.height - 6px; background: Theme.accent-brand; }
        Rectangle { x: parent.width - 5px; y: 3px; width: 2px; height: parent.height - 6px; background: Theme.accent-brand; }
        Rectangle { x: 2px; y: 4px; width: parent.width - 4px; height: 2px; background: Theme.accent-brand; }
        Rectangle { x: 2px; y: parent.height - 6px; width: parent.width - 4px; height: 2px; background: Theme.accent-brand; }
    }

    if icon-id == "sidebar-recent" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle {
            x: 1px; y: 1px;
            width: parent.width - 2px; height: parent.height - 2px;
            border-radius: parent.width;
            border-width: 1.5px;
            border-color: Theme.accent-brand;
            background: transparent;
        }
        Rectangle {
            x: parent.width / 2 - 1px; y: 3px;
            width: 2px; height: parent.height * 0.35;
            background: Theme.accent-brand;
        }
    }

    if icon-id == "sidebar-categories" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle { x: 3px; y: 3px; width: 8px; height: 2px; background: Theme.text-tertiary; }
        Rectangle { x: 3px; y: 7px; width: 10px; height: 2px; background: Theme.text-tertiary; }
        Rectangle { x: 3px; y: 11px; width: 6px; height: 2px; background: Theme.text-tertiary; }
    }

    if icon-id == "sidebar-images" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle {
            x: 1px; y: 2px;
            width: parent.width - 2px; height: parent.height - 4px;
            border-width: 1.5px; border-color: Theme.accent-brand;
            background: transparent; border-radius: 2px;
        }
        Rectangle {
            x: 3px; y: parent.height - 7px;
            width: parent.width * 0.45; height: 3px;
            background: Theme.accent-brand; opacity: 0.7;
        }
    }

    if icon-id == "sidebar-documents" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle {
            x: 3px; y: 1px;
            width: parent.width - 6px; height: parent.height - 2px;
            background: Theme.accent-brand; opacity: 0.75; border-radius: 2px;
        }
        Rectangle { x: 5px; y: 4px; width: parent.width - 10px; height: 1.5px; background: Theme.surface-base; }
        Rectangle { x: 5px; y: 7px; width: parent.width - 10px; height: 1.5px; background: Theme.surface-base; }
        Rectangle { x: 5px; y: 10px; width: parent.width - 12px; height: 1.5px; background: Theme.surface-base; }
    }

    if icon-id == "sidebar-video" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle { x: 3px; y: 3px; width: 3px; height: parent.height - 6px; background: Theme.accent-brand; }
        Rectangle { x: 6px; y: 5px; width: 3px; height: parent.height - 10px; background: Theme.accent-brand; }
        Rectangle { x: 9px; y: 7px; width: 3px; height: parent.height - 14px; background: Theme.accent-brand; }
    }

    if icon-id == "sidebar-audio" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle { x: 2px; y: parent.height * 0.45; width: 2px; height: parent.height * 0.3; background: Theme.accent-brand; }
        Rectangle { x: 5px; y: parent.height * 0.3; width: 2px; height: parent.height * 0.45; background: Theme.accent-brand; }
        Rectangle { x: 8px; y: parent.height * 0.2; width: 2px; height: parent.height * 0.55; background: Theme.accent-brand; }
        Rectangle { x: 11px; y: parent.height * 0.35; width: 2px; height: parent.height * 0.4; background: Theme.accent-brand; }
    }

    if icon-id == "sidebar-archives" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle {
            x: 2px; y: 2px;
            width: parent.width - 4px; height: parent.height - 4px;
            background: Theme.accent-brand; opacity: 0.8; border-radius: 2px;
        }
        Rectangle {
            x: 2px; y: parent.height / 2 - 1px;
            width: parent.width - 4px; height: 2px;
            background: Theme.surface-base;
        }
    }

    if icon-id == "sidebar-managed" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle {
            x: 1px; y: 1px;
            width: parent.width - 2px; height: parent.height - 2px;
            border-width: 1.5px; border-color: Theme.accent-brand;
            background: transparent; border-radius: 2px;
        }
        Rectangle { x: 4px; y: 4px; width: parent.width - 8px; height: 2px; background: Theme.accent-brand; }
        Rectangle { x: 4px; y: 8px; width: parent.width - 8px; height: 2px; background: Theme.accent-brand; opacity: 0.7; }
    }

    if icon-id == "sidebar-network" || icon-id == "sidebar-mount" : Rectangle {
        width: parent.width;
        height: parent.height;
        Rectangle {
            x: parent.width * 0.15; y: parent.height * 0.15;
            width: parent.width * 0.7; height: parent.height * 0.7;
            border-radius: parent.width;
            border-width: 1.5px; border-color: Theme.accent-brand;
            background: transparent;
        }
        Rectangle {
            x: parent.width * 0.35; y: parent.height * 0.35;
            width: parent.width * 0.3; height: parent.height * 0.3;
            border-radius: parent.width;
            background: Theme.accent-brand;
        }
    }
}
