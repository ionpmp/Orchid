import { Theme } from "../../theme_global.slint";
import { FmBreadcrumb } from "../../workspace/defs.slint";

export component FmBreadcrumbs inherits Rectangle {
    in property <[FmBreadcrumb]> breadcrumbs;
    in property <bool> drag-active;
    in property <string> drag-drop-target;
    callback clicked(string);
    callback crumb-drag-hover(string);
    callback crumb-drag-drop(string);

    background: Theme.surface-base;

    Flickable {
        width: parent.width;
        height: parent.height;
        viewport-width: hlay.preferred-width;
        viewport-height: self.height;

        hlay := HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            spacing: 4px;
            alignment: start;

            for crumb[i] in breadcrumbs : HorizontalLayout {
                spacing: 4px;
                if i > 0 : Text {
                    text: "›";
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    vertical-alignment: center;
                }

                Rectangle {
                    background: crumb-ta.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    border-width: (drag-active && crumb.path == drag-drop-target)
                        || crumb-ta.has-hover ? 1px : 0px;
                    border-color: Theme.accent-brand;

                    crumb-ta := TouchArea {
                        clicked => { root.clicked(crumb.path); }
                        pointer-event(e) => {
                            if (drag-active) {
                                if (e.kind == PointerEventKind.move) {
                                    root.crumb-drag-hover(crumb.path);
                                }
                                if (e.kind == PointerEventKind.up) {
                                    root.crumb-drag-drop(crumb.path);
                                }
                            }
                        }
                    }
                    if crumb-ta.has-hover && crumb.path != "" : Rectangle {
                        x: parent.x;
                        y: parent.height + 2px;
                        width: crumb-hint.preferred-width + 12px;
                        height: crumb-hint.preferred-height + 6px;
                        background: Theme.surface-raised;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        z: 100;
                        crumb-hint := Text {
                            x: 6px; y: 3px;
                            text: crumb.path;
                            color: Theme.text-secondary;
                            font-size: Theme.font-size-sm;
                        }
                    }

                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        Text {
                            text: crumb.label;
                            color: i == breadcrumbs.length - 1 ? Theme.accent-brand : Theme.text-secondary;
                            font-weight: i == breadcrumbs.length - 1 ? Theme.weight-semibold : Theme.weight-regular;
                            font-size: Theme.font-size-sm;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

