import { Theme } from "../../theme_global.slint";
import { FmEntry, FmRenameState } from "../../workspace/defs.slint";
import { FmEntryIcon } from "fm-icons.slint";

export component FmEntryGrid inherits Rectangle {
    in property <[FmEntry]> entries;
    in property <int> entry-total-count;
    in property <length> virtual-pad-top;
    in property <length> virtual-content-height;
    in property <bool> large;
    in property <FmRenameState> rename;
    in property <bool> drag-active;
    in property <string> drag-drop-target;

    property <string> pressing-path: "";
    property <length> press-x: 0px;
    property <length> press-y: 0px;
    property <length> drag-threshold: 6px;

    callback entry-clicked(string, bool);
    callback entry-shift-clicked(string);
    callback entry-double-clicked(string, bool);
    callback entry-context(string, length, length);
    callback rename-commit(string, string);
    callback rename-cancel();
    callback entry-drag-start(string);
    callback entry-drag-hover(string);
    callback entry-drag-drop(string);
    callback entry-drag-cancel();
    callback pane-drag-hover();
    callback drop-on-current-dir();
    callback drag-scroll-changed(length, length, length, length);
    callback viewport-changed(length, length, length);

    property <length> tile-size: large ? 220px : 100px;
    property <length> tile-height: large ? 240px : 120px;
    property <length> tile-spacing: 8px;
    property <int> columns: max(1, floor((root.width - tile-spacing) / (tile-size + tile-spacing)));
    property <bool> virtualized: virtual-content-height > 0px;
    property <int> total-count: entry-total-count > 0 ? entry-total-count : entries.length;
    property <int> first-index: virtualized
        ? max(0, floor(virtual-pad-top / (tile-height + tile-spacing)) * columns)
        : 0;

    background: transparent;

    grid-flick := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-width: self.width;
        viewport-height: virtualized
            ? max(self.height, virtual-content-height)
            : max(self.height, ceil(entries.length / columns) * (tile-height + tile-spacing) + tile-spacing);

        changed viewport-y => {
            root.viewport-changed(self.viewport-y, self.height, self.width);
            if (drag-active) {
                root.drag-scroll-changed(bg-ta.mouse-x, bg-ta.mouse-y, self.viewport-y, self.width);
            }
        }

        changed width => {
            root.viewport-changed(self.viewport-y, self.height, self.width);
        }

        changed height => {
            root.viewport-changed(self.viewport-y, self.height, self.width);
        }

        bg-ta := TouchArea {
            width: parent.width;
            height: parent.height;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                    root.entry-context("", self.mouse-x, self.mouse-y);
                }
                if (drag-active) {
                    if (e.kind == PointerEventKind.move) {
                        root.pane-drag-hover();
                    }
                    if (e.kind == PointerEventKind.up) {
                        root.drop-on-current-dir();
                    }
                }
            }
        }

        for entry[i] in entries : Rectangle {
            x: tile-spacing + (mod(first-index + i, columns) * (tile-size + tile-spacing));
            y: tile-spacing + (floor((first-index + i) / columns) * (tile-height + tile-spacing));
            width: tile-size;
            height: tile-height;
            background: entry.is-selected
                ? Theme.accent-brand
                : (tile-ta.has-hover ? Theme.surface-raised : transparent);
            border-radius: Theme.radius-md;
            border-width: drag-active && entry.is-dir && entry.path == drag-drop-target ? 2px : 0px;
            border-color: Theme.accent-brand;

            VerticalLayout {
                padding: 6px;
                spacing: 4px;

                Rectangle {
                    height: tile-size - 32px;
                    background: Theme.surface-base;
                    border-radius: Theme.radius-md;

                    if entry.has-thumbnail : Image {
                        source: entry.thumbnail;
                        width: parent.width - 8px;
                        height: parent.height - 8px;
                        x: 4px;
                        y: 4px;
                        image-fit: contain;
                    }

                    if !entry.has-thumbnail : Rectangle {
                        width: parent.width;
                        height: parent.height;

                        FmEntryIcon {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            icon-size: large ? 64px : 36px;
                            is-dir: entry.is-dir;
                            is-encrypted: entry.is-encrypted;
                            is-managed: entry.is-managed;
                        }
                    }
                }

                if rename.active && entry.path == rename.path : rename-fs := FocusScope {
                    horizontal-stretch: 1;

                    key-pressed(e) => {
                        if (e.text == Key.Return) {
                            root.rename-commit(rename.path, rename-input.text);
                            return accept;
                        }
                        if (e.text == Key.Escape) {
                            root.rename-cancel();
                            return accept;
                        }
                        return reject;
                    }

                    rename-input := TextInput {
                        text: rename.proposed-name;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        horizontal-alignment: center;
                        horizontal-stretch: 1;
                        single-line: true;
                    }

                    init => { rename-fs.focus(); }
                }

                if !rename.active || entry.path != rename.path : Text {
                    text: entry.name;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }

            if entry.is-starred : Text {
                x: parent.width - 20px;
                y: 4px;
                text: "*";
                color: #eab308;
                font-size: Theme.font-size-sm;
            }

            tile-ta := TouchArea {
                width: 100%;
                height: 100%;
                enabled: !(rename.active && entry.path == rename.path);
                double-clicked => {
                    root.pressing-path = "";
                    root.entry-double-clicked(entry.path, entry.is-dir);
                }
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                        if (e.modifiers.shift) {
                            root.entry-shift-clicked(entry.path);
                        } else {
                            root.entry-clicked(entry.path, e.modifiers.control);
                        }
                        if (entry.is-selected) {
                            root.pressing-path = entry.path;
                            root.press-x = self.mouse-x;
                            root.press-y = self.mouse-y;
                        } else {
                            root.pressing-path = "";
                        }
                    }
                    if (pressing-path != "" && e.kind == PointerEventKind.move) {
                        if (abs(self.mouse-x - press-x) >= drag-threshold
                            || abs(self.mouse-y - press-y) >= drag-threshold) {
                            root.entry-drag-start(pressing-path);
                            root.pressing-path = "";
                        }
                    }
                    if (drag-active && entry.is-dir) {
                        if (e.kind == PointerEventKind.move) {
                            root.entry-drag-hover(entry.path);
                        }
                        if (e.kind == PointerEventKind.up) {
                            root.entry-drag-drop(entry.path);
                        }
                    }
                    if (e.kind == PointerEventKind.up) {
                        if (drag-active && !entry.is-dir) {
                            root.entry-drag-cancel();
                        }
                        root.pressing-path = "";
                    }
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                        root.entry-context(entry.path, self.mouse-x, self.mouse-y);
                    }
                }
            }
        }
    }
}

