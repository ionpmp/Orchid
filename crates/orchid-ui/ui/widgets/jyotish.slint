import { Theme } from "../theme_global.slint";
import { JyotishModel, JyotishPanchangaRow, JyotishPlanetEntry } from "../workspace/defs.slint";

export component JyotishView inherits Rectangle {
    in property <JyotishModel> model;

    callback prev-day();
    callback next-day();
    callback go-today();

    background: transparent;

    VerticalLayout {
        padding: 12px;
        spacing: 10px;
        alignment: start;

        // Date navigation
        HorizontalLayout {
            spacing: 8px;
            alignment: center;

            nav-prev := TouchArea {
                width: 28px;
                height: 28px;
                clicked => { root.prev-day(); }
                Rectangle {
                    background: nav-prev.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    Text {
                        width: 100%; height: 100%;
                        text: "<";
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        font-weight: Theme.weight-semibold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            VerticalLayout {
                spacing: 2px;
                alignment: center;
                horizontal-stretch: 1;

                Text {
                    text: model.date-text;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-md;
                    font-weight: Theme.weight-semibold;
                    horizontal-alignment: center;
                    wrap: no-wrap;
                    overflow: elide;
                }

                Text {
                    text: model.location-name;
                    color: Theme.text-secondary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    wrap: no-wrap;
                    overflow: elide;
                }
            }

            nav-next := TouchArea {
                width: 28px;
                height: 28px;
                clicked => { root.next-day(); }
                Rectangle {
                    background: nav-next.has-hover ? Theme.surface-raised : transparent;
                    border-radius: Theme.radius-md;
                    Text {
                        width: 100%; height: 100%;
                        text: ">";
                        color: Theme.text-primary;
                        font-size: Theme.font-size-md;
                        font-weight: Theme.weight-semibold;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        if !model.is-today : today-btn := TouchArea {
            height: 22px;
            clicked => { root.go-today(); }
            Rectangle {
                background: today-btn.has-hover ? Theme.surface-raised : transparent;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-default;
                Text {
                    width: 100%; height: 100%;
                    text: model.today-label;
                    color: Theme.accent-brand;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: model.vara-label;
            color: Theme.accent-brand;
            font-size: Theme.font-size-lg;
            font-weight: Theme.weight-semibold;
            horizontal-alignment: center;
        }

        if model.is-loading : Text {
            text: model.loading-label;
            color: Theme.text-secondary;
            font-size: Theme.font-size-sm;
            horizontal-alignment: center;
        }

        if !model.is-loading : Rectangle {
            height: 1px;
            background: Theme.border-default;
            horizontal-stretch: 1;
        }

        // Panchanga rows
        if !model.is-loading : VerticalLayout {
            spacing: 0px;
            for entry[i] in model.panchanga : Rectangle {
                height: 22px;

                row-ta := TouchArea { }
                if row-ta.has-hover && (entry.label != "" || entry.value != "") : Rectangle {
                    x: parent.x;
                    y: parent.height + 2px;
                    width: row-hint.preferred-width + 12px;
                    height: row-hint.preferred-height + 6px;
                    background: Theme.surface-raised;
                    border-radius: Theme.radius-md;
                    border-width: 1px;
                    border-color: Theme.border-default;
                    z: 100;
                    row-hint := Text {
                        x: 6px; y: 3px;
                        text: entry.label + ": " + entry.value;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: space-between;
                    width: 100%;
                    height: 100%;

                    Text {
                        text: entry.label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        wrap: no-wrap;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: entry.value;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                        wrap: no-wrap;
                        overflow: elide;
                    }
                }
            }
        }

        // Sun times
        if !model.is-loading && (model.sunrise-text != "" || model.sunset-text != "") : HorizontalLayout {
            spacing: 12px;
            alignment: space-around;

            if model.sunrise-text != "" : Text {
                text: model.sunrise-label + " " + model.sunrise-text;
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                wrap: no-wrap;
                overflow: elide;
            }
            if model.sunset-text != "" : Text {
                text: model.sunset-label + " " + model.sunset-text;
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                horizontal-alignment: center;
                wrap: no-wrap;
                overflow: elide;
            }
        }

        // Graha table
        if !model.is-loading && model.show-planets && model.planets.length > 0 : VerticalLayout {
            spacing: 4px;

            Text {
                text: model.planets-title;
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                font-weight: Theme.weight-semibold;
            }

            for planet[i] in model.planets : Rectangle {
                height: 20px;
                HorizontalLayout {
                    spacing: 6px;
                    alignment: space-between;
                    width: 100%;
                    height: 100%;

                    Text {
                        text: planet.graha;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        wrap: no-wrap;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: planet.rashi;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        wrap: no-wrap;
                        overflow: elide;
                    }

                    Text {
                        text: planet.degree-text + (planet.is-retrograde ? " R" : "");
                        color: planet.is-retrograde ? Theme.accent-brand : Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                        wrap: no-wrap;
                        overflow: elide;
                        min-width: 56px;
                    }
                }
            }
        }

        if !model.is-loading : Text {
            text: model.ayanamsa-label;
            color: Theme.text-tertiary;
            font-size: Theme.font-size-sm;
            horizontal-alignment: center;
            wrap: no-wrap;
            overflow: elide;
        }

        Rectangle { vertical-stretch: 1; }
    }
}
