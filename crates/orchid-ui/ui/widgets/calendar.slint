import { Theme } from "../theme_global.slint";
import {
    CalendarModel, CalendarDayEntry, CalendarEventEntry, CalendarUpcomingEntry,
    CalendarWeekdayEntry
} from "../workspace/defs.slint";

component CalToolBtn inherits Rectangle {
    in property <string> label;
    in property <string> tip;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked();

    width: max(28px, label-txt.preferred-width + 14px);
    height: 26px;
    border-radius: Theme.radius-md;
    background: !root.enabled ? transparent :
        root.primary ? Theme.accent-brand :
        root.danger ? #e35d6a :
        ta.has-hover ? Theme.surface-raised : transparent;
    border-width: (root.primary || root.danger) ? 0 : (ta.has-hover ? 1px : 0);
    border-color: Theme.border-default;

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    label-txt := Text {
        width: 100%;
        height: 100%;
        text: root.label;
        color: !root.enabled ? Theme.text-tertiary :
            (root.primary || root.danger) ? Theme.surface-base : Theme.text-secondary;
        font-size: Theme.font-size-sm;
        font-weight: Theme.weight-medium;
        font-family: Theme.font-family-sans;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if ta.has-hover && tip != "" : Rectangle {
        x: (parent.width - tip-box.preferred-width - 12px) / 2;
        y: -tip-box.preferred-height - 8px;
        width: tip-box.preferred-width + 12px;
        height: tip-box.preferred-height + 6px;
        background: Theme.surface-raised;
        border-radius: Theme.radius-md;
        border-width: 1px;
        border-color: Theme.border-default;
        z: 50;
        tip-box := Text {
            x: 6px; y: 3px;
            text: root.tip;
            color: Theme.text-secondary;
            font-size: Theme.font-size-sm;
        }
    }
}

component ColorDot inherits Rectangle {
    in property <int> color-index;
    width: 5px;
    height: 5px;
    border-radius: 2.5px;
    background: color-index == 0 ? #5B8DEF :
        color-index == 1 ? #34C759 :
        color-index == 2 ? #FF9F0A :
        color-index == 3 ? #FF453A :
        color-index == 4 ? #BF5AF2 :
        #64D2FF;
}

component DayCell inherits Rectangle {
    in property <CalendarDayEntry> day;
    callback clicked();
    callback double-clicked();

    border-radius: Theme.radius-md;
    background: day.is-selected ? Theme.accent-brand :
        day.is-today ? Theme.surface-raised :
        ta.has-hover ? Theme.surface-raised : transparent;
    border-width: day.is-today && !day.is-selected ? 1px : 0;
    border-color: Theme.accent-brand;

    ta := TouchArea {
        clicked => { root.clicked(); }
        double-clicked => { root.double-clicked(); }
    }

    VerticalLayout {
        padding-top: 3px;
        padding-bottom: 2px;
        spacing: 2px;
        alignment: center;

        Text {
            text: day.day;
            color: !day.in-month ? Theme.text-tertiary :
                day.is-selected ? Theme.surface-base : Theme.text-primary;
            font-size: Theme.font-size-sm;
            font-weight: day.is-today || day.is-selected ? Theme.weight-semibold : Theme.weight-regular;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            spacing: 2px;
            alignment: center;
            height: 6px;
            for c[idx] in day.dot-colors : ColorDot {
                color-index: c;
            }
        }
    }
}

component EventRow inherits Rectangle {
    in property <CalendarEventEntry> event;
    in property <string> all-day-label;
    in property <string> untitled-label;
    callback clicked();

    height: event.notes-preview == "" ? 44px : 58px;
    border-radius: Theme.radius-md;
    background: ta.has-hover ? Theme.surface-raised : transparent;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 10px;
        alignment: center;

        Rectangle {
            width: 4px;
            height: event.notes-preview == "" ? 28px : 40px;
            border-radius: 2px;
            background: event.color == 0 ? #5B8DEF :
                event.color == 1 ? #34C759 :
                event.color == 2 ? #FF9F0A :
                event.color == 3 ? #FF453A :
                event.color == 4 ? #BF5AF2 :
                #64D2FF;
        }

        VerticalLayout {
            spacing: 2px;
            alignment: center;
            Text {
                text: event.title == "" ? untitled-label : event.title;
                color: Theme.text-primary;
                font-size: Theme.font-size-md;
                font-weight: Theme.weight-medium;
                overflow: elide;
            }
            Text {
                text: event.all-day ? all-day-label : event.time-label;
                color: Theme.text-secondary;
                font-size: Theme.font-size-sm;
                overflow: elide;
            }
            if event.notes-preview != "" : Text {
                text: event.notes-preview;
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                overflow: elide;
            }
        }
    }
}

component ColorSwatch inherits Rectangle {
    in property <int> color-index;
    in property <bool> selected;
    callback clicked();

    width: 22px;
    height: 22px;
    border-radius: 11px;
    background: color-index == 0 ? #5B8DEF :
        color-index == 1 ? #34C759 :
        color-index == 2 ? #FF9F0A :
        color-index == 3 ? #FF453A :
        color-index == 4 ? #BF5AF2 :
        #64D2FF;
    border-width: selected ? 2px : 0;
    border-color: Theme.text-primary;

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component UpcomingChip inherits Rectangle {
    in property <CalendarUpcomingEntry> item;
    in property <string> all-day-label;
    in property <string> untitled-label;
    callback clicked();

    height: 34px;
    border-radius: Theme.radius-md;
    background: ta.has-hover ? Theme.surface-raised : Theme.surface-base;
    border-width: 1px;
    border-color: Theme.border-default;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 8px;
        alignment: center;

        Rectangle {
            width: 3px;
            height: 18px;
            border-radius: 1.5px;
            background: item.color == 0 ? #5B8DEF :
                item.color == 1 ? #34C759 :
                item.color == 2 ? #FF9F0A :
                item.color == 3 ? #FF453A :
                item.color == 4 ? #BF5AF2 :
                #64D2FF;
        }
        VerticalLayout {
            spacing: 0px;
            alignment: center;
            Text {
                text: item.title == "" ? untitled-label : item.title;
                color: Theme.text-primary;
                font-size: Theme.font-size-sm;
                font-weight: Theme.weight-medium;
                overflow: elide;
            }
            Text {
                text: item.date-label + " · " + (item.all-day ? all-day-label : item.time-label);
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                overflow: elide;
            }
        }
    }
}

component TimeRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> time-text;
    in property <int> step-minutes: 15;
    in property <string> tip-minus;
    in property <string> tip-plus;
    in property <string> tip-hour-minus;
    in property <string> tip-hour-plus;
    callback nudge(int);

    spacing: 4px;
    alignment: center;

    Text {
        text: root.label;
        color: Theme.text-secondary;
        font-size: Theme.font-size-sm;
        vertical-alignment: center;
        min-width: 36px;
    }
    CalToolBtn {
        label: "«";
        tip: root.tip-hour-minus;
        clicked => { root.nudge(-60); }
    }
    CalToolBtn {
        label: "−";
        tip: root.tip-minus;
        clicked => { root.nudge(-root.step-minutes); }
    }
    Text {
        text: root.time-text;
        color: Theme.text-primary;
        font-size: Theme.font-size-md;
        font-family: Theme.font-family-mono;
        vertical-alignment: center;
        min-width: 48px;
        horizontal-alignment: center;
    }
    CalToolBtn {
        label: "+";
        tip: root.tip-plus;
        clicked => { root.nudge(root.step-minutes); }
    }
    CalToolBtn {
        label: "»";
        tip: root.tip-hour-plus;
        clicked => { root.nudge(60); }
    }
}

export component CalendarView inherits Rectangle {
    in property <CalendarModel> model;

    callback select-date(string);
    callback activate-day(string);
    callback shift-month(int);
    callback goto-today();
    callback open-new();
    callback open-edit(string);
    callback close-editor();
    callback save-editor();
    callback duplicate-editor();
    callback set-color-filter(int);
    callback request-delete();
    callback confirm-delete();
    callback cancel-delete();
    callback editor-title-changed(string);
    callback editor-date-changed(string);
    callback shift-editor-date(int);
    callback editor-all-day-changed(bool);
    callback nudge-editor-start(int);
    callback nudge-editor-end(int);
    callback editor-notes-changed(string);
    callback editor-color-changed(int);

    background: transparent;

    property <string> draft-title: model.editor-title;
    property <string> draft-notes: model.editor-notes;
    property <string> synced-editor-id: model.editor-event-id;
    property <bool> synced-editor-open: model.editor-open;

    changed model => {
        if model.editor-open != synced-editor-open
            || model.editor-event-id != synced-editor-id
            || (!model.editor-open) {
            draft-title = model.editor-title;
            draft-notes = model.editor-notes;
            synced-editor-id = model.editor-event-id;
            synced-editor-open = model.editor-open;
        }
    }

    VerticalLayout {
        padding: 10px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 6px;
            alignment: center;

            CalToolBtn {
                label: "«";
                tip: model.tip-prev-year;
                clicked => { root.shift-month(-12); }
            }
            CalToolBtn {
                label: "◀";
                tip: model.tip-prev;
                clicked => { root.shift-month(-1); }
            }
            Text {
                horizontal-stretch: 1;
                text: model.month-title;
                color: Theme.text-primary;
                font-size: Theme.font-size-lg;
                font-weight: Theme.weight-semibold;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            CalToolBtn {
                label: "▶";
                tip: model.tip-next;
                clicked => { root.shift-month(1); }
            }
            CalToolBtn {
                label: "»";
                tip: model.tip-next-year;
                clicked => { root.shift-month(12); }
            }
            CalToolBtn {
                label: model.today-label;
                tip: model.tip-today;
                clicked => { root.goto-today(); }
            }
            CalToolBtn {
                label: "+";
                tip: model.tip-add;
                primary: true;
                clicked => { root.open-new(); }
            }
        }

        HorizontalLayout {
            spacing: 6px;
            alignment: center;
            Text {
                text: model.filter-title;
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                vertical-alignment: center;
            }
            CalToolBtn {
                label: model.filter-all-label;
                primary: model.color-filter < 0;
                clicked => { root.set-color-filter(-1); }
            }
            for c[ci] in model.color-options : ColorSwatch {
                color-index: c;
                selected: model.color-filter == c;
                clicked => { root.set-color-filter(c); }
            }
        }

        if model.show-upcoming && model.upcoming.length > 0 : VerticalLayout {
            spacing: 4px;
            Text {
                text: model.upcoming-title;
                color: Theme.text-tertiary;
                font-size: Theme.font-size-sm;
                font-weight: Theme.weight-medium;
            }
            Flickable {
                height: 38px;
                viewport-width: upcoming-row.preferred-width;
                viewport-height: 38px;

                upcoming-row := HorizontalLayout {
                    spacing: 6px;
                    height: 34px;
                    for u[i] in model.upcoming : UpcomingChip {
                        item: u;
                        all-day-label: model.all-day-label;
                        untitled-label: model.untitled-label;
                        min-width: 160px;
                        max-width: 220px;
                        clicked => {
                            root.select-date(u.date-key);
                            root.open-edit(u.id);
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 4px;
                horizontal-stretch: 3;
                min-width: 180px;

                HorizontalLayout {
                    spacing: 2px;
                    height: 20px;
                    for wd[i] in model.weekdays : Text {
                        horizontal-stretch: 1;
                        text: wd.label;
                        color: Theme.text-tertiary;
                        font-size: Theme.font-size-sm;
                        font-weight: Theme.weight-medium;
                        horizontal-alignment: center;
                    }
                }

                GridLayout {
                    spacing: 2px;
                    vertical-stretch: 1;
                    for day[i] in model.days : DayCell {
                        row: i / 7;
                        col: mod(i, 7);
                        day: day;
                        clicked => { root.select-date(day.date-key); }
                        double-clicked => { root.activate-day(day.date-key); }
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.border-default;
            }

            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 2;
                min-width: 140px;

                Text {
                    text: model.selected-label;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-md;
                    font-weight: Theme.weight-semibold;
                }
                if model.events.length > 0 : Text {
                    text: model.events-count-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                }

                if model.events.length == 0 : Text {
                    vertical-stretch: 1;
                    text: model.empty-label;
                    color: Theme.text-tertiary;
                    font-size: Theme.font-size-sm;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                }

                if model.events.length > 0 : Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width;
                    viewport-height: agenda-col.preferred-height;

                    agenda-col := VerticalLayout {
                        spacing: 2px;
                        width: parent.width;
                        for ev[i] in model.events : EventRow {
                            event: ev;
                            all-day-label: model.all-day-label;
                            untitled-label: model.untitled-label;
                            clicked => { root.open-edit(ev.id); }
                        }
                    }
                }
            }
        }
    }

    // Editor overlay
    if model.editor-open : Rectangle {
        width: 100%;
        height: 100%;
        background: #00000088;
        z: 40;

        TouchArea {
            clicked => { root.close-editor(); }
        }

        Rectangle {
            width: min(parent.width - 24px, 360px);
            height: min(parent.height - 24px, 460px);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: Theme.border-default;

            TouchArea { }

            VerticalLayout {
                padding: 14px;
                spacing: 10px;

                Text {
                    text: model.editor-is-new ? model.add-label : model.edit-label;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-lg;
                    font-weight: Theme.weight-semibold;
                }

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: model.title-field-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                    Rectangle {
                        height: 32px;
                        border-radius: Theme.radius-md;
                        background: Theme.surface-raised;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        title-edit := TextInput {
                            x: 8px; y: 0;
                            width: parent.width - 16px;
                            height: 100%;
                            text: root.draft-title;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-md;
                            single-line: true;
                            edited => {
                                root.draft-title = self.text;
                                root.editor-title-changed(self.text);
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: model.date-field-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: center;
                        CalToolBtn {
                            label: "◀";
                            tip: model.tip-date-prev;
                            clicked => { root.shift-editor-date(-1); }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 1px;
                            Text {
                                text: model.editor-date-label;
                                color: Theme.text-primary;
                                font-size: Theme.font-size-md;
                                font-weight: Theme.weight-medium;
                                horizontal-alignment: center;
                                overflow: elide;
                            }
                            Text {
                                text: model.editor-date;
                                color: Theme.text-tertiary;
                                font-size: Theme.font-size-sm;
                                font-family: Theme.font-family-mono;
                                horizontal-alignment: center;
                            }
                        }
                        CalToolBtn {
                            label: "▶";
                            tip: model.tip-date-next;
                            clicked => { root.shift-editor-date(1); }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Rectangle {
                        width: 18px;
                        height: 18px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        background: model.editor-all-day ? Theme.accent-brand : Theme.surface-raised;
                        TouchArea {
                            clicked => {
                                root.editor-all-day-changed(!model.editor-all-day);
                            }
                        }
                        if model.editor-all-day : Text {
                            width: 100%; height: 100%;
                            text: "✓";
                            color: Theme.surface-base;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Text {
                        text: model.all-day-label;
                        color: Theme.text-primary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                }

                if !model.editor-all-day : VerticalLayout {
                    spacing: 6px;
                    TimeRow {
                        label: model.start-label;
                        time-text: model.editor-start-text;
                        step-minutes: model.time-step-minutes;
                        tip-minus: model.tip-time-minus;
                        tip-plus: model.tip-time-plus;
                        tip-hour-minus: model.tip-hour-minus;
                        tip-hour-plus: model.tip-hour-plus;
                        nudge(d) => { root.nudge-editor-start(d); }
                    }
                    TimeRow {
                        label: model.end-label;
                        step-minutes: model.time-step-minutes;
                        time-text: model.editor-end-text;
                        tip-minus: model.tip-time-minus;
                        tip-plus: model.tip-time-plus;
                        tip-hour-minus: model.tip-hour-minus;
                        tip-hour-plus: model.tip-hour-plus;
                        nudge(d) => { root.nudge-editor-end(d); }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    vertical-stretch: 1;
                    Text {
                        text: model.notes-field-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                    }
                    Rectangle {
                        vertical-stretch: 1;
                        min-height: 56px;
                        border-radius: Theme.radius-md;
                        background: Theme.surface-raised;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        notes-edit := TextInput {
                            x: 8px; y: 6px;
                            width: parent.width - 16px;
                            height: parent.height - 12px;
                            text: root.draft-notes;
                            color: Theme.text-primary;
                            font-size: Theme.font-size-sm;
                            wrap: word-wrap;
                            edited => {
                                root.draft-notes = self.text;
                                root.editor-notes-changed(self.text);
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;
                    Text {
                        text: model.color-label;
                        color: Theme.text-secondary;
                        font-size: Theme.font-size-sm;
                        vertical-alignment: center;
                    }
                    for c[ci] in model.color-options : ColorSwatch {
                        color-index: c;
                        selected: model.editor-color == c;
                        clicked => { root.editor-color-changed(c); }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    if !model.editor-is-new : CalToolBtn {
                        label: model.duplicate-label;
                        clicked => { root.duplicate-editor(); }
                    }
                    if !model.editor-is-new : CalToolBtn {
                        label: model.delete-label;
                        danger: true;
                        clicked => { root.request-delete(); }
                    }
                    CalToolBtn {
                        label: model.cancel-label;
                        clicked => { root.close-editor(); }
                    }
                    CalToolBtn {
                        label: model.save-label;
                        primary: true;
                        clicked => { root.save-editor(); }
                    }
                }
            }
        }
    }

    // Delete confirmation
    if model.editor-open && model.delete-confirm-open : Rectangle {
        width: 100%;
        height: 100%;
        background: #00000066;
        z: 50;

        TouchArea {
            clicked => { root.cancel-delete(); }
        }

        Rectangle {
            width: min(parent.width - 48px, 280px);
            height: 140px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.surface-base;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: Theme.border-default;

            TouchArea { }

            VerticalLayout {
                padding: 16px;
                spacing: 14px;

                Text {
                    text: model.delete-confirm-title;
                    color: Theme.text-primary;
                    font-size: Theme.font-size-md;
                    font-weight: Theme.weight-semibold;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    CalToolBtn {
                        label: model.cancel-label;
                        clicked => { root.cancel-delete(); }
                    }
                    CalToolBtn {
                        label: model.delete-confirm-yes;
                        danger: true;
                        clicked => { root.confirm-delete(); }
                    }
                }
            }
        }
    }
}
